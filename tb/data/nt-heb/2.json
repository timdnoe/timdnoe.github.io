, δι’ ὃν τὰ πάντα καὶ δι’ οὗ τὰ πάντα, πολλοὺς υἱοὺς εἰς δόξαν ἀγαγόντα τὸν ἀρχηγὸν τῆς σωτηρίας αὐτῶν διὰ παθημάτων τελειῶσαι.","lemmas":["πρέπω","γάρ","αὐτός","διά","ὅς","ὁ","πᾶς","καί","πολύς","υἱός","εἰς","δόξα","ἄγω","ἀρχηγός","σωτηρία","πάθημα","τελειόω"],"tr":"For [it] was fitting to him through whom [are] all the [things], and through whom [are] all the [things], having led many sons into glory to have perfected the author of their salvation through sufferings.","para":null,"para_continued":false,"words":[{"form":"Ἔπρεπεν","lemma":"πρέπω","type":"verb","code":"V"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"αὐτῷ,","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"δι’","lemma":"διά","type":"preposition","code":"P"},{"form":"ὃν","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πάντα","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"δι’","lemma":"διά","type":"preposition","code":"P"},{"form":"οὗ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πάντα,","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"πολλοὺς","lemma":"πολύς","type":"adjective","code":"A"},{"form":"υἱοὺς","lemma":"υἱός","type":"noun","code":"N"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"δόξαν","lemma":"δόξα","type":"noun","code":"N"},{"form":"ἀγαγόντα","lemma":"ἄγω","type":"verb","code":"V"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀρχηγὸν","lemma":"ἀρχηγός","type":"noun","code":"N"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"σωτηρίας","lemma":"σωτηρία","type":"noun","code":"N"},{"form":"αὐτῶν","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"παθημάτων","lemma":"πάθημα","type":"noun","code":"N"},{"form":"τελ