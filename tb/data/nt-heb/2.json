oun","code":"RP"},{"form":"θέλησιν;","lemma":"θέλησις","type":"noun","code":"N"}]},{"v":5,"ref":"Heb 2:5","grc":"Οὐ γὰρ ἀγγέλοις ὑπέταξεν τὴν οἰκουμένην τὴν μέλλουσαν, περὶ ἧς λαλοῦμεν·","lemmas":["οὐ","γάρ","ἄγγελος","ὑποτάσσω","ὁ","οἰκουμένη","μέλλω","περί","ὅς","λαλέω"],"tr":"For [he] subjected the world about to [be], about which [we] speak, not to angels,","para":null,"para_continued":false,"words":[{"form":"Οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"ἀγγέλοις","lemma":"ἄγγελος","type":"noun","code":"N"},{"form":"ὑπέταξεν","lemma":"ὑποτάσσω","type":"verb","code":"V"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"οἰκουμένην","lemma":"οἰκουμένη","type":"noun","code":"N"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"μέλλουσαν,","lemma":"μέλλω","type":"verb","code":"V"},{"form":"περὶ","lemma":"περί","type":"preposition","code":"P"},{"form":"ἧς","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"λαλοῦμεν·","lemma":"λαλέω","type":"verb","code":"V"}]},{"v":6,"ref":"Heb 2:6","grc":"διεμαρτύρατο δέ πού τις λέγων· Τί ἐστιν ἄνθρωπος ὅτι μιμνῄσκῃ αὐτοῦ, ἢ υἱὸς ἀνθρώπου ὅτι ἐπισκέπτῃ αὐτόν;","lemmas":["διαμαρτύρομαι","δέ","πού","τις","λέγω","τίς","εἰμί","ἄνθρωπος","ὅτι","μιμνήσκομαι","αὐτός","ἤ","υἱός","ἐπισκέπτομαι"],"tr":"but somewhere someone bore witness, saying, “What is [a] person that [you] may remember him, or son of man that [you] may visit him?","para":null,"para_continued":false,"words":[{"form":"διεμαρτύρατο","lemma":"διαμαρτύρομαι","type":"verb","code":"V"},{"form":"δέ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"πού","lemma":"πού","type":"adverb","code":"D"},{"form":"τις","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"λέγων·","lemma":"λέγω","type":"verb","code":"V"},{"form":"Τί","lemma":"τίς","type":"interrogative_pronoun","code":"RI"},{"form":"ἐστιν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"ἄνθρωπος","