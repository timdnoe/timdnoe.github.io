{"book":"nt-heb","book_name":"Epistle to the Hebrews","chapter":7,"chapter_label":"7","prev":6,"next":8,"verses":[{"v":1,"ref":"Heb 7:1","grc":"Οὗτος γὰρ ὁ Μελχισέδεκ, βασιλεὺς Σαλήμ, ἱερεὺς τοῦ θεοῦ τοῦ ὑψίστου, ⸀ὁ συναντήσας Ἀβραὰμ ὑποστρέφοντι ἀπὸ τῆς κοπῆς τῶν βασιλέων καὶ εὐλογήσας αὐτόν,","lemmas":["οὗτος","γάρ","ὁ","Μελχισέδεκ","βασιλεύς","Σαλήμ","ἱερεύς","θεός","ὕψιστος","συναντάω","Ἀβραάμ","ὑποστρέφω","ἀπό","κοπή","καί","εὐλογέω","αὐτός"],"tr":"For this Melchizedek, king of Salem, priest of God the highest, the [one] having met Abraham [while] returning from the slaughter of the kings and having blessed him,","para":null,"para_continued":false,"words":[{"form":"Οὗτος","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Μελχισέδεκ,","lemma":"Μελχισέδεκ","type":"noun","code":"N"},{"form":"βασιλεὺς","lemma":"βασιλεύς","type":"noun","code":"N"},{"form":"Σαλήμ,","lemma":"Σαλήμ","type":"noun","code":"N"},{"form":"ἱερεὺς","lemma":"ἱερεύς","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεοῦ","lemma":"θεός","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ὑψίστου,","lemma":"ὕψιστος","type":"adjective","code":"A"},{"form":"⸀ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"συναντήσας","lemma":"συναντάω","type":"verb","code":"V"},{"form":"Ἀβραὰμ","lemma":"Ἀβραάμ","type":"noun","code":"N"},{"form":"ὑποστρέφοντι","lemma":"ὑποστρέφω","type":"verb","code":"V"},{"form":"ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"κοπῆς","lemma":"κοπή","type":"noun","code":"N"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"βασιλέων","lemma":"βασιλεύς","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"εὐλογήσας","lemma":"εὐλογέω","type":"verb","code":"V"},{"form":"αὐτόν,","lemma":"αὐτός","type":"personal_pronoun","code":"RP"}]},{"v":2,"ref":"Heb 7:2","grc":"ᾧ καὶ δεκάτην ἀπὸ πάντων ἐμέρισεν Ἀβραάμ, πρῶτον μὲν ἑρμηνευόμενος βασιλεὺς δικαιοσύνης ἔπειτα δὲ καὶ βασιλεὺς Σαλήμ, ὅ ἐστιν βασιλεὺς εἰρήνης,","lemmas":["ὅς","καί","δεκάτη","ἀπό","πᾶς","μερίζω","Ἀβραάμ","πρῶτος","μέν","ἑρμηνεύω","βασιλεύς","δικαιοσύνη","ἔπειτα","δέ","Σαλήμ","εἰμί","εἰρήνη"],"tr":"to whom also Abraham distributed [a] tenth from all, on the one hand, first being translated king of righteousness but [on the other hand] then also king of Salem, which is king of peace,","para":null,"para_continued":false,"words":[{"form":"ᾧ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"δεκάτην","lemma":"δεκάτη","type":"adjective","code":"A"},{"form":"ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"πάντων","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"ἐμέρισεν","lemma":"μερίζω","type":"verb","code":"V"},{"form":"Ἀβραάμ,","lemma":"Ἀβραάμ","type":"noun","code":"N"},{"form":"πρῶτον","lemma":"πρῶτος","type":"adjective","code":"A"},{"form":"μὲν","lemma":"μέν","type":"conjunction","code":"C"},{"form":"ἑρμηνευόμενος","lemma":"ἑρμηνεύω","type":"verb","code":"V"},{"form":"βασιλεὺς","lemma":"βασιλεύς","type":"noun","code":"N"},{"form":"δικαιοσύνης","lemma":"δικαιοσύνη","type":"noun","code":"N"},{"form":"ἔπειτα","lemma":"ἔπειτα","type":"adverb","code":"D"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"βασιλεὺς","lemma":"βασιλεύς","type":"noun","code":"N"},{"form":"Σαλήμ,","lemma":"Σαλήμ","type":"noun","code":"N"},{"form":"ὅ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"ἐστιν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"βασιλεὺς","lemma":"βασιλεύς","type":"noun","code":"N"},{"form":"εἰρήνης,","lemma":"εἰρήνη","type":"noun","code":"N"}]},{"v":3,"ref":"Heb 7:3","grc":"ἀπάτωρ