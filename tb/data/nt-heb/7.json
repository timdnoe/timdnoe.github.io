_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ὧδε","lemma":"ὧδε","type":"adverb","code":"D"},{"form":"μὲν","lemma":"μέν","type":"conjunction","code":"C"},{"form":"δεκάτας","lemma":"δεκάτη","type":"adjective","code":"A"},{"form":"ἀποθνῄσκοντες","lemma":"ἀποθνήσκω","type":"verb","code":"V"},{"form":"ἄνθρωποι","lemma":"ἄνθρωπος","type":"noun","code":"N"},{"form":"λαμβάνουσιν,","lemma":"λαμβάνω","type":"verb","code":"V"},{"form":"ἐκεῖ","lemma":"ἐκεῖ","type":"adverb","code":"D"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"μαρτυρούμενος","lemma":"μαρτυρέω","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"ζῇ.","lemma":"ζάω","type":"verb","code":"V"}]},{"v":9,"ref":"Heb 7:9","grc":"καὶ ὡς ἔπος εἰπεῖν, δι’ Ἀβραὰμ καὶ Λευὶ ὁ δεκάτας λαμβάνων δεδεκάτωται,","lemmas":["καί","ὡς","ἔπος","λέγω","διά","Ἀβραάμ","Λευί","ὁ","δεκάτη","λαμβάνω","δεκατόω"],"tr":"And as [a] saying to have said, through Abraham and Levi the [one] receiving tithes has been tithed,","para":null,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"ἔπος","lemma":"ἔπος","type":"noun","code":"N"},{"form":"εἰπεῖν,","lemma":"λέγω","type":"verb","code":"V"},{"form":"δι’","lemma":"διά","type":"preposition","code":"P"},{"form":"Ἀβραὰμ","lemma":"Ἀβραάμ","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"Λευὶ","lemma":"Λευί","type":"noun","code":"N"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δεκάτας","lemma":"δεκάτη","type":"adjective","code":"A"},{"form":"λαμβάνων","lemma":"λαμβάνω","type":"verb","code":"V"},{"form":"δεδεκάτωται,","lemma":"δεκατόω","type":"verb","code":"V"}]},{"v":10,"ref":"Heb 7:10","grc":"ἔτι γὰρ ἐν τῇ ὀσφύϊ τοῦ πατρὸς ἦν ὅτε συνήντησεν αὐτῷ ⸀Μελχισέδεκ.","lemmas":["ἔτι","γάρ","ἐν","ὁ","ὀσφύς","πατήρ","εἰμί","ὅτε"