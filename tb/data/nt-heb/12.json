rb","code":"V"},{"form":"ταῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ψυχαῖς","lemma":"ψυχή","type":"noun","code":"N"},{"form":"ὑμῶν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"ἐκλυόμενοι.","lemma":"ἐκλύομαι","type":"verb","code":"V"}]},{"v":4,"ref":"Heb 12:4","grc":"οὔπω μέχρις αἵματος ἀντικατέστητε πρὸς τὴν ἁμαρτίαν ἀνταγωνιζόμενοι,","lemmas":["οὔπω","μέχρι(ς)","αἷμα","ἀντικαθίστημι","πρός","ὁ","ἁμαρτία","ἀνταγωνίζομαι"],"tr":"Not yet until blood did [you all] stand contending against towards the sin,","para":null,"para_continued":false,"words":[{"form":"οὔπω","lemma":"οὔπω","type":"adverb","code":"D"},{"form":"μέχρις","lemma":"μέχρι(ς)","type":"preposition","code":"P"},{"form":"αἵματος","lemma":"αἷμα","type":"noun","code":"N"},{"form":"ἀντικατέστητε","lemma":"ἀντικαθίστημι","type":"verb","code":"V"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἁμαρτίαν","lemma":"ἁμαρτία","type":"noun","code":"N"},{"form":"ἀνταγωνιζόμενοι,","lemma":"ἀνταγωνίζομαι","type":"verb","code":"V"}]},{"v":5,"ref":"Heb 12:5","grc":"καὶ ἐκλέλησθε τῆς παρακλήσεως, ἥτις ὑμῖν ὡς υἱοῖς διαλέγεται, Υἱέ μου, μὴ ὀλιγώρει παιδείας κυρίου, μηδὲ ἐκλύου ὑπ’ αὐτοῦ ἐλεγχόμενος·","lemmas":["καί","ἐκλανθάνω","ὁ","παράκλησις","ὅστις","σύ","ὡς","υἱός","διαλέγομαι","ἐγώ","μή","ὀλιγωρέω","παιδεία","κύριος","μηδέ","ἐκλύομαι","ὑπό","αὐτός","ἐλέγχω"],"tr":"and [you all] have forgotten the encouragement which to you [all] as to sons [he] says, “My son, do not despise discipline of [the] lord, neither faint, being reproved by him,”","para":null,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐκλέλησθε","lemma":"ἐκλανθάνω","type":"verb","code":"V"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"παρακλήσεως,","lemma":"παράκλησις","type":"noun","code":"N"},{"form":"ἥτις","lemma":"ὅστις","type":"relative_pronoun","code":"RR"},{"form":"ὑμῖν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"υἱοῖς","lemma":"υἱός","type":"noun","code":"N"},{"form":"διαλέγεται,","lemma":"διαλέγομαι","type":"verb","code":"V"},{"form":"Υἱέ","lemma":"υἱός","type":"noun","code":"N"},{"form":"μου,","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"ὀλιγώρει","lemma":"ὀλιγωρέω","type":"verb","code":"V"},{"form":"παιδείας","lemma":"παιδεία","type":"noun","code":"N"},{"form":"κυρίου,","lemma":"κύριος","type":"noun","code":"N"},{"form":"μηδὲ","lemma":"μηδέ","type":"conjunction","code":"C"},{"form":"ἐκλύου","lemma":"ἐκλύομαι","type":"verb","code":"V"},{"form":"ὑπ’","lemma":"ὑπό","type":"preposition","code":"P"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἐλεγχόμενος·","lemma":"ἐλέγχω","type":"verb","code":"V"}]},{"v":6,"ref":"Heb 12:6","grc":"ὃν γὰρ ἀγαπᾷ κύριος παιδεύει, μαστιγοῖ δὲ πάντα υἱὸν ὃν παραδέχεται.","lemmas":["ὅς","γάρ","ἀγαπάω","κύριος","παιδεύω","μαστιγόω","δέ","πᾶς","υἱός","παραδέχομαι"],"tr":"for whom [the] lord loves [he] disciplines, but [he] whips every son whom [he] receives.","para":null,"para_continued":false,"words":[{"form":"ὃν","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"ἀγαπᾷ","lemma":"ἀγαπάω","type":"verb","code":"V"},{"form":"κύριος","lemma":"κύριος","type":"noun","code":"N"},{"form":"παιδεύει,","lemma":"παιδεύω","type":"verb","code":"V"},{"form":"μαστιγοῖ","lemma":"μαστιγόω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"πάντα","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"υἱὸν","lemma":"υἱός","type":"noun","code":"N"},{"form":"ὃν","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"παραδέχεται.","lemma":"παραδέχομαι","type":"verb","code":"V"}]},{"v":7,"ref":"Heb 12:7","grc":"εἰς παιδείαν ὑπομένετε· ὡς υἱοῖς ὑμῖν προσφέρεται ὁ θεός· τίς ⸀γὰρ υἱὸς ὃν οὐ παιδεύει πατήρ;","lemmas":["εἰς","παιδεία","ὑπομένω","ὡς","υἱός","σύ","προσφέρω","ὁ","θεός","τίς","γάρ","ὅς","οὐ","παιδεύω","πατήρ"],"tr":"Endure into discipline; God is being offered as to sons to you [all], for who [is a] son whom [a] father does not discipline?","para":null,"para_continued":false,"words":[{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"παιδείαν","lemma":"παιδεία","type":"noun","code":"N"},{"form":"ὑπομένετε·","lemma":"ὑπομένω","type":"verb","code":"V"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"υἱοῖς","lemma":"υἱός","type":"noun","code":"N"},{"form":"ὑμῖν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"προσφέρεται","lemma":"προσφέρω","type":"verb","code":"V"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεός·","lemma":"θεός","type":"noun","code":"N"},{"form":"τίς","lemma":"τίς","type":"interrogative_pronoun","code":"RI"},{"form":"⸀γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"υἱὸς","lemma":"υἱός","type":"noun","code":"N"},{"form":"ὃν","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"παιδεύει","lemma":"παιδεύω","type":"verb","code":"V"},{"form":"πατήρ;","lemma":"πατήρ","type":"noun","code":"N"}]},{"v":8,"ref":"Heb 12:8","grc":"εἰ δὲ χωρίς ἐστε παιδείας ἧς μέτοχοι γεγόνασι πάντες, ἄρα νόθοι ⸂καὶ οὐχ υἱοί ἐστε⸃.","lemmas":["εἰ","δέ","χωρίς","εἰμί","παιδεία","ὅς","μέτοχος","γίνομαι","πᾶς","ἄρα","νόθος","καί","οὐ","υἱός"],"tr":"But if [you all] are without [the] discipline of which all have become partners, then illegitimate [ones], and [you all] are not sons.","para":null,"para_continued":false,"words":[{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"χωρίς","lemma":"χωρίς","type":"preposition","code":"P"},{"form":"ἐστε","lemma":"εἰμί","type":"verb","code":"V"},{"form":"παιδείας","lemma":"παιδεία","type":"noun","code":"N"},{"form":"ἧς","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"μέτοχοι","lemma":"μέτοχος","type":"adjective","code":"A"},{"form":"γεγόνασι","lemma":"γίνομαι","type":"verb","code":"V"},{"form":"πάντες,","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"ἄρα","lemma":"ἄρα","type":"conjunction","code":"C"},{"form":"νόθοι","lemma":"νόθος","type":"adjective","code":"A"},{"form":"⸂καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"οὐχ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"υἱοί","lemma":"υἱός","type":"noun","code":"N"},{"form":"ἐστε⸃.","lemma":"εἰμί","type":"verb","code":"V"}]},{"v":9,"ref":"Heb 12:9","grc":"εἶτα τοὺς μὲν τῆς σαρκὸς ἡμῶν πατέρας εἴχομεν παιδευτὰς καὶ ἐνετρεπόμεθα· οὐ ⸀πολὺ μᾶλλον ὑποταγησόμεθα τῷ πατρὶ τῶν πνευμάτων καὶ ζήσομεν;","lemmas":["εἶτα","ὁ","μέν","σάρξ","ἐγώ","πατήρ","ἔχω","παιδευτής","καί","ἐντρέπω","οὐ","πολύς","μᾶλλον","ὑποτάσσω","πνεῦμα","ζάω"],"tr":"Then indeed, [we] were having the fathers of our flesh [as] trainers, and [we] were respecting [them]. Shall [we] not much rather be subjected to the father of the spirits and [we] will live?","para":null,"para_continued":false,"words":[{"form":"εἶτα","lemma":"εἶτα","type":"adverb","code":"D"},{"form":"τοὺς","lemma":"ὁ","type":"article","code":"RA"},{"form":"μὲν","lemma":"μέν","type":"conjunction","code":"C"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"σαρκὸς","lemma":"σάρξ","type":"noun","code":"N"},{"form":"ἡμῶν","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"πατέρας","lemma":"πατήρ","type":"noun","code":"N"},{"form":"εἴχομεν","lemma":"ἔχω","type":"verb","code":"V"},{"form":"παιδευτὰς","lemma":"παιδευτής","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐνετρεπόμεθα·","lemma":"ἐντρέπω","type":"verb","code":"V"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"⸀πολὺ","lemma":"πολύς","type":"adjective","code":"A"},{"form":"μᾶλλον","lemma":"μᾶλλον","type":"adverb","code":"D"},{"form":"ὑποταγησόμεθα","lemma":"ὑποτάσσω","type":"verb","code":"V"},{"form":"τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πατρὶ","lemma":"πατήρ","type":"noun","code":"N"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"πνευμάτων","lemma":"πνεῦμα","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ζήσομεν;","lemma":"ζάω","type":"verb","code":"V"}]},{"v":10,"ref":"Heb 12:10","grc":"οἱ μὲν γὰρ πρὸς ὀλίγας ἡμέρας κατὰ τὸ δοκοῦν αὐτοῖς ἐπαίδευον, ὁ δὲ ἐπὶ τὸ συμφέρον εἰς τὸ μεταλαβεῖν τῆς ἁγιότητος αὐτοῦ.","lemmas":["ὁ","μέν","γάρ","πρός","ὀλίγος","ἡμέρα","κατά","δοκέω","αὐτός","παιδεύω","δέ","ἐπί","συμφέρω","εἰς","μεταλαμβάνω","ἁγιότης"],"tr":"For on the one hand, the [ones] disciplined [us] towards few days according to the [thing] seeming [right] to them, but [on the other hand] the [one disciplines] upon the benefit, for [the purpose of] having partaken of his holiness.","para":null,"para_continued":false,"words":[{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"μὲν","lemma":"μέν","type":"conjunction","code":"C"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"ὀλίγας","lemma":"ὀλίγος","type":"adjective","code":"A"},{"form":"ἡμέρας","lemma":"ἡμέρα","type":"noun","code":"N"},{"form":"κατὰ","lemma":"κατά","type":"preposition","code":"P"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δοκοῦν","lemma":"δοκέω","type":"verb","code":"V"},{"form":"αὐτοῖς","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἐπαίδευον,","lemma":"παιδεύω","type":"verb","code":"V"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἐπὶ","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"συμφέρον","lemma":"συμφέρω","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"μεταλαβεῖν","lemma":"μεταλαμβάνω","type":"verb","code":"V"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἁγιότητος","lemma":"ἁγιότης","type":"noun","code":"N"},{"form":"αὐτοῦ.","lemma":"αὐτός","type":"personal_pronoun","code":"RP"}]},{"v":11,"ref":"Heb 12:11","grc":"πᾶσα ⸀δὲ παιδεία πρὸς μὲν τὸ παρὸν οὐ δοκεῖ χαρᾶς εἶναι ἀλλὰ λύπης, ὕστερον δὲ καρπὸν εἰρηνικὸν τοῖς δι’ αὐτῆς γεγυμνασμένοις ἀποδίδωσιν δικαιοσύνης.","lemmas":["πᾶς","δέ","παιδεία","πρός","μέν","ὁ","πάρειμι","οὐ","δοκέω","χαρά","εἰμί","ἀλλά","λύπη","ὕστερον","καρπός","εἰρηνικός","διά","αὐτός","γυμνάζω","ἀποδίδωμι","δικαιοσύνη"],"tr":"But every discipline, on the one hand, towards the [thing] being present does not seem to be of joy, rather of sorrow, but [on the other hand] afterward peaceful fruit of righteousness to the [ones] having had been trained through it gives back.","para":null,"para_continued":false,"words":[{"form":"πᾶσα","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"⸀δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"παιδεία","lemma":"παιδεία","type":"noun","code":"N"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"μὲν","lemma":"μέν","type":"conjunction","code":"C"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"παρὸν","lemma":"πάρειμι","type":"verb","code":"V"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"δοκεῖ","lemma":"δοκέω","type":"verb","code":"V"},{"form":"χαρᾶς","lemma":"χαρά","type":"noun","code":"N"},{"form":"εἶναι","lemma":"εἰμί","type":"verb","code":"V"},{"form":"ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"λύπης,","lemma":"λύπη","type":"noun","code":"N"},{"form":"ὕστερον","lemma":"ὕστερον","type":"adjective","code":"A"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"καρπὸν",