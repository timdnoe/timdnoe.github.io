oved and [a] curse [is] near, of which the end [is] into burning.","para":null,"para_continued":false,"words":[{"form":"ἐκφέρουσα","lemma":"ἐκφέρω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἀκάνθας","lemma":"ἄκανθα","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"τριβόλους","lemma":"τρίβολος","type":"noun","code":"N"},{"form":"ἀδόκιμος","lemma":"ἀδόκιμος","type":"adjective","code":"A"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"κατάρας","lemma":"κατάρα","type":"noun","code":"N"},{"form":"ἐγγύς,","lemma":"ἐγγύς","type":"preposition","code":"P"},{"form":"ἧς","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"τέλος","lemma":"τέλος","type":"noun","code":"N"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"καῦσιν.","lemma":"καῦσις","type":"noun","code":"N"}]},{"v":9,"ref":"Heb 6:9","grc":"Πεπείσμεθα δὲ περὶ ὑμῶν, ἀγαπητοί, τὰ κρείσσονα καὶ ἐχόμενα σωτηρίας, εἰ καὶ οὕτως λαλοῦμεν·","lemmas":["πείθω","δέ","περί","σύ","ἀγαπητός","ὁ","κρείττων","καί","ἔχω","σωτηρία","εἰ","οὕτως","λαλέω"],"tr":"But [we] have been persuaded about you [all], beloved [ones], the better [things] and [things] neighboring of salvation, if also thus [we] speak.","para":null,"para_continued":false,"words":[{"form":"Πεπείσμεθα","lemma":"πείθω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"περὶ","lemma":"περί","type":"preposition","code":"P"},{"form":"ὑμῶν,","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"ἀγαπητοί,","lemma":"ἀγαπητός","type":"adjective","code":"A"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"κρείσσονα","lemma":"κρείττων","type":"adjective","code":"A"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐχόμενα","lemma":"ἔχω","type":"verb","code":"V"},{"form":"σωτηρίας,","lemma":