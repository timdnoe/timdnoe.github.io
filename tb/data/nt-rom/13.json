":"θεός","type":"noun","code":"N"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"διάκονός","lemma":"διάκονος","type":"noun","code":"N"},{"form":"ἐστιν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"σοὶ","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀγαθόν.","lemma":"ἀγαθός","type":"adjective","code":"A"},{"form":"ἐὰν","lemma":"ἐάν","type":"conjunction","code":"C"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"κακὸν","lemma":"κακός","type":"adjective","code":"A"},{"form":"ποιῇς,","lemma":"ποιέω","type":"verb","code":"V"},{"form":"φοβοῦ·","lemma":"φοβέομαι","type":"verb","code":"V"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"εἰκῇ","lemma":"εἰκῆ","type":"adverb","code":"D"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"μάχαιραν","lemma":"μάχαιρα","type":"noun","code":"N"},{"form":"φορεῖ·","lemma":"φορέω","type":"verb","code":"V"},{"form":"θεοῦ","lemma":"θεός","type":"noun","code":"N"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"διάκονός","lemma":"διάκονος","type":"noun","code":"N"},{"form":"ἐστιν,","lemma":"εἰμί","type":"verb","code":"V"},{"form":"ἔκδικος","lemma":"ἔκδικος","type":"adjective","code":"A"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"ὀργὴν","lemma":"ὀργή","type":"noun","code":"N"},{"form":"τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"κακὸν","lemma":"κακός","type":"adjective","code":"A"},{"form":"πράσσοντι.","lemma":"πράσσω","type":"verb","code":"V"}]},{"v":5,"ref":"Rom 13:5","grc":"διὸ ἀνάγκη ὑποτάσσεσθαι, οὐ μόνον διὰ τὴν ὀργὴν ἀλλὰ καὶ διὰ τὴν συνείδησιν,","lemmas":["διό","ἀνάγκη","ὑποτάσσω","οὐ","μόνος","διά","ὁ","ὀργή","ἀλλά","καί","συνείδησις"],"tr":"Therefore [it is] necessary to be subject, not only because of the wrath, rather also because of the conscience.","para":null,"para_continued":false,"words":[{"form":"διὸ","lemma":"διό","type":"conjunction","code":"C"},{"form":"ἀνάγκη","lemma":"ἀνάγκη","type":"noun","code":"N"},{"form":"ὑποτάσσεσθαι,","lemma":"ὑποτάσσω","type":"verb","code":"V"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"μόνον","lemma":"μόνος","type":"adjective","code":"A"},{"form":"διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"ὀργὴν","lemma":"ὀργή","type":"noun","code":"N"},{"form":"ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"συνείδησιν,","lemma":"συνείδησις","type":"noun","code":"N"}]},{"v":6,"ref":"Rom 13:6","grc":"διὰ τοῦτο γὰρ καὶ φόρους τελεῖτε, λειτουργοὶ γὰρ θεοῦ εἰσιν εἰς αὐτὸ τοῦτο προσκαρτεροῦντες.","lemmas":["διά","οὗτος","γάρ","καί","φόρος","τελέω","λειτουργός","θεός","εἰμί","εἰς","αὐτός","προσκαρτερέω"],"tr":"For because of this, [you all] also pay taxes, for [they] are ministers of God, persevering into this very [thing].","para":null,"para_continued":false,"words":[{"form":"διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"τοῦτο","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"φόρους","lemma":"φόρος","type":"noun","code":"N"},{"form":"τελεῖτε,","lemma":"τελέω","type":"verb","code":"V"},{"form":"λειτουργοὶ","lemma":"λειτουργός","type":"noun","code":"N"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"θεοῦ","lemma":"θεός","type":"noun","code":"N"},{"form":"εἰσιν","lemma":"εἰμί","type":"verb","co