n","code":"N"},{"form":"αὐτοῖς","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἐπαγγελλόμενοι,","lemma":"ἐπαγγέλλομαι","type":"verb","code":"V"},{"form":"αὐτοὶ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"δοῦλοι","lemma":"δοῦλος","type":"noun","code":"N"},{"form":"ὑπάρχοντες","lemma":"ὑπάρχω","type":"verb","code":"V"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"φθορᾶς·","lemma":"φθορά","type":"noun","code":"N"},{"form":"ᾧ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"γάρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"τις","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"ἥττηται,","lemma":"ἡττάομαι","type":"verb","code":"V"},{"form":"τούτῳ","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"⸀καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"δεδούλωται.","lemma":"δουλόω","type":"verb","code":"V"}]},{"v":20,"ref":"2Pet 2:20","grc":"εἰ γὰρ ἀποφυγόντες τὰ μιάσματα τοῦ κόσμου ἐν ἐπιγνώσει τοῦ ⸀κυρίου καὶ σωτῆρος Ἰησοῦ Χριστοῦ τούτοις δὲ πάλιν ἐμπλακέντες ἡττῶνται, γέγονεν αὐτοῖς τὰ ἔσχατα χείρονα τῶν πρώτων.","lemmas":["εἰ","γάρ","ἀποφεύγω","ὁ","μίασμα","κόσμος","ἐν","ἐπίγνωσις","κύριος","καί","σωτήρ","Ἰησοῦς","Χριστός","οὗτος","δέ","πάλιν","ἐμπλέκομαι","ἡττάομαι","γίνομαι","αὐτός","ἔσχατος","χείρων","πρῶτος"],"tr":"For if having escaped the defilements of the world in [full] knowledge of the lord and savior Jesus Christ, but [with] these [things] again having become entangled, [they] have been defeated; the [collection of the] last [things] has become to them  worse than the first [things].","para":null,"para_continued":false,"words":[{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"ἀποφυγόντες","lemma":"ἀποφεύγω","type":"verb","code":"V"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"μιάσματα","lemma":"μίασμα","type":"noun","code":"N"},{"form":"