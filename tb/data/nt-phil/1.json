":"interrogative_pronoun","code":"RI"},{"form":"γάρ;","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"πλὴν","lemma":"πλήν","type":"conjunction","code":"C"},{"form":"⸀ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"παντὶ","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"τρόπῳ,","lemma":"τρόπος","type":"noun","code":"N"},{"form":"εἴτε","lemma":"εἴτε","type":"conjunction","code":"C"},{"form":"προφάσει","lemma":"πρόφασις","type":"noun","code":"N"},{"form":"εἴτε","lemma":"εἴτε","type":"conjunction","code":"C"},{"form":"ἀληθείᾳ,","lemma":"ἀλήθεια","type":"noun","code":"N"},{"form":"Χριστὸς","lemma":"Χριστός","type":"noun","code":"N"},{"form":"καταγγέλλεται,","lemma":"καταγγέλλω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"τούτῳ","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"χαίρω·","lemma":"χαίρω","type":"verb","code":"V"},{"form":"ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"χαρήσομαι,","lemma":"χαίρω","type":"verb","code":"V"}]},{"v":19,"ref":"Phil 1:19","grc":"οἶδα γὰρ ὅτι τοῦτό μοι ἀποβήσεται εἰς σωτηρίαν διὰ τῆς ὑμῶν δεήσεως καὶ ἐπιχορηγίας τοῦ πνεύματος Ἰησοῦ Χριστοῦ,","lemmas":["οἶδα","γάρ","ὅτι","οὗτος","ἐγώ","ἀποβαίνω","εἰς","σωτηρία","διά","ὁ","σύ","δέησις","καί","ἐπιχορηγία","πνεῦμα","Ἰησοῦς","Χριστός"],"tr":"For [I] know because this will turn out to me into salvation through the prayer of you [all] and [of the] supply of the spirit of Jesus Christ,","para":null,"para_continued":false,"words":[{"form":"οἶδα","lemma":"οἶδα","type":"verb","code":"V"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"τοῦτό","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"μοι","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"ἀποβήσεται","