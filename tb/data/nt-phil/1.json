oun","code":"N"},{"form":"ὑμῶν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"περισσεύῃ","lemma":"περισσεύω","type":"verb","code":"V"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"Χριστῷ","lemma":"Χριστός","type":"noun","code":"N"},{"form":"Ἰησοῦ","lemma":"Ἰησοῦς","type":"noun","code":"N"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"ἐμοὶ","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἐμῆς","lemma":"ἐμός","type":"adjective","code":"A"},{"form":"παρουσίας","lemma":"παρουσία","type":"noun","code":"N"},{"form":"πάλιν","lemma":"πάλιν","type":"adverb","code":"D"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"ὑμᾶς.","lemma":"σύ","type":"personal_pronoun","code":"RP"}]},{"v":27,"ref":"Phil 1:27","grc":"Μόνον ἀξίως τοῦ εὐαγγελίου τοῦ Χριστοῦ πολιτεύεσθε, ἵνα εἴτε ἐλθὼν καὶ ἰδὼν ὑμᾶς εἴτε ἀπὼν ⸀ἀκούω τὰ περὶ ὑμῶν, ὅτι στήκετε ἐν ἑνὶ πνεύματι, μιᾷ ψυχῇ συναθλοῦντες τῇ πίστει τοῦ εὐαγγελίου,","lemmas":["μόνος","ἀξίως","ὁ","εὐαγγέλιον","Χριστός","πολιτεύομαι","ἵνα","εἴτε","ἔρχομαι","καί","ὁράω","σύ","ἄπειμι","ἀκούω","περί","ὅτι","στήκω","ἐν","εἷς","πνεῦμα","ψυχή","συναθλέω","πίστις"],"tr":"Only conduct yourselves worthily of the good news of Christ, so that whether having come and having seen you [all], or being absent [I] hear the [things] about you [all], that [you all] stand in one spirit, striving together [with] one soul, [with] the faith of the good news,","para":null,"para_continued":false,"words":[{"form":"Μόνον","lemma":"μόνος","type":"adjective","code":"A"},{"form":"ἀξίως","lemma":"ἀξίως","type":"adverb","code":"D"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"εὐαγγελίου","lemma":"εὐαγγέλιον","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Χριστοῦ","lemma":"Χριστός","type":"noun","code":"N"