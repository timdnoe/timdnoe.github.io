{"book":"nt-2john","book_name":"Second Epistle of John","chapter":1,"chapter_label":"1","prev":null,"next":null,"verses":[{"v":1,"ref":"2John 1:1","grc":"Ὁ πρεσβύτερος ἐκλεκτῇ κυρίᾳ καὶ τοῖς τέκνοις αὐτῆς, οὓς ἐγὼ ἀγαπῶ ἐν ἀληθείᾳ, καὶ οὐκ ἐγὼ μόνος ἀλλὰ καὶ πάντες οἱ ἐγνωκότες τὴν ἀλήθειαν,","lemmas":["ὁ","πρεσβύτερος","ἐκλεκτός","κυρία","καί","τέκνον","αὐτός","ὅς","ἐγώ","ἀγαπάω","ἐν","ἀλήθεια","οὐ","μόνος","ἀλλά","πᾶς","γινώσκω"],"tr":"The elder, to [the] elect lady, and to her children whom I love in truth, and not I alone rather also all the [ones] having had known the truth,","para":null,"para_continued":false,"words":[{"form":"Ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πρεσβύτερος","lemma":"πρεσβύτερος","type":"adjective","code":"A"},{"form":"ἐκλεκτῇ","lemma":"ἐκλεκτός","type":"adjective","code":"A"},{"form":"κυρίᾳ","lemma":"κυρία","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"τοῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"τέκνοις","lemma":"τέκνον","type":"noun","code":"N"},{"form":"αὐτῆς,","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"οὓς","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"ἐγὼ","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"ἀγαπῶ","lemma":"ἀγαπάω","type":"verb","code":"V"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"ἀληθείᾳ,","lemma":"ἀλήθεια","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"οὐκ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"ἐγὼ","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"μόνος","lemma":"μόνος","type":"adjective","code":"A"},{"form":"ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"πάντες","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἐγνωκότες","lemma":"γινώσκω","type":"verb","code":"V"},{"