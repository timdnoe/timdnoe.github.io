,"code":"N"},{"form":"ἑαυτοὺς","lemma":"ἑαυτοῦ","type":"personal_pronoun","code":"RP"},{"form":"δοκιμάζετε·","lemma":"δοκιμάζω","type":"verb","code":"V"},{"form":"ἢ","lemma":"ἤ","type":"conjunction","code":"C"},{"form":"οὐκ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"ἐπιγινώσκετε","lemma":"ἐπιγινώσκω","type":"verb","code":"V"},{"form":"ἑαυτοὺς","lemma":"ἑαυτοῦ","type":"personal_pronoun","code":"RP"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"⸂Ἰησοῦς","lemma":"Ἰησοῦς","type":"noun","code":"N"},{"form":"Χριστὸς⸃","lemma":"Χριστός","type":"noun","code":"N"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"⸀ὑμῖν;","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"μήτι","lemma":"μήτι","type":"particle","code":"X"},{"form":"ἀδόκιμοί","lemma":"ἀδόκιμος","type":"adjective","code":"A"},{"form":"ἐστε.","lemma":"εἰμί","type":"verb","code":"V"}]},{"v":6,"ref":"2Cor 13:6","grc":"ἐλπίζω δὲ ὅτι γνώσεσθε ὅτι ἡμεῖς οὐκ ἐσμὲν ἀδόκιμοι.","lemmas":["ἐλπίζω","δέ","ὅτι","γινώσκω","ἐγώ","οὐ","εἰμί","ἀδόκιμος"],"tr":"But [I] hope that [you all] will know that we are not unapproved.","para":null,"para_continued":false,"words":[{"form":"ἐλπίζω","lemma":"ἐλπίζω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"γνώσεσθε","lemma":"γινώσκω","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"ἡμεῖς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"οὐκ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"ἐσμὲν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"ἀδόκιμοι.","lemma":"ἀδόκιμος","type":"adjective","code":"A"}]},{"v":7,"ref":"2Cor 13:7","grc":"⸀εὐχόμεθα δὲ πρὸς τὸν θεὸν μὴ ποιῆσαι ὑμᾶς κακὸν μηδέν, οὐχ ἵνα ἡμεῖς δόκιμοι φανῶμεν, ἀλλ’ ἵνα ὑμεῖς τὸ καλὸν ποιῆτε, ἡμεῖς δὲ ὡς ἀδόκιμοι ὦμεν.","lemmas":["εὔχομαι","δέ","πρός","ὁ","θεός","μή","ποιέω","σύ","κακός","μηδείς","οὐ","ἵνα","ἐγώ","δόκιμος","φαίνω","ἀλλά","καλός","ὡς","ἀδόκιμος","εἰμί"],"tr":"But [we] pray towards God [for] you [all] to not have done any bad, not so that we might appear approved, rather so that you [all] may do the good [thing], but we as [if we] may be unapproved.","para":null,"para_continued":false,"words":[{"form":"⸀εὐχόμεθα","lemma":"εὔχομαι","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεὸν","lemma":"θεός","type":"noun","code":"N"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"ποιῆσαι","lemma":"ποιέω","type":"verb","code":"V"},{"form":"ὑμᾶς","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"κακὸν","lemma":"κακός","type":"adjective","code":"A"},{"form":"μηδέν,","lemma":"μηδείς","type":"adjective","code":"A"},{"form":"οὐχ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"ἡμεῖς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"δόκιμοι","lemma":"δόκιμος","type":"adjective","code":"A"},{"form":"φανῶμεν,","lemma":"φαίνω","type":"verb","code":"V"},{"form":"ἀλλ’","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"ὑμεῖς","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"καλὸν","lemma":"καλός","type":"adjective","code":"A"},{"form":"ποιῆτε,","lemma":"ποιέω","type":"verb","code":"V"},{"form":"ἡμεῖς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"ἀδόκιμοι","lemma":"ἀδόκιμος","type":"adjective","code":"A"},{"form":"ὦμεν.","lemma":"εἰμί","type":"verb","code":"V"}]},{"v":8,"ref":"2Cor 13:8","grc":"οὐ γὰρ δυνάμεθά τι κατὰ τῆς ἀληθείας, ἀλλὰ ὑπὲρ τῆς ἀληθείας.","lemmas":["οὐ","γάρ","δύναμαι","τις","κατά","ὁ","ἀλήθεια","ἀλλά","ὑπέρ"],"tr":"For [we] are not able [to do] anything against the truth, rather on behalf of the truth.","para":null,"para_continued":false,"words":[{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"δυνάμεθά","lemma":"δύναμαι","type":"verb","code":"V"},{"form":"τι","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"κατὰ","lemma":"κατά","type":"preposition","code":"P"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀληθείας,","lemma":"ἀλήθεια","type":"noun","code":"N"},{"form":"ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"ὑπὲρ","lemma":"ὑπέρ","type":"preposition","code":"P"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀληθείας.","lemma":"ἀλήθεια","type":"noun","code":"N"}]},{"v":9,"ref":"2Cor 13:9","grc":"χαίρομεν γὰρ ὅταν ἡμεῖς ἀσθενῶμεν, ὑμεῖς δὲ δυνατοὶ ἦτε· ⸀τοῦτο καὶ εὐχόμεθα, τὴν ὑμῶν κατάρτισιν.","lemmas":["χαίρω","γάρ","ὅταν","ἐγώ","ἀσθενέω","σύ","δέ","δυνατός","εἰμί","οὗτος","καί","εὔχομαι","ὁ","κατάρτισις"],"tr":"For [we] rejoice whenever we may be weak, but you [all] may be mighty. [For] this [we] also pray: [all] your restoration.","para":null,"para_continued":false,"words":[{"form":"χαίρομεν","lemma":"χαίρω","type":"verb","code":"V"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"ὅταν","lemma":"ὅταν","type":"conjunction","code":"C"},{"form":"ἡμεῖς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"ἀσθενῶμεν,","lemma":"ἀσθενέω","type":"verb","code":"V"},{"form":"ὑμεῖς","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"δυνατοὶ","lemma":"δυνατός","type":"adjective","code":"A"},{"form":"ἦτε·","lemma":"εἰμί","type":"verb","code":"V"},{"form":"⸀τοῦτο","lemma":"οὗτος","type":"d