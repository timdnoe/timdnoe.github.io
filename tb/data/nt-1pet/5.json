"words":[{"form":"νήψατε,","lemma":"νήφω","type":"verb","code":"V"},{"form":"γρηγορήσατε.","lemma":"γρηγορέω","type":"verb","code":"V"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀντίδικος","lemma":"ἀντίδικος","type":"noun","code":"N"},{"form":"ὑμῶν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"διάβολος","lemma":"διάβολος","type":"adjective","code":"A"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"λέων","lemma":"λέων","type":"noun","code":"N"},{"form":"ὠρυόμενος","lemma":"ὠρύομαι","type":"verb","code":"V"},{"form":"περιπατεῖ","lemma":"περιπατέω","type":"verb","code":"V"},{"form":"ζητῶν","lemma":"ζητέω","type":"verb","code":"V"},{"form":"⸀τινα","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"⸀καταπιεῖν·","lemma":"καταπίνω","type":"verb","code":"V"}]},{"v":9,"ref":"1Pet 5:9","grc":"ᾧ ἀντίστητε στερεοὶ τῇ πίστει, εἰδότες τὰ αὐτὰ τῶν παθημάτων τῇ ἐν ⸀τῷ κόσμῳ ὑμῶν ἀδελφότητι ἐπιτελεῖσθαι.","lemmas":["ὅς","ἀνθίστημι","στερεός","ὁ","πίστις","οἶδα","αὐτός","πάθημα","ἐν","κόσμος","σύ","ἀδελφότης","ἐπιτελέω"],"tr":"to whom: stand against [as] firm [with] the faith, knowing the same [things] of the sufferings to be being completed [with] your brotherhood in the world.","para":null,"para_continued":false,"words":[{"form":"ᾧ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"ἀντίστητε","lemma":"ἀνθίστημι","type":"verb","code":"V"},{"form":"στερεοὶ","lemma":"στερεός","type":"adjective","code":"A"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πίστει,","lemma":"πίστις","type":"noun","code":"N"},{"form":"εἰδότες","lemma":"οἶδα","type":"verb","code":"V"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"αὐτὰ","lemma":"αὐτός","type":"adjective","code":"A"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"παθημάτων","lemma":"πάθημα","type":"noun","code":"N"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"⸀τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"κόσμῳ","lemma":"κόσμος","type":"noun","code":"N"},{"form":"ὑμῶν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"ἀδελφότητι","lemma":"ἀδελφότης","type":"noun","code":"N"},{"form":"ἐπιτελεῖσθαι.","lemma":"ἐπιτελέω","type":"verb","code":"V"}]},{"v":10,"ref":"1Pet 5:10","grc":"ὁ δὲ θεὸς πάσης χάριτος, ὁ καλέσας ὑμᾶς εἰς τὴν αἰώνιον αὐτοῦ δόξαν ἐν ⸀Χριστῷ, ὀλίγον παθόντας αὐτὸς ⸀καταρτίσει, στηρίξει, σθενώσει, ⸀θεμελιώσει.","lemmas":["ὁ","δέ","θεός","πᾶς","χάρις","καλέω","σύ","εἰς","αἰώνιος","αὐτός","δόξα","ἐν","Χριστός","ὀλίγος","πάσχω","καταρτίζω","στηρίζω","σθενόω","θεμελιόω"],"tr":"But the God of all grace, the [one] having called you [all] into his eternal glory in Christ, [for a] little having suffered, he will prepare, support, strengthen, found.","para":null,"para_continued":false,"words":[{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"θεὸς","lemma":"θεός","type":"noun","code":"N"},{"form":"πάσης","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"χάριτος,","lemma":"χάρις","type":"noun","code":"N"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"καλέσας","lemma":"καλέω","type":"verb","code":"V"},{"form":"ὑμᾶς","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"αἰώνιον","lemma":"αἰώνιος","type":"adjective","code":"A"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"δόξαν","lemma":"δόξα","type":"noun","code":"N"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"⸀Χριστῷ,","lemma":"Χριστός","type":"noun","code":"N"},{"form":"ὀλίγον","lemma":"ὀλίγος","type":"adjective","code":"A"},{"form":"παθόντας","lemma":"πάσχω","type":"verb","code":"V"},{"form":"αὐτὸς","lemma":"αὐτός","type":"personal_pronoun","code