":"ἀναζάω","type":"verb","code":"V"},{"form":"⸂ἦν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"ἀπολωλὼς⸃","lemma":"ἀπόλλυμι","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"εὑρέθη.","lemma":"εὑρίσκω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἤρξαντο","lemma":"ἄρχω","type":"verb","code":"V"},{"form":"εὐφραίνεσθαι.","lemma":"εὐφραίνω","type":"verb","code":"V"}]},{"v":25,"ref":"Luke 15:25","grc":"Ἦν δὲ ὁ υἱὸς αὐτοῦ ὁ πρεσβύτερος ἐν ἀγρῷ· καὶ ὡς ἐρχόμενος ἤγγισεν τῇ οἰκίᾳ, ἤκουσεν συμφωνίας καὶ χορῶν,","lemmas":["εἰμί","δέ","ὁ","υἱός","αὐτός","πρεσβύτερος","ἐν","ἀγρός","καί","ὡς","ἔρχομαι","ἐγγίζω","οἰκία","ἀκούω","συμφωνία","χορός"],"tr":"But his son, the elder, was in the field; and as coming, [he] approached the house, [he] heard music and dancing.","para":1,"para_continued":false,"words":[{"form":"Ἦν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"υἱὸς","lemma":"υἱός","type":"noun","code":"N"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πρεσβύτερος","lemma":"πρεσβύτερος","type":"adjective","code":"A"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"ἀγρῷ·","lemma":"ἀγρός","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"ἐρχόμενος","lemma":"ἔρχομαι","type":"verb","code":"V"},{"form":"ἤγγισεν","lemma":"ἐγγίζω","type":"verb","code":"V"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"οἰκίᾳ,","lemma":"οἰκία","type":"noun","code":"N"},{"form":"ἤκουσεν","lemma":"ἀκούω","type":"verb","code":"V"},{"form":"συμφωνίας","lemma":"συμφωνία","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form"