{"book":"nt-acts","book_name":"Acts of the Apostles","chapter":18,"chapter_label":"18","prev":17,"next":19,"verses":[{"v":1,"ref":"Acts 18:1","grc":"⸀Μετὰ ταῦτα ⸀χωρισθεὶς ἐκ τῶν Ἀθηνῶν ἦλθεν εἰς Κόρινθον.","lemmas":["μετά","οὗτος","χωρίζω","ἐκ","ὁ","Ἀθῆναι","ἔρχομαι","εἰς","Κόρινθος"],"tr":"After these [things], having separated out of the Athenians, [he] came into Corinth.","para":1,"para_continued":false,"words":[{"form":"⸀Μετὰ","lemma":"μετά","type":"preposition","code":"P"},{"form":"ταῦτα","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"⸀χωρισθεὶς","lemma":"χωρίζω","type":"verb","code":"V"},{"form":"ἐκ","lemma":"ἐκ","type":"preposition","code":"P"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"Ἀθηνῶν","lemma":"Ἀθῆναι","type":"noun","code":"N"},{"form":"ἦλθεν","lemma":"ἔρχομαι","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"Κόρινθον.","lemma":"Κόρινθος","type":"noun","code":"N"}]},{"v":2,"ref":"Acts 18:2","grc":"καὶ εὑρών τινα Ἰουδαῖον ὀνόματι Ἀκύλαν, Ποντικὸν τῷ γένει, προσφάτως ἐληλυθότα ἀπὸ τῆς Ἰταλίας καὶ Πρίσκιλλαν γυναῖκα αὐτοῦ διὰ τὸ ⸀διατεταχέναι Κλαύδιον χωρίζεσθαι πάντας τοὺς Ἰουδαίους ⸀ἀπὸ τῆς Ῥώμης, προσῆλθεν αὐτοῖς,","lemmas":["καί","εὑρίσκω","τις","Ἰουδαῖος","ὄνομα","Ἀκύλας","Ποντικός","ὁ","γένος","προσφάτως","ἔρχομαι","ἀπό","Ἰταλία","Πρίσκιλλα","γυνή","αὐτός","διά","διατάσσω","Κλαύδιος","χωρίζω","πᾶς","Ῥώμη","προσέρχομαι"],"tr":"And having found [a] certain Jew [with the] name Aquila, Pontus by race, recently having had come from Italy, and Priscilla his wife, because of the commanding of Claudius to separate all the Jews from Rome, [he] came to them.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"εὑρών","lemma":"εὑρίσκω","type":"verb","code":"V"},{"form":"τινα","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"Ἰουδαῖον","lemma":"Ἰουδαῖος","type":"adjective","code":"A"},{"form":"ὀνόματι","lemma":"ὄνομα","type":"noun","code":"N"},{"form":"Ἀκύλαν,","lemma":"Ἀκύλας","type":"noun","code":"N"},{"form":"Ποντικὸν","lemma":"Ποντικός","type":"adjective","code":"A"},{"form":"τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"γένει,","lemma":"γένος","type":"noun","code":"N"},{"form":"προσφάτως","lemma":"προσφάτως","type":"adverb","code":"D"},{"form":"ἐληλυθότα","lemma":"ἔρχομαι","type":"verb","code":"V"},{"form":"ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"Ἰταλίας","lemma":"Ἰταλία","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"Πρίσκιλλαν","lemma":"Πρίσκιλλα","type":"noun","code":"N"},{"form":"γυναῖκα","lemma":"γυνή","type":"noun","code":"N"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"⸀διατεταχέναι","lemma":"διατάσσω","type":"verb","code":"V"},{"form":"Κλαύδιον","lemma":"Κλαύδιος","type":"noun","code":"N"},{"form":"χωρίζεσθαι","lemma":"χωρίζω","type":"verb","code":"V"},{"form":"πάντας","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"τοὺς","lemma":"ὁ","type":"article","code":"RA"},{"form":"Ἰουδαίους","lemma":"Ἰουδαῖος","type":"adjective","code":"A"},{"form":"⸀ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"Ῥώμης,","lemma":"Ῥώμη","type":"noun","code":"N"},{"form":"προσῆλθεν","lemma":"προσέρχομαι","type":"verb","code":"V"},{"form":"αὐτοῖς,","lemma":"αὐτός","type":"personal_pronoun","code":"RP"}]},{"v":3,"ref":"Acts 18:3","grc":"καὶ διὰ τὸ ὁμότεχνον εἶναι ἔμενεν παρ’ αὐτοῖς καὶ ⸀ἠργάζετο, ἦσαν γὰρ σκηνοποιοὶ ⸂τῇ τέχνῃ⸃.","lemmas":["καί","διά","ὁ","ὁμότεχνος","εἰμί","μένω","παρά","αὐτός","ἐργάζομαι","γάρ","σκηνοποιός","τέχνη"],"tr":"And because of being of the same craft, [he] remained beside them and worked, for [they] were tentmakers [by] trade.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ὁμότεχνον","lemma":"ὁμότεχνος","type":"adjective","code":"A"},{"form":"εἶναι","lemma":"εἰμί","type":"verb","code":"V"},{"form":"ἔμενεν","lemma":"μένω","type":"verb","code":"V"},{"form":"παρ’","lemma":"παρά","type":"preposition","code":"P"},{"form":"αὐτοῖς","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"⸀ἠργάζετο,","lemma":"ἐργάζομαι","type":"verb","code":"V"},{"form":"ἦσαν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"σκηνοποιοὶ","lemma":"σκηνοποιός","type":"noun","code":"N"},{"form":"⸂τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"τέχνῃ⸃.","lemma":"τέχνη","type":"noun","code":"N"}]},{"v":4,"ref":"Acts 18:4","grc":"διελέγετο δὲ ἐν τῇ συναγωγῇ κατὰ πᾶν σάββατον, ἔπειθέν τε Ἰουδαίους καὶ Ἕλληνας.","lemmas":["διαλέγομαι","δέ","ἐν","ὁ","συναγωγή","κατά","πᾶς","σάββατον","πείθω","τέ","Ἰουδαῖος","καί","Ἕλλην"],"tr":"But [he] was speaking in the synagogue every Sabbath, and [he] was persuading both Jews and Greeks.","para":1,"para_continued":false,"words":[{"form":"διελέγετο","lemma":"διαλέγομαι","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"συναγωγῇ","lemma":"συναγωγή","type":"noun","code":"N"},{"form":"κατὰ","lemma":"κατά","type":"preposition","code":"P"},{"form":"πᾶν","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"σάββατον,","lemma":"σάββατον","type":"noun","code":"N"},{"form":"ἔπειθέν","lemma":"πείθω","type":"verb","code":"V"},{"form":"τε","lemma":"τέ","type":"conjunction","code":"C"},{"form":"Ἰουδαίους","lemma":"Ἰουδαῖος","type":"adjective","code":"A"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"Ἕλληνας.","lemma":"Ἕλλην","type":"noun","code":"N"}]},{"v":5,"ref":"Acts 18:5","grc":"Ὡς δὲ κατῆλθον ἀπὸ τῆς Μακεδονίας ὅ τε Σιλᾶς καὶ ὁ Τιμόθεος, συνείχετο τῷ ⸀λόγῳ ὁ Παῦλος, διαμαρτυρόμενος τοῖς Ἰουδαίοις ⸀εἶναι τὸν χριστὸν Ἰησοῦν.","lemmas":["ὡς","δέ","κατέρχομαι","ἀπό","ὁ","Μακεδονία","τέ","Σιλᾶς","καί","Τιμόθεος","συνέχω","λόγος","Παῦλος","διαμαρτύρομαι","Ἰουδαῖος","εἰμί","Χριστός","Ἰησοῦς"],"tr":"But as Silas and Timothy came down from Macedonia, Paul was deeply devoted to the word, thoroughly testifying Jesus to be the Christ to the Jews.","para":1,"para_continued":false,"words":[{"form":"Ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"κατῆλθον","lemma":"κατέρχομαι","type":"verb","code":"V"},{"form":"ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"Μακεδονίας","lemma":"Μακεδονία","type":"noun","code":"N"},{"form":"ὅ","lemma":"ὁ","type":"article","code":"RA"},{"form":"τε","lemma":"τέ","type":"conjunction","code":"C"},{"form":"Σιλᾶς","lemma":"Σιλᾶς","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Τιμόθεος,","lemma":"Τιμόθεος","type":"noun","code":"N"},{"form":"συνείχετο","lemma":"συνέχω","type":"verb","code":"V"},{"form":"τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"⸀λόγῳ","lemma":"λόγος","type":"noun","code":"N"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Παῦλος,","lemma":"Παῦλος","type":"noun","code":"N"},{"form":"διαμαρτυρόμενος","lemma":"διαμαρτύρομαι","type":"verb","code":"V"},{"form":"τοῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"Ἰουδαίοις","lemma":"Ἰουδαῖος","type":"adjective","code":"A"},{"form":"⸀εἶναι","lemma":"εἰμί","type":"verb","code":"V"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"χριστὸν","lemma":"Χριστός","type":"noun","code":"N"},{"form":"Ἰησοῦν.","lemma":"Ἰησοῦς","type":"noun","code":"N"}]},{"v":6,"ref":"Acts 18:6","grc":"ἀντιτασσομένων δὲ αὐτῶν καὶ βλασφημούντων ἐκτιναξάμενος τὰ ἱμάτια εἶπεν πρὸς αὐτούς· Τὸ αἷμα ὑμῶν ἐπὶ τὴν κεφαλὴν ὑμῶν· καθαρὸς ἐγώ· ἀπὸ τοῦ νῦν εἰς τὰ ἔθνη πορεύσομαι.","lemmas":["ἀντιτάσσομαι","δέ","αὐτός","καί","βλασφημέω","ἐκτινάσσω","ὁ","ἱμάτιον","λέγω","πρός","αἷμα","σύ","ἐπί","κεφαλή","καθαρός","ἐγώ","ἀπό","νῦν","εἰς","ἔθνος","πορεύομαι"],"tr":"But [with] their resisting and blaspheming, having shaken off the clothes, [he] said to them, “[All] your blood [is] upon [all] your head; I [am] clean. From now, into the nations [I] will go.”","para":1,"para_continued":false,"words":[{"form":"ἀντιτασσομένων","lemma":"ἀντιτάσσομαι","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"αὐτῶν","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"βλασφημούντων","lemma":"βλασφημέω","type":"verb","code":"V"},{"form":"ἐκτιναξάμενος","lemma":"ἐκτινάσσω","type":"verb","code":"V"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἱμάτια","lemma":"ἱμάτιον","type":"noun","code":"N"},{"form":"εἶπεν","lemma":"λέγω","type":"verb","code":"V"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"αὐτούς·","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"Τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"αἷμα","lemma":"αἷμα","type":"noun","code":"N"},{"form":"ὑμῶν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"ἐπὶ","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"κεφαλὴν","lemma":"κεφαλή","type":"noun","code":"N"},{"form":"ὑμῶν·","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"καθαρὸς","lemma":"καθαρός","type":"adjective","code":"A"},{"form":"ἐγώ·","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"νῦν","lemma":"νῦν","type":"adverb","code":"D"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἔθνη","lemma":"ἔθνος","type":"noun","code":"N"},{"form":"πορεύσομαι.","lemma":"πορεύομαι","type":"verb","code":"V"}]},{"v":7,"ref":"Acts 18:7","grc":"καὶ μεταβὰς ἐκεῖθεν ⸀εἰσῆλθεν εἰς οἰκίαν τινὸς ὀνόματι ⸀Τιτίου Ἰούστου σεβομένου τὸν θεόν, οὗ ἡ οἰκία ἦν συνομοροῦσα τῇ συναγωγῇ.","lemmas":["καί","μεταβαίνω","ἐκεῖθεν","εἰσέρχομαι","εἰς","οἰκία","τις","ὄνομα","Τίτιος","Ἰοῦστος","σέβομαι","ὁ","θεός","ὅς","εἰμί","συνομορέω","συναγωγή"],"tr":"And having left from there, [he] entered into [a] house of [a] certain [one with the] name Titus Justus, worshiping God, whose house was adjoining to the synagogue.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"μεταβὰς","lemma":"μεταβαίνω","type":"verb","code":"V"},{"form":"ἐκεῖθεν","lemma":"ἐκεῖθεν","type":"adverb","code":"D"},{"form":"⸀εἰσῆλθεν","lemma":"εἰσέρχομαι","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"οἰκίαν","lemma":"οἰκία","type":"noun","code":"N"},{"form":"τινὸς","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"ὀνόματι","lemma":"ὄνομα","type":"noun","code":"N"},{"form":"⸀Τιτίου","lemma":"Τίτιος","type":"noun","code":"N"},{"form":"Ἰούστου","lemma":"Ἰοῦστος","type":"noun","code":"N"},{"form":"σεβομένου","lemma":"σέβομαι","type":"verb","code":"V"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεόν,","lemma":"θεός","type":"noun","code":"N"},{"form":"οὗ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"οἰκία","lemma":"οἰκία","type":"noun","co