ction","code":"C"},{"form":"Παῦλος","lemma":"Παῦλος","type":"noun","code":"N"},{"form":"ἔτι","lemma":"ἔτι","type":"adverb","code":"D"},{"form":"προσμείνας","lemma":"προσμένω","type":"verb","code":"V"},{"form":"ἡμέρας","lemma":"ἡμέρα","type":"noun","code":"N"},{"form":"ἱκανὰς","lemma":"ἱκανός","type":"adjective","code":"A"},{"form":"τοῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀδελφοῖς","lemma":"ἀδελφός","type":"noun","code":"N"},{"form":"ἀποταξάμενος","lemma":"ἀποτάσσομαι","type":"verb","code":"V"},{"form":"ἐξέπλει","lemma":"ἐκπλέω","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"Συρίαν,","lemma":"Συρία","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"σὺν","lemma":"σύν","type":"preposition","code":"P"},{"form":"αὐτῷ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"Πρίσκιλλα","lemma":"Πρίσκιλλα","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"Ἀκύλας,","lemma":"Ἀκύλας","type":"noun","code":"N"},{"form":"κειράμενος","lemma":"κείρω","type":"verb","code":"V"},{"form":"⸂ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"Κεγχρεαῖς","lemma":"Κεγχρεαί","type":"noun","code":"N"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"κεφαλήν⸃,","lemma":"κεφαλή","type":"noun","code":"N"},{"form":"εἶχεν","lemma":"ἔχω","type":"verb","code":"V"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"εὐχήν.","lemma":"εὐχή","type":"noun","code":"N"}]},{"v":19,"ref":"Acts 18:19","grc":"⸀κατήντησαν δὲ εἰς Ἔφεσον, κἀκείνους κατέλιπεν αὐτοῦ, αὐτὸς δὲ εἰσελθὼν εἰς τὴν συναγωγὴν ⸀διελέξατο τοῖς Ἰουδαίοις.","lemmas":["καταντάω","δέ","εἰς","Ἔφεσος","κἀκεῖνος","καταλείπω","αὐτοῦ","αὐτός","εἰσέρχομαι","ὁ","συναγωγή","διαλέγομαι","Ἰουδαῖος"],"tr":"But [they] came down into Ephesus, and [he] left those [ones] of him. But he, having entered into the synagogue, spoke to the Jews.","para":1,"para_continued":false,"words":[{"form":"⸀κατήντησαν","lemma":"καταντάω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"Ἔφεσον,","lemma":"Ἔφεσος","type":"noun","code":"N"},{"form":"κἀκείνους","lemma":"κἀκεῖνος","type":"demonstrative_pronoun","code":"RD"},{"form":"κατέλιπεν","lemma":"καταλείπω","type":"verb","code":"V"},{"form":"αὐτοῦ,","lemma":"αὐτοῦ","type":"adverb","code":"D"},{"form":"αὐτὸς","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"εἰσελθὼν","lemma":"εἰσέρχομαι","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"συναγωγὴν","lemma":"συναγωγή","type":"noun","code":"N"},{"form":"⸀διελέξατο","lemma":"διαλέγομαι","type":"verb","code":"V"},{"form":"τοῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"Ἰουδαίοις.","lemma":"Ἰουδαῖος","type":"adjective","code":"A"}]},{"v":20,"ref":"Acts 18:20","grc":"ἐρωτώντων δὲ αὐτῶν ἐπὶ πλείονα χρόνον ⸀μεῖναι οὐκ ἐπένευσεν,","lemmas":["ἐρωτάω","δέ","αὐτός","ἐπί","πολύς","χρόνος","μένω","οὐ","ἐπινεύω"],"tr":"But [with] their asking him to stay upon [a] longer time, [he] did not consent,","para":1,"para_continued":false,"words":[{"form":"ἐρωτώντων","lemma":"ἐρωτάω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"αὐτῶν","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἐπὶ","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"πλείονα","lemma":"πολύς","type":"adjective","code":"A"},{"form":"χρόνον","lemma":"χρόνος","type":"noun","code":"N"},{"form":"⸀μεῖναι","lemma":"μένω","type":"verb","code":"V"},{"form":"οὐκ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"ἐπένευσεν,","lemma":"ἐπινεύω","type":"verb","code":"V"}]},{"v":21,"ref":"Acts 1