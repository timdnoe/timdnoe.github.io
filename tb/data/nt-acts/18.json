ν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"περὶ","lemma":"περί","type":"preposition","code":"P"},{"form":"λόγου","lemma":"λόγος","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ὀνομάτων","lemma":"ὄνομα","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"νόμου","lemma":"νόμος","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"καθ’","lemma":"κατά","type":"preposition","code":"P"},{"form":"ὑμᾶς,","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"ὄψεσθε","lemma":"ὁράω","type":"verb","code":"V"},{"form":"αὐτοί·","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"⸀κριτὴς","lemma":"κριτής","type":"noun","code":"N"},{"form":"ἐγὼ","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"τούτων","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"βούλομαι","lemma":"βούλομαι","type":"verb","code":"V"},{"form":"εἶναι.","lemma":"εἰμί","type":"verb","code":"V"}]},{"v":16,"ref":"Acts 18:16","grc":"καὶ ἀπήλασεν αὐτοὺς ἀπὸ τοῦ βήματος.","lemmas":["καί","ἀπελαύνω","αὐτός","ἀπό","ὁ","βῆμα"],"tr":"And [he] drove them away from the judgment seat.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἀπήλασεν","lemma":"ἀπελαύνω","type":"verb","code":"V"},{"form":"αὐτοὺς","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"βήματος.","lemma":"βῆμα","type":"noun","code":"N"}]},{"v":17,"ref":"Acts 18:17","grc":"ἐπιλαβόμενοι δὲ ⸀πάντες Σωσθένην τὸν ἀρχισυνάγωγον ἔτυπτον ἔμπροσθεν τοῦ βήματος· καὶ οὐδὲν τούτων τῷ Γαλλίωνι ⸀ἔμελεν.","lemmas":["ἐπιλαμβάνομαι","δέ","πᾶς","Σωσθένης","ὁ","ἀρχισυνάγωγος","τύπτω","ἔμπροσθεν","βῆμα","καί","οὐδείς","οὗτος","Γαλλίων","μέλω"],"tr":