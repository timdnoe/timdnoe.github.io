"},{"form":"ἀναβὰς","lemma":"ἀναβαίνω","type":"verb","code":"V"},{"form":"ἐκεῖ","lemma":"ἐκεῖ","type":"adverb","code":"D"},{"form":"περὶ","lemma":"περί","type":"preposition","code":"P"},{"form":"τούτων","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"⸀κριθῆναι","lemma":"κρίνω","type":"verb","code":"V"},{"form":"ἐπ’","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"ἐμοῦ;","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"}]},{"v":10,"ref":"Acts 25:10","grc":"εἶπεν δὲ ὁ Παῦλος· ⸂Ἐπὶ τοῦ βήματος Καίσαρος ἑστώς⸃ εἰμι, οὗ με δεῖ κρίνεσθαι. Ἰουδαίους οὐδὲν ⸀ἠδίκησα, ὡς καὶ σὺ κάλλιον ἐπιγινώσκεις.","lemmas":["λέγω","δέ","ὁ","Παῦλος","ἐπί","βῆμα","Καῖσαρ","ἵστημι","εἰμί","οὗ","ἐγώ","δέω","κρίνω","Ἰουδαῖος","οὐδείς","ἀδικέω","ὡς","καί","σύ","καλός","ἐπιγινώσκω"],"tr":"But Paul said, “[I] am having had stood upon the judgment seat of Caesar, of which [it] binds me to be judged; [I] wronged the Jews [in] nothing, as also you more fully know.","para":1,"para_continued":false,"words":[{"form":"εἶπεν","lemma":"λέγω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Παῦλος·","lemma":"Παῦλος","type":"noun","code":"N"},{"form":"⸂Ἐπὶ","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"βήματος","lemma":"βῆμα","type":"noun","code":"N"},{"form":"Καίσαρος","lemma":"Καῖσαρ","type":"noun","code":"N"},{"form":"ἑστώς⸃","lemma":"ἵστημι","type":"verb","code":"V"},{"form":"εἰμι,","lemma":"εἰμί","type":"verb","code":"V"},{"form":"οὗ","lemma":"οὗ","type":"adverb","code":"D"},{"form":"με","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"δεῖ","lemma":"δέω","type":"verb","code":"V"},{"form":"κρίνεσθαι.","lemma":"κρίνω","type":"verb","code":"V"},{"form":"Ἰουδαίους","lemma":"Ἰουδαῖος","type":"adjective","code":"A"},{"form":"οὐδὲν","lemma":"οὐδείς","type":"adjective","code":"A"},{"form":"⸀ἠδίκησα,","lemm