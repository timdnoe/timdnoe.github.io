_continued":false,"words":[{"form":"εἶπον","lemma":"λέγω","type":"verb","code":"V"},{"form":"δέ·","lemma":"δέ","type":"conjunction","code":"C"},{"form":"Μηδαμῶς,","lemma":"μηδαμῶς","type":"adverb","code":"D"},{"form":"κύριε,","lemma":"κύριος","type":"noun","code":"N"},{"form":"⸀ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"κοινὸν","lemma":"κοινός","type":"adjective","code":"A"},{"form":"ἢ","lemma":"ἤ","type":"conjunction","code":"C"},{"form":"ἀκάθαρτον","lemma":"ἀκάθαρτος","type":"adjective","code":"A"},{"form":"οὐδέποτε","lemma":"οὐδέποτε","type":"adverb","code":"D"},{"form":"εἰσῆλθεν","lemma":"εἰσέρχομαι","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"στόμα","lemma":"στόμα","type":"noun","code":"N"},{"form":"μου.","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"}]},{"v":9,"ref":"Acts 11:9","grc":"ἀπεκρίθη δὲ ⸂φωνὴ ἐκ δευτέρου⸃ ἐκ τοῦ οὐρανοῦ· Ἃ ὁ θεὸς ἐκαθάρισεν σὺ μὴ κοίνου.","lemmas":["ἀποκρίνομαι","δέ","φωνή","ἐκ","δεύτερος","ὁ","οὐρανός","ὅς","θεός","καθαρίζω","σύ","μή","κοινόω"],"tr":"But [a] voice answered out of [a] second time from the heaven, ‘[That] which God cleansed, do not, you, defile.’","para":1,"para_continued":false,"words":[{"form":"ἀπεκρίθη","lemma":"ἀποκρίνομαι","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"⸂φωνὴ","lemma":"φωνή","type":"noun","code":"N"},{"form":"ἐκ","lemma":"ἐκ","type":"preposition","code":"P"},{"form":"δευτέρου⸃","lemma":"δεύτερος","type":"adjective","code":"A"},{"form":"ἐκ","lemma":"ἐκ","type":"preposition","code":"P"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"οὐρανοῦ·","lemma":"οὐρανός","type":"noun","code":"N"},{"form":"Ἃ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεὸς","lemma":"θεός","type":"noun","code":"N"},{"form":"ἐκαθάρισεν","lemma":"καθαρίζω","type":"verb","code":"V"},{"form":"σὺ","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"κοίνου.","lemma":"κοινόω","type":"verb","code":"V"}]},{"v":10,"ref":"Acts 11:10","grc":"τοῦτο δὲ ἐγένετο ἐπὶ τρίς, καὶ ⸂ἀνεσπάσθη πάλιν⸃ ἅπαντα εἰς τὸν οὐρανόν.","lemmas":["οὗτος","δέ","γίνομαι","ἐπί","τρίς","καί","ἀνασπάω","πάλιν","ἅπας","εἰς","ὁ","οὐρανός"],"tr":"But this happened upon thrice, and [it] was pulled up again, all into the heaven.","para":1,"para_continued":false,"words":[{"form":"τοῦτο","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἐγένετο","lemma":"γίνομαι","type":"verb","code":"V"},{"form":"ἐπὶ","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"τρίς,","lemma":"τρίς","type":"adverb","code":"D"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"⸂ἀνεσπάσθη","lemma":"ἀνασπάω","type":"verb","code":"V"},{"form":"πάλιν⸃","lemma":"πάλιν","type":"adverb","code":"D"},{"form":"ἅπαντα","lemma":"ἅπας","type":"adjective","code":"A"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"οὐρανόν.","lemma":"οὐρανός","type":"noun","code":"N"}]},{"v":11,"ref":"Acts 11:11","grc":"καὶ ἰδοὺ ἐξαυτῆς τρεῖς ἄνδρες ἐπέστησαν ἐπὶ τὴν οἰκίαν ἐν ᾗ ⸀ἦμεν, ἀπεσταλμένοι ἀπὸ Καισαρείας πρός με.","lemmas":["καί","ἰδού","ἐξαυτῆς","τρεῖς","ἀνήρ","ἐφίστημι","ἐπί","ὁ","οἰκία","ἐν","ὅς","εἰμί","ἀποστέλλω","ἀπό","Καισάρεια","πρός","ἐγώ"],"tr":"And behold, at once three men stood upon the house in which [we] were. having had been sent from Caesarea toward me.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἰδοὺ","lemma":"ἰδού","type":"particle","code":"X"},{"form":"ἐξαυτῆς","lemma":"ἐξαυτῆς","type":"adverb","code":"D"},{"form":"τρεῖς","lemma":"τρεῖς","type":"adjective","code":"A"},{"form":"ἄνδρες","lemma":"ἀνήρ","type":"noun","code":"N"},{"form":"ἐπέστησαν","lemma":"ἐφίστημι","type":"verb","code":"V"},{"form":"ἐπὶ","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"οἰκίαν","lemma":"οἰκία","type":"noun","code":"N"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"ᾗ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"⸀ἦμεν,","lemma":"εἰμί","type":"verb","code":"V"},{"form":"ἀπεσταλμένοι","lemma":"ἀποστέλλω","type":"verb","code":"V"},{"form":"ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"Καισαρείας","lemma":"Καισάρεια","type":"noun","code":"N"},{"form":"πρός","lemma":"πρός","type":"preposition","code":"P"},{"form":"με.","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"}]},{"v":12,"ref":"Acts 11:12","grc":"εἶπεν δὲ ⸂τὸ πνεῦμά μοι⸃ συνελθεῖν αὐτοῖς μηδὲν ⸀διακρίναντα. ἦλθον δὲ σὺν ἐμοὶ καὶ οἱ ἓξ ἀδελφοὶ οὗτοι, καὶ εἰσήλθομεν εἰς τὸν οἶκον τοῦ ἀνδρός.","lemmas":["λέγω","δέ","ὁ","πνεῦμα","ἐγώ","συνέρχομαι","αὐτός","μηδείς","διακρίνω","ἔρχομαι","σύν","καί","ἕξ","ἀδελφός","οὗτος","εἰσέρχομαι","εἰς","οἶκος","ἀνήρ"],"tr":"But the Spirit said to me to have come together with them, having doubted nothing. But these six brothers also came with me. and [we] entered into the house of the man.","para":1,"para_continued":false,"words":[{"form":"εἶπεν","lemma":"λέγω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"⸂τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πνεῦμά","lemma":"πνεῦμα","type":"noun","code":"N"},{"form":"μοι⸃","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"συνελθεῖν","lemma":"συνέρχομαι","type":"verb","code":"V"},{"form":"αὐτοῖς","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"μηδὲν","lemma":"μηδείς","type":"adjective","code":"A"},{"form":"⸀διακρίναντα.","lemma":"διακρίνω","type":"verb","code":"V"},{"form":"ἦλθον","lemma":"ἔρχομαι","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","t