ιανούς.","lemmas":["καί","εὑρίσκω","ἄγω","εἰς","Ἀντιόχεια","γίνομαι","δέ","αὐτός","ἐνιαυτός","ὅλος","συνάγω","ἐν","ὁ","ἐκκλησία","διδάσκω","ὄχλος","ἱκανός","χρηματίζω","τέ","πρώτως","μαθητής","Χριστιανός"],"tr":"And having found [him, he] led [him] into Antioch. But [it] came about to them even [for a] whole year to be gathered in the church and to teach [a] sufficient crowd, and to first have bore the name Christian disciples in Antioch.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"εὑρὼν","lemma":"εὑρίσκω","type":"verb","code":"V"},{"form":"⸀ἤγαγεν","lemma":"ἄγω","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"Ἀντιόχειαν.","lemma":"Ἀντιόχεια","type":"noun","code":"N"},{"form":"ἐγένετο","lemma":"γίνομαι","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"⸂αὐτοῖς","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"καὶ⸃","lemma":"καί","type":"adverb","code":"D"},{"form":"ἐνιαυτὸν","lemma":"ἐνιαυτός","type":"noun","code":"N"},{"form":"ὅλον","lemma":"ὅλος","type":"adjective","code":"A"},{"form":"συναχθῆναι","lemma":"συνάγω","type":"verb","code":"V"},{"form":"⸀ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἐκκλησίᾳ","lemma":"ἐκκλησία","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"διδάξαι","lemma":"διδάσκω","type":"verb","code":"V"},{"form":"ὄχλον","lemma":"ὄχλος","type":"noun","code":"N"},{"form":"ἱκανόν,","lemma":"ἱκανός","type":"adjective","code":"A"},{"form":"χρηματίσαι","lemma":"χρηματίζω","type":"verb","code":"V"},{"form":"τε","lemma":"τέ","type":"conjunction","code":"C"},{"form":"⸀πρώτως","lemma":"πρώτως","type":"adverb","code":"D"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"Ἀντιοχείᾳ","lemma":"Ἀντιόχεια","type":"noun","code":"N"},{"form":"τοὺς","lemma":"ὁ",