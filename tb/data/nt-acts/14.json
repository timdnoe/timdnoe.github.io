ου.","lemmas":["καλέω","τέ","ὁ","Βαρναβᾶς","Ζεύς","δέ","Παῦλος","Ἑρμῆς","ἐπειδή","αὐτός","εἰμί","ἡγέομαι","λόγος"],"tr":"And they were calling also Barnabas Zeus, but Paul Hermes, since he was the leader of the word.","para":1,"para_continued":false,"words":[{"form":"ἐκάλουν","lemma":"καλέω","type":"verb","code":"V"},{"form":"τε","lemma":"τέ","type":"conjunction","code":"C"},{"form":"⸀τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"Βαρναβᾶν","lemma":"Βαρναβᾶς","type":"noun","code":"N"},{"form":"Δία,","lemma":"Ζεύς","type":"noun","code":"N"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"Παῦλον","lemma":"Παῦλος","type":"noun","code":"N"},{"form":"Ἑρμῆν,","lemma":"Ἑρμῆς","type":"noun","code":"N"},{"form":"ἐπειδὴ","lemma":"ἐπειδή","type":"conjunction","code":"C"},{"form":"αὐτὸς","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἦν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἡγούμενος","lemma":"ἡγέομαι","type":"verb","code":"V"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"λόγου.","lemma":"λόγος","type":"noun","code":"N"}]},{"v":13,"ref":"Acts 14:13","grc":"ὅ ⸀τε ἱερεὺς τοῦ Διὸς τοῦ ὄντος πρὸ τῆς ⸀πόλεως ταύρους καὶ στέμματα ἐπὶ τοὺς πυλῶνας ἐνέγκας σὺν τοῖς ὄχλοις ἤθελεν θύειν.","lemmas":["ὁ","τέ","ἱερεύς","Ζεύς","εἰμί","πρό","πόλις","ταῦρος","καί","στέμμα","ἐπί","πυλών","φέρω","σύν","ὄχλος","θέλω","θύω"],"tr":"And the priest of Zeus being before the city, having brought bulls and crowns upon the gates, together with the crowds, desired to sacrifice.","para":1,"para_continued":false,"words":[{"form":"ὅ","lemma":"ὁ","type":"article","code":"RA"},{"form":"⸀τε","lemma":"τέ","type":"conjunction","code":"C"},{"form":"ἱερεὺς","lemma":"ἱερεύς","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Διὸς","lemma":"Ζεύς","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ὄντος","lemma":"εἰμί","type":"verb","code":"V"},{"form":"πρὸ","lemma":"πρό","type":"preposition","code":"P"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"⸀πόλεως","lemma":"πόλις","type":"noun","code":"N"},{"form":"ταύρους","lemma":"ταῦρος","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"στέμματα","lemma":"στέμμα","type":"noun","code":"N"},{"form":"ἐπὶ","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"τοὺς","lemma":"ὁ","type":"article","code":"RA"},{"form":"πυλῶνας","lemma":"πυλών","type":"noun","code":"N"},{"form":"ἐνέγκας","lemma":"φέρω","type":"verb","code":"V"},{"form":"σὺν","lemma":"σύν","type":"preposition","code":"P"},{"form":"τοῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ὄχλοις","lemma":"ὄχλος","type":"noun","code":"N"},{"form":"ἤθελεν","lemma":"θέλω","type":"verb","code":"V"},{"form":"θύειν.","lemma":"θύω","type":"verb","code":"V"}]},{"v":14,"ref":"Acts 14:14","grc":"ἀκούσαντες δὲ οἱ ἀπόστολοι Βαρναβᾶς καὶ Παῦλος, διαρρήξαντες τὰ ἱμάτια ⸀αὐτῶν ⸀ἐξεπήδησαν εἰς τὸν ὄχλον κράζοντες","lemmas":["ἀκούω","δέ","ὁ","ἀπόστολος","Βαρναβᾶς","καί","Παῦλος","διαρρήγνυμι","ἱμάτιον","αὐτός","ἐκπηδάω","εἰς","ὄχλος","κράζω"],"tr":"But the apostles Barnabas and Paul, having heard having [this], having torn their clothes, [they] leaped into the crowd, crying out","para":1,"para_continued":false,"words":[{"form":"ἀκούσαντες","lemma":"ἀκούω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀπόστολοι","lemma":"ἀπόστολος","type":"noun","code":"N"},{"form":"Βαρναβᾶς","lemma":"Βαρναβᾶς","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"Παῦλος,","lemma":"Παῦλος","type":"noun","code":"N"},{"form":"διαρρήξαντες","lemma":"διαρρήγνυμι","type":"verb","code":"V"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{