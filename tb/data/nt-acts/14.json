ω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"⸂τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"μαθητῶν","lemma":"μαθητής","type":"noun","code":"N"},{"form":"αὐτὸν⸃","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἀναστὰς","lemma":"ἀνίστημι","type":"verb","code":"V"},{"form":"εἰσῆλθεν","lemma":"εἰσέρχομαι","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"πόλιν.","lemma":"πόλις","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἐπαύριον","lemma":"ἐπαύριον","type":"adverb","code":"D"},{"form":"ἐξῆλθεν","lemma":"ἐξέρχομαι","type":"verb","code":"V"},{"form":"σὺν","lemma":"σύν","type":"preposition","code":"P"},{"form":"τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Βαρναβᾷ","lemma":"Βαρναβᾶς","type":"noun","code":"N"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"Δέρβην.","lemma":"Δέρβη","type":"noun","code":"N"}]},{"v":21,"ref":"Acts 14:21","grc":"Εὐαγγελισάμενοί τε τὴν πόλιν ἐκείνην καὶ μαθητεύσαντες ἱκανοὺς ὑπέστρεψαν εἰς τὴν Λύστραν καὶ ⸀εἰς Ἰκόνιον καὶ ⸁εἰς Ἀντιόχειαν,","lemmas":["εὐαγγελίζω","τέ","ὁ","πόλις","ἐκεῖνος","καί","μαθητεύω","ἱκανός","ὑποστρέφω","εἰς","Λύστρα","Ἰκόνιον","Ἀντιόχεια"],"tr":"Having evangelized that city and discipled sufficient [ones, they] returned into Lystra and into Iconium and into Antioch,","para":1,"para_continued":false,"words":[{"form":"Εὐαγγελισάμενοί","lemma":"εὐαγγελίζω","type":"verb","code":"V"},{"form":"τε","lemma":"τέ","type":"conjunction","code":"C"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"πόλιν","lemma":"πόλις","type":"noun","code":"N"},{"form":"ἐκείνην","lemma":"ἐκεῖνος","type":"demonstrative_pronoun","code":"RD"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"μαθητεύσαντες","lemma":"μαθητεύω","type":"verb","code":"V"},{"form":"ἱκανοὺς","lemma":"ἱκανός","type":"adjective","code":"A"},{"form":"ὑπέστρεψαν","lemma":"ὑποστρέφω","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"Λύστραν","lemma":"Λύστρα","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"⸀εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"Ἰκόνιον","lemma":"Ἰκόνιον","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"⸁εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"Ἀντιόχειαν,","lemma":"Ἀντιόχεια","type":"noun","code":"N"}]},{"v":22,"ref":"Acts 14:22","grc":"ἐπιστηρίζοντες τὰς ψυχὰς τῶν μαθητῶν, παρακαλοῦντες ἐμμένειν τῇ πίστει καὶ ὅτι διὰ πολλῶν θλίψεων δεῖ ἡμᾶς εἰσελθεῖν εἰς τὴν βασιλείαν τοῦ θεοῦ.","lemmas":["ἐπιστηρίζω","ὁ","ψυχή","μαθητής","παρακαλέω","ἐμμένω","πίστις","καί","ὅτι","διά","πολύς","θλῖψις","δέω","ἐγώ","εἰσέρχομαι","εἰς","βασιλεία","θεός"],"tr":"supporting the souls of the disciples, exhorting [them] to remain in the faith and that through many tribulations [it] binds us to enter into the kingdom of God.","para":1,"para_continued":false,"words":[{"form":"ἐπιστηρίζοντες","lemma":"ἐπιστηρίζω","type":"verb","code":"V"},{"form":"τὰς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ψυχὰς","lemma":"ψυχή","type":"noun","code":"N"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"μαθητῶν,","lemma":"μαθητής","type":"noun","code":"N"},{"form":"παρακαλοῦντες","lemma":"παρακαλέω","type":"verb","code":"V"},{"form":"ἐμμένειν","lemma":"ἐμμένω","type":"verb","code":"V"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πίστει","lemma":"πίστις","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"πολλῶν","lemma":"πολύς","type":"adjective","code":"A"},{"form":"θλίψεων","lemma":"θλῖψις","type":"noun","code":"N"},{"form":"δεῖ","lemma":"δέω","type":"verb","code":"V"},{"form":"ἡμᾶς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"εἰσελθεῖν","lemma":"εἰσέρχομαι","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"βασιλείαν","lemma":"βασιλεία","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεοῦ.","lemma":"θεός","type":"noun","code":"N"}]},{"v":23,"ref":"Acts 14:23","grc":"χειροτονήσαντες δὲ αὐτοῖς ⸂κατ’ ἐκκλησίαν πρεσβυτέρους⸃ προσευξάμενοι μετὰ νηστειῶν παρέθεντο αὐτοὺς τῷ κυρίῳ εἰς ὃν πεπιστεύκεισαν.","lemmas":["χειροτονέω","δέ","αὐτός","κατά","ἐκκλησία","πρεσβύτερος","προσεύχομαι","μετά","νηστεία","παρατίθημι","ὁ","κύριος","εἰς","ὅς","πιστεύω"],"tr":"But having appointed elders to them according to the church, having prayed with fasts, [they] committed them to the Lord into whom [they] had believed.","para":1,"para_continued":false,"words":[{"form":"χειροτονήσαντες","lemma":"χειροτονέω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"αὐτοῖς","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"⸂κατ’","lemma":"κατά","type":"preposition","code":"P"},{"form":"ἐκκλησίαν","lemma":"ἐκκλησία","type":"noun","code":"N"},{"form":"πρεσβυτέρους⸃","lemma":"πρεσβύτερος","type":"adjective","code":"A"},{"form":"προσευξάμενοι","lemma":"προσεύχομαι","type":"verb","code":"V"},{"form":"μετὰ","lemma":"μετά","type":"preposition","code":"P"},{"form":"νηστειῶν","lemma":"νηστεία","type":"noun","code":"N"},{"form":"παρέθεντο","lemma":"παρατίθημι","type":"verb","code":"V"},{"form":"αὐτοὺς","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"κυρίῳ","lemma":"κύριος","type":"noun","code":"N"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"ὃν","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"πεπιστεύκεισαν.","lemma":"πιστεύω","type":"verb","code":"V"}]},{"v":24,"ref":"Acts 14:24","grc":"καὶ διελθόντες τὴν Πισιδίαν ἦλθον εἰς ⸀τὴν Παμφυλίαν,","lemmas":["καί","διέρχομαι","ὁ","Πισιδία","ἔρχομαι","εἰς","Παμφυλία"],"tr":"And having passed through Pisidia, [they] came into Pamphylia.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"διελθόντες","lemma":"διέρχομαι","type":"verb","code":"V"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"Πισιδίαν","lemma":"Πισιδία","type":"noun","code":"N"},{"form":"ἦλθον","lemma":"ἔρχομαι","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"⸀τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"Παμφυλίαν,","lemma":"Παμφυλία","type":"noun","code":"N"}]},{"v":25,"ref":"Acts 14:25","grc":"καὶ λαλήσαντες ἐν Πέργῃ τὸν λόγον κατέβησαν εἰς Ἀττάλειαν,","lemmas":["καί","λαλέω","ἐν","Πέργη","ὁ","λόγος","καταβαίνω","εἰς","Ἀττάλεια"],"tr":"And having spoken the word in Perga, [they] went down into Attalia.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"λαλήσαντες","lemma":"λαλέω","type":"verb","code":"V"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"Πέργῃ","lemma":"Πέργη","type":"noun","code":"N"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"λόγον","lemma":"λόγος","type":"noun","code":"N"},{"form":"κατέβησαν","lemma":"καταβαίνω","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"Ἀττάλειαν,","lemma":"Ἀττάλεια","type":"noun","code":"N"}]},{"v":26,"ref":"Acts 14:26","grc":"κἀκεῖθεν ἀπέπλευσαν εἰς Ἀντιόχειαν, ὅθεν ἦσαν παραδεδομένοι τῇ χάριτι τοῦ θεοῦ εἰς τὸ ἔργον ὃ ἐπλήρωσαν.","lemmas":["κἀκεῖθεν","ἀποπλέω","εἰς","Ἀντιόχεια","ὅθεν","εἰμί","παραδίδωμι","ὁ","χάρις","θεός","ἔργον","ὅς","πληρόω"],"tr":"And from there [they] sailed into Antioch, from which [they] were having had been delivered up [with] the grace of God for the work which [they] fulfilled.","para":1,"para_continued":false,"words":[{"form":"κἀκεῖθεν","lemma":"κἀκεῖθεν","type":"conjunction","code":"C"},{"form":"ἀπέπλευσαν","lemma":"ἀποπλέω","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"Ἀντιόχειαν,","lemma":"Ἀντιόχεια","type":"noun","code":"N"},{"form":"ὅθεν","lemma":"ὅθεν","type":"adverb","code":"D"},{"form":"ἦσαν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"παραδεδομένοι","lemma":"παραδίδωμι","type":"verb","code":"V"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"χάριτι","lemma":"χάρις","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεοῦ","lemma":"θεός","type":"noun","code":"N"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἔργον","lemma":"ἔργον","type":"noun","code":"N"},{"form":"ὃ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"ἐπλήρωσαν.","lemma":"πληρόω","type":"verb","code":"V"}]},{"v":27,"ref":"Acts 14:27","grc":"παραγενόμενοι δὲ καὶ συναγαγόντες τὴν ἐκκλησίαν ⸀ἀνήγγελλον ὅσα ἐποίησεν ὁ θεὸς μετ’ αὐτῶν καὶ ὅτι ἤνοιξεν τοῖς ἔθνεσιν θύραν πίστεως.","lemmas":["παραγίνομαι","δέ","καί","συνάγω","ὁ","ἐκκλησία","ἀναγγέλλω","ὅσος","ποιέω","θεός","μετά","αὐτός","ὅτι","ἀνοίγω","ἔθνος","θύρα","πίστις"],"tr":"But having come and having gathered the church, [they] were declaring however much God did with them, and that [he] opened to the Gentiles [a] door of faith.","para":1,"para_continued":false,"words":[{"form":"παραγενόμενοι","lemma":"παραγίνομαι","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"συναγαγόντες","lemma":"συν