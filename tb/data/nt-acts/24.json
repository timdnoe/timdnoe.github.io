":"ὁ","type":"article","code":"RA"},{"form":"Παῦλος","lemma":"Παῦλος","type":"noun","code":"N"},{"form":"νεύσαντος","lemma":"νεύω","type":"verb","code":"V"},{"form":"αὐτῷ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἡγεμόνος","lemma":"ἡγεμών","type":"noun","code":"N"},{"form":"λέγειν·","lemma":"λέγω","type":"verb","code":"V"},{"form":"Ἐκ","lemma":"ἐκ","type":"preposition","code":"P"},{"form":"πολλῶν","lemma":"πολύς","type":"adjective","code":"A"},{"form":"ἐτῶν","lemma":"ἔτος","type":"noun","code":"N"},{"form":"ὄντα","lemma":"εἰμί","type":"verb","code":"V"},{"form":"σε","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"κριτὴν","lemma":"κριτής","type":"noun","code":"N"},{"form":"τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἔθνει","lemma":"ἔθνος","type":"noun","code":"N"},{"form":"τούτῳ","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"ἐπιστάμενος","lemma":"ἐπίσταμαι","type":"verb","code":"V"},{"form":"⸀εὐθύμως","lemma":"εὐθύμως","type":"adverb","code":"D"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"περὶ","lemma":"περί","type":"preposition","code":"P"},{"form":"ἐμαυτοῦ","lemma":"ἐμαυτοῦ","type":"personal_pronoun","code":"RP"},{"form":"ἀπολογοῦμαι,","lemma":"ἀπολογέομαι","type":"verb","code":"V"}]},{"v":11,"ref":"Acts 24:11","grc":"δυναμένου σου ⸀ἐπιγνῶναι, ὅτι οὐ πλείους εἰσίν μοι ἡμέραι ⸀δώδεκα ἀφ’ ἧς ἀνέβην προσκυνήσων ⸀εἰς Ἰερουσαλήμ,","lemmas":["δύναμαι","σύ","ἐπιγινώσκω","ὅτι","οὐ","πολύς","εἰμί","ἐγώ","ἡμέρα","δώδεκα","ἀπό","ὅς","ἀναβαίνω","προσκυνέω","εἰς","Ἰερουσαλήμ"],"tr":"[with] your being able to know that [there] are not more [than] twelve days for me from [the time] which [I] went up to worship into Jerusalem,","para":1,"para_continued":false,"words":[{"form":"δυναμένου","lemma":"δύναμαι","type":"verb","code":"V"},{"form":"σου","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"⸀ἐπιγνῶναι,","lemma":"ἐπιγινώσκω