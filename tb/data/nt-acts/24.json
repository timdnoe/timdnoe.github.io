im.","para":1,"para_continued":false,"words":[{"form":"ἅμα","lemma":"ἅμα","type":"adverb","code":"D"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"ἐλπίζων","lemma":"ἐλπίζω","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"χρήματα","lemma":"χρῆμα","type":"noun","code":"N"},{"form":"δοθήσεται","lemma":"δίδωμι","type":"verb","code":"V"},{"form":"αὐτῷ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ὑπὸ","lemma":"ὑπό","type":"preposition","code":"P"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"⸀Παύλου·","lemma":"Παῦλος","type":"noun","code":"N"},{"form":"διὸ","lemma":"διό","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"πυκνότερον","lemma":"πυκνός","type":"adjective","code":"A"},{"form":"αὐτὸν","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"μεταπεμπόμενος","lemma":"μεταπέμπομαι","type":"verb","code":"V"},{"form":"ὡμίλει","lemma":"ὁμιλέω","type":"verb","code":"V"},{"form":"αὐτῷ.","lemma":"αὐτός","type":"personal_pronoun","code":"RP"}]},{"v":27,"ref":"Acts 24:27","grc":"Διετίας δὲ πληρωθείσης ἔλαβεν διάδοχον ὁ Φῆλιξ Πόρκιον Φῆστον· θέλων τε ⸀χάριτα καταθέσθαι τοῖς Ἰουδαίοις ὁ Φῆλιξ κατέλιπε τὸν Παῦλον δεδεμένον.","lemmas":["διετία","δέ","πληρόω","λαμβάνω","διάδοχος","ὁ","Φῆλιξ","Πόρκιος","Φῆστος","θέλω","τέ","χάρις","κατατίθημι","Ἰουδαῖος","καταλείπω","Παῦλος","δέω"],"tr":"But [a] period of two years having been fulfilled, Felix received as successor Porcius Festus. Wanting also to have granted favor to the Jews, Felix left Paul having had been bound.","para":1,"para_continued":false,"words":[{"form":"Διετίας","lemma":"διετία","type":"noun","code":"N"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"πληρωθείσης","lemma":"πληρόω","type":"verb","code":"V"},{"form":"ἔλαβεν","lemma":"λαμβάνω","type":"verb","code":"V"},{"form":"διάδοχον","lemma":"διάδοχος","type":"noun","code":"N"},{"form"