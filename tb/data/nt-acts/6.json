":"N"},{"form":"ψευδεῖς","lemma":"ψευδής","type":"adjective","code":"A"},{"form":"λέγοντας·","lemma":"λέγω","type":"verb","code":"V"},{"form":"Ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἄνθρωπος","lemma":"ἄνθρωπος","type":"noun","code":"N"},{"form":"οὗτος","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"παύεται","lemma":"παύω","type":"verb","code":"V"},{"form":"⸂λαλῶν","lemma":"λαλέω","type":"verb","code":"V"},{"form":"ῥήματα⸃","lemma":"ῥῆμα","type":"noun","code":"N"},{"form":"κατὰ","lemma":"κατά","type":"preposition","code":"P"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"τόπου","lemma":"τόπος","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"⸀ἁγίου","lemma":"ἅγιος","type":"adjective","code":"A"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"νόμου,","lemma":"νόμος","type":"noun","code":"N"}]},{"v":14,"ref":"Acts 6:14","grc":"ἀκηκόαμεν γὰρ αὐτοῦ λέγοντος ὅτι Ἰησοῦς ὁ Ναζωραῖος οὗτος καταλύσει τὸν τόπον τοῦτον καὶ ἀλλάξει τὰ ἔθη ἃ παρέδωκεν ἡμῖν Μωϋσῆς.","lemmas":["ἀκούω","γάρ","αὐτός","λέγω","ὅτι","Ἰησοῦς","ὁ","Ναζωραῖος","οὗτος","καταλύω","τόπος","καί","ἀλλάσσω","ἔθος","ὅς","παραδίδωμι","ἐγώ","Μωϋσῆς"],"tr":"For [we] have heard him saying that Jesus the Nazarene, this [one] will terminate this place and will change the customs which Moses handed down to us.”","para":1,"para_continued":false,"words":[{"form":"ἀκηκόαμεν","lemma":"ἀκούω","type":"verb","code":"V"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"λέγοντος","lemma":"λέγω","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"Ἰησοῦς","lemma":"Ἰησοῦς","type":"noun","code":"N"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Ναζωραῖος",