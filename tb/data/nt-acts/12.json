form":"Ῥόδη,","lemma":"Ῥόδη","type":"noun","code":"N"}]},{"v":14,"ref":"Acts 12:14","grc":"καὶ ἐπιγνοῦσα τὴν φωνὴν τοῦ Πέτρου ἀπὸ τῆς χαρᾶς οὐκ ἤνοιξεν τὸν πυλῶνα, εἰσδραμοῦσα δὲ ἀπήγγειλεν ἑστάναι τὸν Πέτρον πρὸ τοῦ πυλῶνος.","lemmas":["καί","ἐπιγινώσκω","ὁ","φωνή","Πέτρος","ἀπό","χαρά","οὐ","ἀνοίγω","πυλών","εἰστρέχω","δέ","ἀπαγγέλλω","ἵστημι","πρό"],"tr":"And having recognized the voice of Peter, from the joy [she] did not open the gate. But having run into [the house, she] reported Peter to have had been standing before the gate.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐπιγνοῦσα","lemma":"ἐπιγινώσκω","type":"verb","code":"V"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"φωνὴν","lemma":"φωνή","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Πέτρου","lemma":"Πέτρος","type":"noun","code":"N"},{"form":"ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"χαρᾶς","lemma":"χαρά","type":"noun","code":"N"},{"form":"οὐκ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"ἤνοιξεν","lemma":"ἀνοίγω","type":"verb","code":"V"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"πυλῶνα,","lemma":"πυλών","type":"noun","code":"N"},{"form":"εἰσδραμοῦσα","lemma":"εἰστρέχω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἀπήγγειλεν","lemma":"ἀπαγγέλλω","type":"verb","code":"V"},{"form":"ἑστάναι","lemma":"ἵστημι","type":"verb","code":"V"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"Πέτρον","lemma":"Πέτρος","type":"noun","code":"N"},{"form":"πρὸ","lemma":"πρό","type":"preposition","code":"P"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πυλῶνος.","lemma":"πυλών","type":"noun","code":"N"}]},{"v":15,"ref":"Acts 12:15","grc":"οἱ δὲ πρὸς αὐτὴν εἶπαν· Μαίνῃ. ἡ δὲ διϊσχυρίζετο οὕτως ἔχειν. οἱ δὲ ἔλεγον· Ὁ ἄγγελός ⸂ἐστιν αὐτοῦ⸃.","lemmas":["ὁ","δέ","πρός","αὐτός","λέγω","μαίνομαι","διϊσχυρίζομαι","οὕτως","ἔχω","ἄγγελος","εἰμί"],"tr":"But [they] said toward her, “[You] are insane.” But [she] was insisting to have [it] thus. But [they] were saying, “[It] is his angel.”","para":1,"para_continued":false,"words":[{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"αὐτὴν","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"εἶπαν·","lemma":"λέγω","type":"verb","code":"V"},{"form":"Μαίνῃ.","lemma":"μαίνομαι","type":"verb","code":"V"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"διϊσχυρίζετο","lemma":"διϊσχυρίζομαι","type":"verb","code":"V"},{"form":"οὕτως","lemma":"οὕτως","type":"adverb","code":"D"},{"form":"ἔχειν.","lemma":"ἔχω","type":"verb","code":"V"},{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἔλεγον·","lemma":"λέγω","type":"verb","code":"V"},{"form":"Ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἄγγελός","lemma":"ἄγγελος","type":"noun","code":"N"},{"form":"⸂ἐστιν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"αὐτοῦ⸃.","lemma":"αὐτός","type":"personal_pronoun","code":"RP"}]},{"v":16,"ref":"Acts 12:16","grc":"ὁ δὲ Πέτρος ἐπέμενεν κρούων· ἀνοίξαντες δὲ εἶδαν αὐτὸν καὶ ἐξέστησαν.","lemmas":["ὁ","δέ","Πέτρος","ἐπιμένω","κρούω","ἀνοίγω","ὁράω","αὐτός","καί","ἐξίστημι"],"tr":"But Peter was remaining knocking. But having opened, [they] saw him and marveled.","para":1,"para_continued":false,"words":[{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"Πέτρος","lemma":"Πέτρος","type":"noun","code":"N"},{"form":"ἐπέμενεν","lemma":"ἐπιμένω","type":"verb","code":"V"},{"form":"κρούων·","lemma":"κρούω"