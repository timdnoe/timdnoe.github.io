"χείρ"],"tr":"And behold; [an] angel of [the] Lord stood by, and [a] light shone in the house. But having striked the side of Peter, [he] raised him, saying, “Having risen, [be] in haste.” And the chains fell out of his hands","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἰδοὺ","lemma":"ἰδού","type":"particle","code":"X"},{"form":"ἄγγελος","lemma":"ἄγγελος","type":"noun","code":"N"},{"form":"κυρίου","lemma":"κύριος","type":"noun","code":"N"},{"form":"ἐπέστη,","lemma":"ἐφίστημι","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"φῶς","lemma":"φῶς","type":"noun","code":"N"},{"form":"ἔλαμψεν","lemma":"λάμπω","type":"verb","code":"V"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"οἰκήματι·","lemma":"οἴκημα","type":"noun","code":"N"},{"form":"πατάξας","lemma":"πατάσσω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"πλευρὰν","lemma":"πλευρά","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Πέτρου","lemma":"Πέτρος","type":"noun","code":"N"},{"form":"ἤγειρεν","lemma":"ἐγείρω","type":"verb","code":"V"},{"form":"αὐτὸν","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"λέγων·","lemma":"λέγω","type":"verb","code":"V"},{"form":"Ἀνάστα","lemma":"ἀνίστημι","type":"verb","code":"V"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"τάχει·","lemma":"τάχος","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐξέπεσαν","lemma":"ἐκπίπτω","type":"verb","code":"V"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"αἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἁλύσεις","lemma":"ἅλυσις","type":"noun","code":"N"},{"form":"ἐκ","lemma":"ἐκ","type":"preposition","code":"P"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"χειρῶν.","lemma":"χείρ","type":"noun","code":"N"}]},{"v":8,"ref":"Acts 12:8","grc":"εἶπεν ⸀δὲ ὁ ἄγγελος πρὸς αὐτόν· ⸀Ζῶσαι καὶ ὑπόδησαι τὰ σανδάλιά σου· ἐποίησεν δὲ οὕτως. καὶ λέγει αὐτῷ· Περιβαλοῦ τὸ ἱμάτιόν σου καὶ ἀκολούθει μοι.","lemmas":["λέγω","δέ","ὁ","ἄγγελος","πρός","αὐτός","ζώννυμι","καί","ὑποδέομαι","σανδάλιον","σύ","ποιέω","οὕτως","περιβάλλω","ἱμάτιον","ἀκολουθέω","ἐγώ"],"tr":"But the angel said toward him, “Live and put on your sandals.” But [he] did thus, and [he] says to him, “Put on your garment and follow me.”","para":1,"para_continued":false,"words":[{"form":"εἶπεν","lemma":"λέγω","type":"verb","code":"V"},{"form":"⸀δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἄγγελος","lemma":"ἄγγελος","type":"noun","code":"N"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"αὐτόν·","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"⸀Ζῶσαι","lemma":"ζώννυμι","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ὑπόδησαι","lemma":"ὑποδέομαι","type":"verb","code":"V"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"σανδάλιά","lemma":"σανδάλιον","type":"noun","code":"N"},{"form":"σου·","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"ἐποίησεν","lemma":"ποιέω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"οὕτως.","lemma":"οὕτως","type":"adverb","code":"D"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"λέγει","lemma":"λέγω","type":"verb","code":"V"},{"form":"αὐτῷ·","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"Περιβαλοῦ","lemma":"περιβάλλω","type":"verb","code":"V"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἱμάτιόν","lemma":"ἱμάτιον","type":"noun","code":"N"},{"form":"σου","lemma":"σύ","type":"personal_p