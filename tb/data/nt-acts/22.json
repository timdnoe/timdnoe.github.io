sition","code":"P"},{"form":"θανάτου,","lemma":"θάνατος","type":"noun","code":"N"},{"form":"δεσμεύων","lemma":"δεσμεύω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"παραδιδοὺς","lemma":"παραδίδωμι","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"φυλακὰς","lemma":"φυλακή","type":"noun","code":"N"},{"form":"ἄνδρας","lemma":"ἀνήρ","type":"noun","code":"N"},{"form":"τε","lemma":"τέ","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"γυναῖκας,","lemma":"γυνή","type":"noun","code":"N"}]},{"v":5,"ref":"Acts 22:5","grc":"ὡς καὶ ὁ ἀρχιερεὺς μαρτυρεῖ μοι καὶ πᾶν τὸ πρεσβυτέριον· παρ’ ὧν καὶ ἐπιστολὰς δεξάμενος πρὸς τοὺς ἀδελφοὺς εἰς Δαμασκὸν ἐπορευόμην ἄξων καὶ τοὺς ἐκεῖσε ὄντας δεδεμένους εἰς Ἰερουσαλὴμ ἵνα τιμωρηθῶσιν.","lemmas":["ὡς","καί","ὁ","ἀρχιερεύς","μαρτυρέω","ἐγώ","πᾶς","πρεσβυτέριον","παρά","ὅς","ἐπιστολή","δέχομαι","πρός","ἀδελφός","εἰς","Δαμασκός","πορεύομαι","ἄγω","ἐκεῖσε","εἰμί","δέω","Ἰερουσαλήμ","ἵνα","τιμωρέω"],"tr":"as even the high priest testifies to me and all the council, from whom also having received letters toward the brothers, [I] was going into Damascus, going to lead both the [ones] being there having been bound into Jerusalem so that [they] might be punished","para":1,"para_continued":false,"words":[{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀρχιερεὺς","lemma":"ἀρχιερεύς","type":"noun","code":"N"},{"form":"μαρτυρεῖ","lemma":"μαρτυρέω","type":"verb","code":"V"},{"form":"μοι","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"πᾶν","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πρεσβυτέριον·","lemma":"πρεσβυτέριον","type":"noun","code":