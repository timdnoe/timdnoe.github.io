μένῳ","lemma":"πορεύομαι","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐγγίζοντι","lemma":"ἐγγίζω","type":"verb","code":"V"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Δαμασκῷ","lemma":"Δαμασκός","type":"noun","code":"N"},{"form":"περὶ","lemma":"περί","type":"preposition","code":"P"},{"form":"μεσημβρίαν","lemma":"μεσημβρία","type":"noun","code":"N"},{"form":"ἐξαίφνης","lemma":"ἐξαίφνης","type":"adverb","code":"D"},{"form":"ἐκ","lemma":"ἐκ","type":"preposition","code":"P"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"οὐρανοῦ","lemma":"οὐρανός","type":"noun","code":"N"},{"form":"περιαστράψαι","lemma":"περιαστράπτω","type":"verb","code":"V"},{"form":"φῶς","lemma":"φῶς","type":"noun","code":"N"},{"form":"ἱκανὸν","lemma":"ἱκανός","type":"adjective","code":"A"},{"form":"περὶ","lemma":"περί","type":"preposition","code":"P"},{"form":"ἐμέ,","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"}]},{"v":7,"ref":"Acts 22:7","grc":"ἔπεσά τε εἰς τὸ ἔδαφος καὶ ἤκουσα φωνῆς λεγούσης μοι· Σαοὺλ Σαούλ, τί με διώκεις;","lemmas":["πίπτω","τέ","εἰς","ὁ","ἔδαφος","καί","ἀκούω","φωνή","λέγω","ἐγώ","Σαούλ","τίς","διώκω"],"tr":"And [I] fell into the ground and [I] heard [a] voice saying to me, ‘Saul, Saul, why do [you] persecute me?’","para":1,"para_continued":false,"words":[{"form":"ἔπεσά","lemma":"πίπτω","type":"verb","code":"V"},{"form":"τε","lemma":"τέ","type":"conjunction","code":"C"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἔδαφος","lemma":"ἔδαφος","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἤκουσα","lemma":"ἀκούω","type":"verb","code":"V"},{"form":"φωνῆς","lemma":"φωνή","type":"noun","code":"N"},{"form":"λεγούσης","lemma":"λέγω","type":"verb","code":"V"},{"form":"μοι·","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"Σαοὺλ","lemma":"Σαούλ","type":"noun","code":"N"},{"form":"Σαούλ,","lemma":"Σαούλ","type":"noun","code":"N"},{"form":"τί","lemma":"τίς","type":"interrogative_pronoun","code":"RI"},{"form":"με","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"διώκεις;","lemma":"διώκω","type":"verb","code":"V"}]},{"v":8,"ref":"Acts 22:8","grc":"ἐγὼ δὲ ἀπεκρίθην· Τίς εἶ, κύριε; εἶπέν τε πρὸς ⸀ἐμέ· Ἐγώ εἰμι Ἰησοῦς ὁ Ναζωραῖος ὃν σὺ διώκεις.","lemmas":["ἐγώ","δέ","ἀποκρίνομαι","τίς","εἰμί","κύριος","λέγω","τέ","πρός","Ἰησοῦς","ὁ","Ναζωραῖος","ὅς","σύ","διώκω"],"tr":"But I answered, ‘Who are [you], Lord?’ And [he] said toward me, ‘I am Jesus the Nazarene whom you persecute.’","para":1,"para_continued":false,"words":[{"form":"ἐγὼ","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἀπεκρίθην·","lemma":"ἀποκρίνομαι","type":"verb","code":"V"},{"form":"Τίς","lemma":"τίς","type":"interrogative_pronoun","code":"RI"},{"form":"εἶ,","lemma":"εἰμί","type":"verb","code":"V"},{"form":"κύριε;","lemma":"κύριος","type":"noun","code":"N"},{"form":"εἶπέν","lemma":"λέγω","type":"verb","code":"V"},{"form":"τε","lemma":"τέ","type":"conjunction","code":"C"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"⸀ἐμέ·","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"Ἐγώ","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"εἰμι","lemma":"εἰμί","type":"verb","code":"V"},{"form":"Ἰησοῦς","lemma":"Ἰησοῦς","type":"noun","code":"N"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Ναζωραῖος","lemma":"Ναζωραῖος","type":"noun","code":"N"},{"form":"ὃν","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"σὺ","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"διώκεις.","lemma":"διώκω","type":"verb","code":"V"}]},{"v":9,"ref":"Acts 22:9","grc":"οἱ δὲ σὺν ἐμοὶ ὄντες τὸ μὲν φῶς ⸀ἐθεάσαντο τὴν δὲ φωνὴν οὐκ ἤκουσαν τοῦ λαλοῦντός μοι.","lemmas":["ὁ","δέ","σύν","ἐγώ","εἰμί","μέν","φῶς","θεάομαι","φωνή","οὐ","ἀκούω","λαλέω"],"tr":"But the [ones] being with me saw the light indeed but did not hear the voice of the [one] speaking to me.","para":1,"para_continued":false,"words":[{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"σὺν","lemma":"σύν","type":"preposition","code":"P"},{"form":"ἐμοὶ","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"ὄντες","lemma":"εἰμί","type":"verb","code":"V"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"μὲν","lemma":"μέν","type":"conjunction","code":"C"},{"form":"φῶς","lemma":"φῶς","type":"noun","code":"N"},{"form":"⸀ἐθεάσαντο","lemma":"θεάομαι","type":"verb","code":"V"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"φωνὴν","lemma":"φωνή","type":"noun","code":"N"},{"form":"οὐκ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"ἤκουσαν","lemma":"ἀκούω","type":"verb","code":"V"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"λαλοῦντός","lemma":"λαλέω","type":"verb","code":"V"},{"form":"μοι.","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"}]},{"v":10,"ref":"Acts 22:10","grc":"εἶπον δέ· Τί ποιήσω, κύριε; ὁ δὲ κύριος εἶπεν πρός με· Ἀναστὰς πορεύου εἰς Δαμασκόν, κἀκεῖ σοι λαληθήσεται περὶ πάντων ὧν τέτακταί σοι ποιῆσαι.","lemmas":["λέγω","δέ","τίς","ποιέω","κύριος","ὁ","πρός","ἐγώ","ἀνίστημι","πορεύομαι","εἰς","Δαμασκός","κἀκεῖ","σύ","λαλέω","περί","πᾶς","ὅς","τάσσω"],"tr":"But [I] said, ‘What shall I do, Lord?’ But the Lord said toward me, ‘Having risen, go into Damascus. And there will be spoken to you about all [things] of which [it] has been appointed for you to have done.’","para":1,"para_continued":false,"words":[{"form":"εἶπον","lemma":"λέγω","type":"verb","code":"V"},{"form":"δέ·","lemma":"δέ","type":"conjunction","code":"C"},{"form":"Τί","lemma":"τίς","type":"interrogative_pronoun","code":"RI"},{"form":"ποιήσω,","lemma":"ποιέω","type":"ver