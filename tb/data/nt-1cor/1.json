junction","code":"C"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"Κρίσπον","lemma":"Κρίσπος","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"Γάϊον,","lemma":"Γάϊος","type":"noun","code":"N"}]},{"v":15,"ref":"1Cor 1:15","grc":"ἵνα μή τις εἴπῃ ὅτι εἰς τὸ ἐμὸν ὄνομα ⸀ἐβαπτίσθητε·","lemmas":["ἵνα","μή","τις","λέγω","ὅτι","εἰς","ὁ","ἐμός","ὄνομα","βαπτίζω"],"tr":"so that anyone might not say that [you all] were baptized into my name.","para":null,"para_continued":false,"words":[{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"μή","lemma":"μή","type":"adverb","code":"D"},{"form":"τις","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"εἴπῃ","lemma":"λέγω","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἐμὸν","lemma":"ἐμός","type":"adjective","code":"A"},{"form":"ὄνομα","lemma":"ὄνομα","type":"noun","code":"N"},{"form":"⸀ἐβαπτίσθητε·","lemma":"βαπτίζω","type":"verb","code":"V"}]},{"v":16,"ref":"1Cor 1:16","grc":"ἐβάπτισα δὲ καὶ τὸν Στεφανᾶ οἶκον· λοιπὸν οὐκ οἶδα εἴ τινα ἄλλον ἐβάπτισα.","lemmas":["βαπτίζω","δέ","καί","ὁ","Στεφανᾶς","οἶκος","λοιπός","οὐ","οἶδα","εἰ","τις","ἄλλος"],"tr":"But [I] baptized even the household of Stephanas; henceforth [I] do not know if [I] baptized any other,","para":null,"para_continued":false,"words":[{"form":"ἐβάπτισα","lemma":"βαπτίζω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"Στεφανᾶ","lemma":"Στεφανᾶς","type":"noun","code":"N"},{"form":"οἶκον·","lemma":"οἶκος","type":"noun","code":"N"},{"form":"λοιπὸν","lemma":"λοιπός","type":"adjective","code":"A"},{"form":"οὐκ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"οἶ