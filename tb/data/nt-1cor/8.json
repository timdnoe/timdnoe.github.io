","type":"conjunction","code":"C"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"εἰδωλοθύτων","lemma":"εἰδωλόθυτον","type":"adjective","code":"A"},{"form":"οἴδαμεν","lemma":"οἶδα","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"οὐδὲν","lemma":"οὐδείς","type":"adjective","code":"A"},{"form":"εἴδωλον","lemma":"εἴδωλον","type":"noun","code":"N"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"κόσμῳ,","lemma":"κόσμος","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"οὐδεὶς","lemma":"οὐδείς","type":"adjective","code":"A"},{"form":"⸀θεὸς","lemma":"θεός","type":"noun","code":"N"},{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"εἷς.","lemma":"εἷς","type":"adjective","code":"A"}]},{"v":5,"ref":"1Cor 8:5","grc":"καὶ γὰρ εἴπερ εἰσὶν λεγόμενοι θεοὶ εἴτε ἐν οὐρανῷ εἴτε ἐπὶ γῆς, ὥσπερ εἰσὶν θεοὶ πολλοὶ καὶ κύριοι πολλοί,","lemmas":["καί","γάρ","εἴπερ","εἰμί","λέγω","θεός","εἴτε","ἐν","οὐρανός","ἐπί","γῆ","ὥσπερ","πολύς","κύριος"],"tr":"For also, since [there] are [ones] being called gods, whether in heaven or upon earth, just as [there] are many gods and many lords.","para":null,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"εἴπερ","lemma":"εἴπερ","type":"conjunction","code":"C"},{"form":"εἰσὶν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"λεγόμενοι","lemma":"λέγω","type":"verb","code":"V"},{"form":"θεοὶ","lemma":"θεός","type":"noun","code":"N"},{"form":"εἴτε","lemma":"εἴτε","type":"conjunction","code":"C"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"οὐρανῷ","lemma":"οὐρανός","type":"noun","code":"N"},{"form":"εἴτε","lemma":"εἴτε","type":"conjunction","code":"C"},{"form":"ἐπὶ","