":"D"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"εἰδώλου⸃","lemma":"εἴδωλον","type":"noun","code":"N"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"εἰδωλόθυτον","lemma":"εἰδωλόθυτον","type":"adjective","code":"A"},{"form":"ἐσθίουσιν,","lemma":"ἐσθίω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"συνείδησις","lemma":"συνείδησις","type":"noun","code":"N"},{"form":"αὐτῶν","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἀσθενὴς","lemma":"ἀσθενής","type":"adjective","code":"A"},{"form":"οὖσα","lemma":"εἰμί","type":"verb","code":"V"},{"form":"μολύνεται.","lemma":"μολύνω","type":"verb","code":"V"}]},{"v":8,"ref":"1Cor 8:8","grc":"βρῶμα δὲ ἡμᾶς οὐ ⸀παραστήσει τῷ θεῷ· οὔτε ⸂γὰρ ἐὰν φάγωμεν, περισσεύομεν, οὔτε ἐὰν μὴ φάγωμεν, ὑστερούμεθα⸃.","lemmas":["βρῶμα","δέ","ἐγώ","οὐ","παρίστημι","ὁ","θεός","οὔτε","γάρ","ἐάν","ἐσθίω","περισσεύω","μή","ὑστερέω"],"tr":"But food [will] not present us to God; for neither if [we] might eat, do [we] abound, nor if [we] might not eat, do [we] lack.","para":null,"para_continued":false,"words":[{"form":"βρῶμα","lemma":"βρῶμα","type":"noun","code":"N"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἡμᾶς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"⸀παραστήσει","lemma":"παρίστημι","type":"verb","code":"V"},{"form":"τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεῷ·","lemma":"θεός","type":"noun","code":"N"},{"form":"οὔτε","lemma":"οὔτε","type":"conjunction","code":"C"},{"form":"⸂γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"ἐὰν","lemma":"ἐάν","type":"conjunction","code":"C"},{"form":"φάγωμεν,","lemma":"ἐσθίω","type":"verb","code":"V"},{"form":"περισσεύομεν,","lemma":"περισσεύω","type":"verb","code":"V"},{"form":"οὔτε","lemma":"οὔτε","type":"conjunction","code":"C"},{"for