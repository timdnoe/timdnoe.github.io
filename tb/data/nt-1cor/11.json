,"type":"noun","code":"N"},{"form":"κατέχετε.","lemma":"κατέχω","type":"verb","code":"V"}]},{"v":3,"ref":"1Cor 11:3","grc":"θέλω δὲ ὑμᾶς εἰδέναι ὅτι παντὸς ἀνδρὸς ἡ κεφαλὴ ὁ Χριστός ἐστιν, κεφαλὴ δὲ γυναικὸς ὁ ἀνήρ, κεφαλὴ δὲ ⸀τοῦ Χριστοῦ ὁ θεός.","lemmas":["θέλω","δέ","σύ","οἶδα","ὅτι","πᾶς","ἀνήρ","ὁ","κεφαλή","Χριστός","εἰμί","γυνή","θεός"],"tr":"But [I] want you [all] to know that the head of every man is Christ, but [the] head of [a] woman [is] the man, but [the] head of Christ [is] God.","para":null,"para_continued":false,"words":[{"form":"θέλω","lemma":"θέλω","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ὑμᾶς","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"εἰδέναι","lemma":"οἶδα","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"παντὸς","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"ἀνδρὸς","lemma":"ἀνήρ","type":"noun","code":"N"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"κεφαλὴ","lemma":"κεφαλή","type":"noun","code":"N"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Χριστός","lemma":"Χριστός","type":"noun","code":"N"},{"form":"ἐστιν,","lemma":"εἰμί","type":"verb","code":"V"},{"form":"κεφαλὴ","lemma":"κεφαλή","type":"noun","code":"N"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"γυναικὸς","lemma":"γυνή","type":"noun","code":"N"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀνήρ,","lemma":"ἀνήρ","type":"noun","code":"N"},{"form":"κεφαλὴ","lemma":"κεφαλή","type":"noun","code":"N"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"⸀τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"Χριστοῦ","lemma":"Χριστός","type":"noun","code":"N"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεός.","lemma":"θεός","type":"noun","code":"N"}]},{"v":4,"ref":"1Cor 11:4","grc":"πᾶς ἀνὴρ προσευχόμενος ἢ προφητεύων κατὰ κεφαλῆς ἔχων καταισχύνει τὴν κεφα