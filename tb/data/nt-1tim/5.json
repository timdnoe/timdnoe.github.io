{"book":"nt-1tim","book_name":"First Epistle to Timothy","chapter":5,"chapter_label":"5","prev":4,"next":6,"verses":[{"v":1,"ref":"1Tim 5:1","grc":"Πρεσβυτέρῳ μὴ ἐπιπλήξῃς, ἀλλὰ παρακάλει ὡς πατέρα, νεωτέρους ὡς ἀδελφούς,","lemmas":["πρεσβύτερος","μή","ἐπιπλήσσω","ἀλλά","παρακαλέω","ὡς","πατήρ","νέος","ἀδελφός"],"tr":"Might [you] not rebuke [an] elder, rather encourage as [a] father, younger [men] as brothers,","para":null,"para_continued":false,"words":[{"form":"Πρεσβυτέρῳ","lemma":"πρεσβύτερος","type":"adjective","code":"A"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"ἐπιπλήξῃς,","lemma":"ἐπιπλήσσω","type":"verb","code":"V"},{"form":"ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"παρακάλει","lemma":"παρακαλέω","type":"verb","code":"V"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"πατέρα,","lemma":"πατήρ","type":"noun","code":"N"},{"form":"νεωτέρους","lemma":"νέος","type":"adjective","code":"A"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"ἀδελφούς,","lemma":"ἀδελφός","type":"noun","code":"N"}]},{"v":2,"ref":"1Tim 5:2","grc":"πρεσβυτέρας ὡς μητέρας, νεωτέρας ὡς ἀδελφὰς ἐν πάσῃ ἁγνείᾳ.","lemmas":["πρεσβύτερος","ὡς","μήτηρ","νέος","ἀδελφή","ἐν","πᾶς","ἁγνεία"],"tr":"elder women as mothers, younger [women] as sisters in all purity.","para":null,"para_continued":false,"words":[{"form":"πρεσβυτέρας","lemma":"πρεσβύτερος","type":"adjective","code":"A"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"μητέρας,","lemma":"μήτηρ","type":"noun","code":"N"},{"form":"νεωτέρας","lemma":"νέος","type":"adjective","code":"A"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"ἀδελφὰς","lemma":"ἀδελφή","type":"noun","code":"N"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"πάσῃ","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"ἁγνείᾳ.","lemma":"ἁγνεία","type":"noun","code":"N"}]},{"v":3,"ref":"1Tim 5:3","grc":"Χήρας τίμα τὰς ὄντως χήρας.","lemmas":["χήρα","τιμάω","ὁ","ὄντως"],"tr":"Honor widows, the [ones] truly widows.","para":null,"para_continued":false,"words":[{"form":"Χήρας","lemma":"χήρα","type":"adjective","code":"A"},{"form":"τίμα","lemma":"τιμάω","type":"verb","code":"V"},{"form":"τὰς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ὄντως","lemma":"ὄντως","type":"adverb","code":"D"},{"form":"χήρας.","lemma":"χήρα","type":"adjective","code":"A"}]},{"v":4,"ref":"1Tim 5:4","grc":"εἰ δέ τις χήρα τέκνα ἢ ἔκγονα ἔχει, μανθανέτωσαν πρῶτον τὸν ἴδιον οἶκον εὐσεβεῖν καὶ ἀμοιβὰς ἀποδιδόναι τοῖς προγόνοις, τοῦτο γάρ ἐστιν ἀπόδεκτον ἐνώπιον τοῦ θεοῦ.","lemmas":["εἰ","δέ","τις","χήρα","τέκνον","ἤ","ἔκγονον","ἔχω","μανθάνω","πρῶτον","ὁ","ἴδιος","οἶκος","εὐσεβέω","καί","ἀμοιβή","ἀποδίδωμι","πρόγονος","οὗτος","γάρ","εἰμί","ἀπόδεκτος","ἐνώπιον","θεός"],"tr":"But if any widow has children or grandchildren, may [they] learn first to practice piety [toward] their own household and to give back rewards to the ancestors, for this is acceptable before God.","para":null,"para_continued":false,"words":[{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"δέ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"τις","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"χήρα","lemma":"χήρα","type":"adjective","code":"A"},{"form":"τέκνα","lemma":"τέκνον","type":"noun","code":"N"},{"form":"ἢ","lemma":"ἤ","type":"conjunction","code":"C"},{"form":"ἔκγονα","lemma":"ἔκγονον","type":"adjective","code":"A"},{"form":"ἔχει,","lemma":"ἔχω","type":"verb","code":"V"},{"form":"μανθανέτωσαν","lemma":"μανθάνω","type":"verb","code":"V"},{"form":"πρῶτον","lemma":"πρῶτον","type":"adverb","code":"D"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἴδιον","lemma":"ἴδιος","type":"adjective","code":"A"},{"form":"οἶκον","lemma":"οἶκος","type":"noun","code":"N"},{"form":"εὐσεβεῖν","lemma":"εὐσεβέω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἀμο