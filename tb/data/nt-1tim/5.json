:"conjunction","code":"C"},{"form":"τις","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἰδίων","lemma":"ἴδιος","type":"adjective","code":"A"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"⸀μάλιστα","lemma":"μάλιστα","type":"adverb","code":"D"},{"form":"οἰκείων","lemma":"οἰκεῖος","type":"adjective","code":"A"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"⸀προνοεῖ,","lemma":"προνοέω","type":"verb","code":"V"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"πίστιν","lemma":"πίστις","type":"noun","code":"N"},{"form":"ἤρνηται","lemma":"ἀρνέομαι","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἔστιν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"ἀπίστου","lemma":"ἄπιστος","type":"adjective","code":"A"},{"form":"χείρων.","lemma":"χείρων","type":"adjective","code":"A"}]},{"v":9,"ref":"1Tim 5:9","grc":"Χήρα καταλεγέσθω μὴ ἔλαττον ἐτῶν ἑξήκοντα γεγονυῖα, ἑνὸς ἀνδρὸς γυνή,","lemmas":["χήρα","καταλέγω","μή","ἐλάσσων","ἔτος","ἑξήκοντα","γίνομαι","εἷς","ἀνήρ","γυνή"],"tr":"May [a] widow be enrolled not less [than] sixty years [old], having had become [the] wife of one man,","para":null,"para_continued":false,"words":[{"form":"Χήρα","lemma":"χήρα","type":"adjective","code":"A"},{"form":"καταλεγέσθω","lemma":"καταλέγω","type":"verb","code":"V"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"ἔλαττον","lemma":"ἐλάσσων","type":"adjective","code":"A"},{"form":"ἐτῶν","lemma":"ἔτος","type":"noun","code":"N"},{"form":"ἑξήκοντα","lemma":"ἑξήκοντα","type":"adjective","code":"A"},{"form":"γεγονυῖα,","lemma":"γίνομαι","type":"verb","code":"V"},{"form":"ἑνὸς","lemma":"εἷς","type":"adjective","code":"A"},{"form":"ἀνδρὸς","lemma":"ἀνήρ","type":"noun","code":"N"},{"form":"γυνή,","lemma":"γυνή","type":"noun","code":"N"}]},{"v":10,"ref":"1Tim 5:10","grc":"ἐν ἔργοις καλοῖς μαρτυρουμένη, εἰ ἐτεκνοτρόφησεν, εἰ ἐξενοδόχησεν, εἰ ἁγίων πόδας ἔνιψεν, εἰ θλιβομένοις ἐπήρκεσεν, εἰ παντὶ ἔργῳ ἀγαθῷ ἐπηκολούθησεν.","lemmas":["ἐν","ἔργον","καλός","μαρτυρέω","εἰ","τεκνοτροφέω","ξενοδοχέω","ἅγιος","πούς","νίπτω","θλίβω","ἐπαρκέω","πᾶς","ἀγαθός","ἐπακολουθέω"],"tr":"being witnessed in good deeds, if [she] raised children, if [she] lodged [as a guest], if [she] washed feet of holy [ones], if [she] aided [the ones] being pressed, if [she] followed in every good work,","para":null,"para_continued":false,"words":[{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"ἔργοις","lemma":"ἔργον","type":"noun","code":"N"},{"form":"καλοῖς","lemma":"καλός","type":"adjective","code":"A"},{"form":"μαρτυρουμένη,","lemma":"μαρτυρέω","type":"verb","code":"V"},{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"ἐτεκνοτρόφησεν,","lemma":"τεκνοτροφέω","type":"verb","code":"V"},{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"ἐξενοδόχησεν,","lemma":"ξενοδοχέω","type":"verb","code":"V"},{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"ἁγίων","lemma":"ἅγιος","type":"adjective","code":"A"},{"form":"πόδας","lemma":"πούς","type":"noun","code":"N"},{"form":"ἔνιψεν,","lemma":"νίπτω","type":"verb","code":"V"},{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"θλιβομένοις","lemma":"θλίβω","type":"verb","code":"V"},{"form":"ἐπήρκεσεν,","lemma":"ἐπαρκέω","type":"verb","code":"V"},{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"παντὶ","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"ἔργῳ","lemma":"ἔργον","type":"noun","code":"N"},{"form":"ἀγαθῷ","lemma":"ἀγαθός","type":"adjective","code":"A"},{"form":"ἐπηκολούθησεν.","lemma":"ἐπακολουθέω","type":"verb","code":"V"}]},{"v":11,"ref":"1Tim 5:11","grc":"νεωτέρας δὲ χήρας παραιτοῦ· ὅταν γὰρ καταστρηνιάσωσιν τοῦ Χριστοῦ, γαμεῖν θέλουσιν,","lemmas":["νέος","δέ","χήρα","παραιτέομαι","ὅταν","γάρ","καταστρηνιάω","ὁ","Χριστός","γαμέω","θέλω"],"tr":"but excuse [f