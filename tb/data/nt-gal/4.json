":"N"},{"form":"ἀπολάβωμεν.","lemma":"ἀπολαμβάνω","type":"verb","code":"V"}]},{"v":6,"ref":"Gal 4:6","grc":"ὅτι δέ ἐστε υἱοί, ἐξαπέστειλεν ὁ θεὸς τὸ πνεῦμα τοῦ υἱοῦ αὐτοῦ εἰς τὰς καρδίας ⸀ἡμῶν, κρᾶζον· Αββα ὁ πατήρ.","lemmas":["ὅτι","δέ","εἰμί","υἱός","ἐξαποστέλλω","ὁ","θεός","πνεῦμα","αὐτός","εἰς","καρδία","ἐγώ","κράζω","αββα","πατήρ"],"tr":"But because [you all] are sons, God sent out the spirit of his son into our hearts, crying out “Abba, the father,”","para":null,"para_continued":false,"words":[{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"δέ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἐστε","lemma":"εἰμί","type":"verb","code":"V"},{"form":"υἱοί,","lemma":"υἱός","type":"noun","code":"N"},{"form":"ἐξαπέστειλεν","lemma":"ἐξαποστέλλω","type":"verb","code":"V"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεὸς","lemma":"θεός","type":"noun","code":"N"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πνεῦμα","lemma":"πνεῦμα","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"υἱοῦ","lemma":"υἱός","type":"noun","code":"N"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὰς","lemma":"ὁ","type":"article","code":"RA"},{"form":"καρδίας","lemma":"καρδία","type":"noun","code":"N"},{"form":"⸀ἡμῶν,","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"κρᾶζον·","lemma":"κράζω","type":"verb","code":"V"},{"form":"Αββα","lemma":"αββα","type":"noun","code":"N"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πατήρ.","lemma":"πατήρ","type":"noun","code":"N"}]},{"v":7,"ref":"Gal 4:7","grc":"ὥστε οὐκέτι εἶ δοῦλος ἀλλὰ υἱός· εἰ δὲ υἱός, καὶ κληρονόμος ⸂διὰ θεοῦ⸃.","lemmas":["ὥστε","οὐκέτι","εἰμί","δοῦλος","ἀλλά","υἱός","εἰ","δέ","καί","κληρονόμος","διά","θεός"],"tr":"so that [you] areno longer [a] servant, rather [a] son; but if [a] son, also [an] heir through God.","para":null,"para_continued":false,"words":[{"form":"ὥστε","lemma":"ὥστε","type":"conjunction","code":"C"},{"form":"οὐκέτι","lemma":"οὐκέτι","type":"adverb","code":"D"},{"form":"εἶ","lemma":"εἰμί","type":"verb","code":"V"},{"form":"δοῦλος","lemma":"δοῦλος","type":"noun","code":"N"},{"form":"ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"υἱός·","lemma":"υἱός","type":"noun","code":"N"},{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"υἱός,","lemma":"υἱός","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"κληρονόμος","lemma":"κληρονόμος","type":"noun","code":"N"},{"form":"⸂διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"θεοῦ⸃.","lemma":"θεός","type":"noun","code":"N"}]},{"v":8,"ref":"Gal 4:8","grc":"Ἀλλὰ τότε μὲν οὐκ εἰδότες θεὸν ἐδουλεύσατε τοῖς ⸂φύσει μὴ⸃ οὖσι θεοῖς·","lemmas":["ἀλλά","τότε","μέν","οὐ","οἶδα","θεός","δουλεύω","ὁ","φύσις","μή","εἰμί"],"tr":"Rather, on the one hand, then, not having known God, [you all] served the [ones] by nature not being gods.","para":null,"para_continued":false,"words":[{"form":"Ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"τότε","lemma":"τότε","type":"adverb","code":"D"},{"form":"μὲν","lemma":"μέν","type":"conjunction","code":"C"},{"form":"οὐκ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"εἰδότες","lemma":"οἶδα","type":"verb","code":"V"},{"form":"θεὸν","lemma":"θεός","type":"noun","code":"N"},{"form":"ἐδουλεύσατε","lemma":"δουλεύω","type":"verb","code":"V"},{"form":"τοῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"⸂φύσει","lemma":"φύσις","type":"noun","code":"N"},{"form":"μὴ⸃","lemma":"μή","type":"adverb","code":"D"},{"form":"οὖσι","lemma":"εἰμί","type":"verb","code":"V"},{"form":"θεοῖς·","lemma":"θεός","type":"noun","code":"N"}]},{"v":9,"ref":"Gal 4:9","grc":"νῦν δὲ γνόντες θεόν, μᾶλλον δὲ γνωσθέντες ὑπὸ θεοῦ, πῶς ἐπιστρέφετε πάλιν ἐπὶ τὰ ἀσθενῆ καὶ 