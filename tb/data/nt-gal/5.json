":"φρονέω","type":"verb","code":"V"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ταράσσων","lemma":"ταράσσω","type":"verb","code":"V"},{"form":"ὑμᾶς","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"βαστάσει","lemma":"βαστάζω","type":"verb","code":"V"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"κρίμα,","lemma":"κρῖμα","type":"noun","code":"N"},{"form":"ὅστις","lemma":"ὅστις","type":"relative_pronoun","code":"RR"},{"form":"⸀ἐὰν","lemma":"ἐάν","type":"particle","code":"X"},{"form":"ᾖ.","lemma":"εἰμί","type":"verb","code":"V"}]},{"v":11,"ref":"Gal 5:11","grc":"ἐγὼ δέ, ἀδελφοί, εἰ περιτομὴν ἔτι κηρύσσω, τί ἔτι διώκομαι; ἄρα κατήργηται τὸ σκάνδαλον τοῦ σταυροῦ.","lemmas":["ἐγώ","δέ","ἀδελφός","εἰ","περιτομή","ἔτι","κηρύσσω","τίς","διώκω","ἄρα","καταργέω","ὁ","σκάνδαλον","σταυρός"],"tr":"But I, brothers, if [I] still proclaim circumcision, why am I still being pursued? Then the stumbling block of the cross has been made useless.","para":null,"para_continued":false,"words":[{"form":"ἐγὼ","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"δέ,","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἀδελφοί,","lemma":"ἀδελφός","type":"noun","code":"N"},{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"περιτομὴν","lemma":"περιτομή","type":"noun","code":"N"},{"form":"ἔτι","lemma":"ἔτι","type":"adverb","code":"D"},{"form":"κηρύσσω,","lemma":"κηρύσσω","type":"verb","code":"V"},{"form":"τί","lemma":"τίς","type":"interrogative_pronoun","code":"RI"},{"form":"ἔτι","lemma":"ἔτι","type":"adverb","code":"D"},{"form":"διώκομαι;","lemma":"διώκω","type":"verb","code":"V"},{"form":"ἄρα","lemma":"ἄρα","type":"conjunction","code":"C"},{"form":"κατήργηται","lemma":"καταργέω","type":"verb","code":"V"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"σκάνδαλον","lemma":"σκάνδαλον","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"art