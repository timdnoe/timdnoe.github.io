":"N"},{"form":"Ἰησοῦ,","lemma":"Ἰησοῦς","type":"noun","code":"N"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"ἡμᾶς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"⸀καταδουλώσουσιν—","lemma":"καταδουλόω","type":"verb","code":"V"}]},{"v":5,"ref":"Gal 2:5","grc":"οἷς οὐδὲ πρὸς ὥραν εἴξαμεν τῇ ὑποταγῇ, ἵνα ἡ ἀλήθεια τοῦ εὐαγγελίου διαμείνῃ πρὸς ὑμᾶς.","lemmas":["ὅς","οὐδέ","πρός","ὥρα","εἴκω","ὁ","ὑποταγή","ἵνα","ἀλήθεια","εὐαγγέλιον","διαμένω","σύ"],"tr":"to [the ones] whom not even towards [an] hour [we] yielded to the submission, so that the truth of the good news might remain towards you [all].","para":null,"para_continued":false,"words":[{"form":"οἷς","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"οὐδὲ","lemma":"οὐδέ","type":"adverb","code":"D"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"ὥραν","lemma":"ὥρα","type":"noun","code":"N"},{"form":"εἴξαμεν","lemma":"εἴκω","type":"verb","code":"V"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ὑποταγῇ,","lemma":"ὑποταγή","type":"noun","code":"N"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀλήθεια","lemma":"ἀλήθεια","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"εὐαγγελίου","lemma":"εὐαγγέλιον","type":"noun","code":"N"},{"form":"διαμείνῃ","lemma":"διαμένω","type":"verb","code":"V"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"ὑμᾶς.","lemma":"σύ","type":"personal_pronoun","code":"RP"}]},{"v":6,"ref":"Gal 2:6","grc":"ἀπὸ δὲ τῶν δοκούντων εἶναί τι— ὁποῖοί ποτε ἦσαν οὐδέν μοι διαφέρει· πρόσωπον ⸀θεὸς ἀνθρώπου οὐ λαμβάνει— ἐμοὶ γὰρ οἱ δοκοῦντες οὐδὲν προσανέθεντο,","lemmas":["ἀπό","δέ","ὁ","δοκέω","εἰμί","τις","ὁποῖος","ποτε","οὐδείς","ἐγώ","διαφέρω","πρόσωπον","θεός","ἄνθρωπος","οὐ","λαμβάνω","γάρ","προσανατίθημι"],"tr":"But from the [ones] seeming to be something—what sort [they] once were, differs nothing to me; God does not receive the face of [a] person— for the [ones] seeming contributed nothing to me.","para":null,"para_continued":false,"words":[{"form":"ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"δοκούντων","lemma":"δοκέω","type":"verb","code":"V"},{"form":"εἶναί","lemma":"εἰμί","type":"verb","code":"V"},{"form":"τι—","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"ὁποῖοί","lemma":"ὁποῖος","type":"interrogative_pronoun","code":"RI"},{"form":"ποτε","lemma":"ποτε","type":"adverb","code":"D"},{"form":"ἦσαν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"οὐδέν","lemma":"οὐδείς","type":"adjective","code":"A"},{"form":"μοι","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"διαφέρει·","lemma":"διαφέρω","type":"verb","code":"V"},{"form":"πρόσωπον","lemma":"πρόσωπον","type":"noun","code":"N"},{"form":"⸀θεὸς","lemma":"θεός","type":"noun","code":"N"},{"form":"ἀνθρώπου","lemma":"ἄνθρωπος","type":"noun","code":"N"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"λαμβάνει—","lemma":"λαμβάνω","type":"verb","code":"V"},{"form":"ἐμοὶ","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δοκοῦντες","lemma":"δοκέω","type":"verb","code":"V"},{"form":"οὐδὲν","lemma":"οὐδείς","type":"adjective","code":"A"},{"form":"προσανέθεντο,","lemma":"προσανατίθημι","type":"verb","code":"V"}]},{"v":7,"ref":"Gal 2:7","grc":"ἀλλὰ τοὐναντίον ἰδόντες ὅτι πεπίστευμαι τὸ εὐαγγέλιον τῆς ἀκροβυστίας καθὼς Πέτρος τῆς περιτομῆς,","lemmas":["ἀλλά","τοὐναντίον","ὁράω","ὅτι","πιστεύω","ὁ","εὐαγγέλιον","ἀκροβυστία","καθώς","Πέτρος","περιτομή"],"tr":"Rather of the opposite, [they], having seen that [I] have been trusted [with respect to] the good news of the foreskin just as Peter