":"ὁ","type":"article","code":"RA"},{"form":"ἔθνη,","lemma":"ἔθνος","type":"noun","code":"N"}]},{"v":9,"ref":"Gal 2:9","grc":"καὶ γνόντες τὴν χάριν τὴν δοθεῖσάν μοι, Ἰάκωβος καὶ Κηφᾶς καὶ Ἰωάννης, οἱ δοκοῦντες στῦλοι εἶναι, δεξιὰς ἔδωκαν ἐμοὶ καὶ Βαρναβᾷ κοινωνίας, ἵνα ⸀ἡμεῖς εἰς τὰ ἔθνη, αὐτοὶ δὲ εἰς τὴν περιτομήν·","lemmas":["καί","γινώσκω","ὁ","χάρις","δίδωμι","ἐγώ","Ἰάκωβος","Κηφᾶς","Ἰωάννης","δοκέω","στῦλος","εἰμί","δεξιός","Βαρναβᾶς","κοινωνία","ἵνα","εἰς","ἔθνος","αὐτός","δέ","περιτομή"],"tr":"and, having recognized the grace having been given to me, James and Cephas and John, the [ones] seeming to be pillars, gave [the] right [hand] of fellowship to me and to Barnabas, so that we [might go] into the nations, but they into the circumcision;","para":null,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"γνόντες","lemma":"γινώσκω","type":"verb","code":"V"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"χάριν","lemma":"χάρις","type":"noun","code":"N"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"δοθεῖσάν","lemma":"δίδωμι","type":"verb","code":"V"},{"form":"μοι,","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"Ἰάκωβος","lemma":"Ἰάκωβος","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"Κηφᾶς","lemma":"Κηφᾶς","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"Ἰωάννης,","lemma":"Ἰωάννης","type":"noun","code":"N"},{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δοκοῦντες","lemma":"δοκέω","type":"verb","code":"V"},{"form":"στῦλοι","lemma":"στῦλος","type":"noun","code":"N"},{"form":"εἶναι,","lemma":"εἰμί","type":"verb","code":"V"},{"form":"δεξιὰς","lemma":"δεξιός","type":"adjective","code":"A"},{"form":"ἔδωκαν","lemma":"δίδωμι","type":"verb","code":"V"},{"form":"ἐμοὶ","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"Βαρναβᾷ","lemma":"Βαρναβᾶς","type":"noun","code":"N"},{"form":"κοινωνίας,","lemma":"κοινωνία","type":"noun","code":"N"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"⸀ἡμεῖς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἔθνη,","lemma":"ἔθνος","type":"noun","code":"N"},{"form":"αὐτοὶ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"περιτομήν·","lemma":"περιτομή","type":"noun","code":"N"}]},{"v":10,"ref":"Gal 2:10","grc":"μόνον τῶν πτωχῶν ἵνα μνημονεύωμεν, ὃ καὶ ἐσπούδασα αὐτὸ τοῦτο ποιῆσαι.","lemmas":["μόνος","ὁ","πτωχός","ἵνα","μνημονεύω","ὅς","καί","σπουδάζω","αὐτός","οὗτος","ποιέω"],"tr":"only so that [we] may remember the poor, which also [I] was eager to have done this same [thing].","para":null,"para_continued":false,"words":[{"form":"μόνον","lemma":"μόνος","type":"adjective","code":"A"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"πτωχῶν","lemma":"πτωχός","type":"adjective","code":"A"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"μνημονεύωμεν,","lemma":"μνημονεύω","type":"verb","code":"V"},{"form":"ὃ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"ἐσπούδασα","lemma":"σπουδάζω","type":"verb","code":"V"},{"form":"αὐτὸ","lemma":"αὐτός","type":"adjective","code":"A"},{"form":"τοῦτο","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"ποιῆσαι.","lemma":"ποιέω","type":"verb","code":"V"}]},{"v":11,"ref":"Gal 2:11","grc":"Ὅτε δὲ ἦλθεν ⸀Κηφᾶς εἰς Ἀντιόχειαν, κατὰ πρόσωπον αὐτῷ ἀντέστην, ὅτι κατεγνωσμένος ἦν·","lemmas":["ὅτε","δέ","ἔρχομαι","Κηφᾶς","εἰς","Ἀντιόχεια","κατά","πρόσωπον","αὐτός","ἀνθίστημι","ὅτι","καταγινώσκω","εἰμί"],"tr":"But when Cephas came into Antioch, against [the] face to him [I] stood , because [he] was having had been condemned.","para":null,"para_continued":false,"words":[{"form":"Ὅτε","lemma":"ὅτε","type":"conjunction","code":"C"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἦλθεν","lemma":"ἔρχομαι","type":"verb","code":"V"},{"form":"⸀Κηφᾶς","lemma":"Κηφᾶς","type":"noun","code":"N"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"Ἀντιόχειαν,","lemma":"Ἀντιόχεια","type":"noun","code":"N"},{"form":"κατὰ","lemma":"κατά","type":"preposition","code":"P"},{"form":"πρόσωπον","lemma":"πρόσωπον","type":"noun","code":"N"},{"form":"αὐτῷ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἀντέστην,","lemma":"ἀνθίστημι","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"κατεγνωσμένος","lemma":"καταγινώσκω","type":"verb","code":"V"},{"form":"ἦν·","lemma":"εἰμί","type":"verb","code":"V"}]},{"v":12,"ref":"Gal 2:12","grc":"πρὸ τοῦ γὰρ ἐλθεῖν τινας ἀπὸ Ἰακώβου μετὰ τῶν ἐθνῶν συνήσθιεν· ὅτε δὲ ⸀ἦλθον, ὑπέστελλεν καὶ ἀφώριζεν ἑαυτόν, φοβούμενος τοὺς ἐκ περιτομῆς.","lemmas":["πρό","ὁ","γάρ","ἔρχομαι","τις","ἀπό","Ἰάκωβος","μετά","ἔθνος","συνεσθίω","ὅτε","δέ","ὑποστέλλω","καί","ἀφορίζω","ἑαυτοῦ","φοβέομαι","ἐκ","περιτομή"],"tr":"For before the coming of certain [ones] from James, [he] was eating together with the gentiles; but when [they] came, [he] was shrinking back and separating himself, fearing the [ones] out of [the] circumcision.","para":null,"para_continued":false,"words":[{"form":"πρὸ","lemma":"πρό","type":"preposition","code":"P"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"ἐλθεῖν","lemma":"ἔρχομαι","type":"verb","code":"V"},{"form":"τινας","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"Ἰακώβου","lemma":"Ἰάκωβος","type":"noun","code":"N"},{"form":"μετὰ","lemma":"μετά","type":"preposition","code":"P"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἐθνῶν","lemma":"ἔθνος","type":"noun","code":"N"},{"form":"συνήσθιεν·","lemma":"συνεσθίω","type":"verb","code":"V"},{"form":"ὅτε","lemma":"ὅτε","type":"conjunction","code":"C"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"⸀ἦλθον,","lemma":"ἔρχομαι","type":"verb","code":"V"},{"form":"ὑπέστελλεν","lemma":"ὑποστέλλω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἀφώριζεν","lemma":"ἀφορίζω","type":"verb","code":"V"},{"form":"ἑαυτόν,","lemma":"ἑαυτοῦ","type":"personal_pronoun","code":"RP"},{"form":"φοβούμενος","lemma":"φοβέομαι","type":"verb","code":"V"},{"form":"τοὺς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἐκ","lemma":"ἐκ","type":"preposition","code":"P"},{"form":"περιτομῆς.","lemma":"περιτομή","type":"noun","code":"N"}]},{"v":13,"ref":"Gal 2:13","grc":"καὶ συνυπεκρίθησαν αὐτῷ ⸀καὶ οἱ λοιποὶ Ἰουδαῖοι, ὥστε καὶ Βαρναβᾶς συναπήχθη αὐτῶν τῇ ὑποκρίσει.","lemmas":["καί","συνυποκρίνομαι","αὐτός","ὁ","λοιπός","Ἰουδαῖος","ὥστε","Βαρναβᾶς","συναπάγω","ὑπόκρισις"],"tr":"And even the rest [of the] Jews hypocritized with him, so that even Barnabas was carried away with them [with] hypocrisy.","para":null,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"συνυπεκρίθησαν","lemma":"συνυποκρίνομαι","type":"verb","code":"V"},{"form":"αὐτῷ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"⸀καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"λοιποὶ","lemma":"λοιπός","type":"adjective","code":"A"},{"form":"Ἰουδαῖοι,","lemma":"Ἰουδαῖος","type":"adjective","code":"A"},{"form":"ὥστε","lemma":"ὥστε","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"adverb","code"