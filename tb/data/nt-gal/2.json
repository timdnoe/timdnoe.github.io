ὐ","δικαιόω","ἄνθρωπος","ἐκ","ἔργον","νόμος","ἐάν","μή","διά","πίστις","Ἰησοῦς","Χριστός","καί","ἐγώ","εἰς","πιστεύω","ἵνα","πᾶς","σάρξ"],"tr":"but knowing that [a] person is not justified out of works of law except through faith of Jesus Christ, and we believed into Christ Jesus so that [we] might be justified out of faith of Christ and not out of works of law, because out of works of law all flesh will not be justified.","para":null,"para_continued":false,"words":[{"form":"εἰδότες","lemma":"οἶδα","type":"verb","code":"V"},{"form":"⸀δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"δικαιοῦται","lemma":"δικαιόω","type":"verb","code":"V"},{"form":"ἄνθρωπος","lemma":"ἄνθρωπος","type":"noun","code":"N"},{"form":"ἐξ","lemma":"ἐκ","type":"preposition","code":"P"},{"form":"ἔργων","lemma":"ἔργον","type":"noun","code":"N"},{"form":"νόμου","lemma":"νόμος","type":"noun","code":"N"},{"form":"ἐὰν","lemma":"ἐάν","type":"conjunction","code":"C"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"πίστεως","lemma":"πίστις","type":"noun","code":"N"},{"form":"⸂Ἰησοῦ","lemma":"Ἰησοῦς","type":"noun","code":"N"},{"form":"Χριστοῦ⸃,","lemma":"Χριστός","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"ἡμεῖς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"Χριστὸν","lemma":"Χριστός","type":"noun","code":"N"},{"form":"Ἰησοῦν","lemma":"Ἰησοῦς","type":"noun","code":"N"},{"form":"ἐπιστεύσαμεν,","lemma":"πιστεύω","type":"verb","code":"V"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"δικαιωθῶμεν","lemma":"δικαιόω","type":"verb","code":"V"},{"form":"ἐκ","lemma":"ἐκ","type":"preposition","code":"P"},{"form":"πίστεως","lemma":"πίστις","type":"noun","code":"N"},{"form"