ώ","type":"personal_pronoun","code":"RP"},{"form":"ὅταν","lemma":"ὅταν","type":"conjunction","code":"C"},{"form":"πειρασμοῖς","lemma":"πειρασμός","type":"noun","code":"N"},{"form":"περιπέσητε","lemma":"περιπίπτω","type":"verb","code":"V"},{"form":"ποικίλοις,","lemma":"ποικίλος","type":"adjective","code":"A"}]},{"v":3,"ref":"Jas 1:3","grc":"γινώσκοντες ὅτι τὸ δοκίμιον ὑμῶν τῆς πίστεως κατεργάζεται ὑπομονήν·","lemmas":["γινώσκω","ὅτι","ὁ","δοκίμιον","σύ","πίστις","κατεργάζομαι","ὑπομονή"],"tr":"knowing that the testing of faith of you [all] produces endurance.","para":null,"para_continued":false,"words":[{"form":"γινώσκοντες","lemma":"γινώσκω","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δοκίμιον","lemma":"δοκίμιον","type":"noun","code":"N"},{"form":"ὑμῶν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"πίστεως","lemma":"πίστις","type":"noun","code":"N"},{"form":"κατεργάζεται","lemma":"κατεργάζομαι","type":"verb","code":"V"},{"form":"ὑπομονήν·","lemma":"ὑπομονή","type":"noun","code":"N"}]},{"v":4,"ref":"Jas 1:4","grc":"ἡ δὲ ὑπομονὴ ἔργον τέλειον ἐχέτω, ἵνα ἦτε τέλειοι καὶ ὁλόκληροι, ἐν μηδενὶ λειπόμενοι.","lemmas":["ὁ","δέ","ὑπομονή","ἔργον","τέλειος","ἔχω","ἵνα","εἰμί","καί","ὁλόκληρος","ἐν","μηδείς","λείπω"],"tr":"But may the endurance have [a] perfect work so that [you all] may be perfect and whole, being left behind in nothing.","para":null,"para_continued":false,"words":[{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ὑπομονὴ","lemma":"ὑπομονή","type":"noun","code":"N"},{"form":"ἔργον","lemma":"ἔργον","type":"noun","code":"N"},{"form":"τέλειον","lemma":"τέλειος","type":"adjective","code":"A"},{"form":"ἐχέτω,","lemma":"ἔχω","type":"verb","code":"V"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"ἦ