","code":"C"},{"form":"περισσείαν","lemma":"περισσεία","type":"noun","code":"N"},{"form":"κακίας","lemma":"κακία","type":"noun","code":"N"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"πραΰτητι","lemma":"πραΰτης","type":"noun","code":"N"},{"form":"δέξασθε","lemma":"δέχομαι","type":"verb","code":"V"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἔμφυτον","lemma":"ἔμφυτος","type":"adjective","code":"A"},{"form":"λόγον","lemma":"λόγος","type":"noun","code":"N"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"δυνάμενον","lemma":"δύναμαι","type":"verb","code":"V"},{"form":"σῶσαι","lemma":"σώζω","type":"verb","code":"V"},{"form":"τὰς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ψυχὰς","lemma":"ψυχή","type":"noun","code":"N"},{"form":"ὑμῶν.","lemma":"σύ","type":"personal_pronoun","code":"RP"}]},{"v":22,"ref":"Jas 1:22","grc":"Γίνεσθε δὲ ποιηταὶ λόγου καὶ μὴ ⸂ἀκροαταὶ μόνον⸃ παραλογιζόμενοι ἑαυτούς.","lemmas":["γίνομαι","δέ","ποιητής","λόγος","καί","μή","ἀκροατής","μόνος","παραλογίζομαι","ἑαυτοῦ"],"tr":"But become doers of [the] word and not hearers only, deceiving yourselves,","para":null,"para_continued":false,"words":[{"form":"Γίνεσθε","lemma":"γίνομαι","type":"verb","code":"V"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ποιηταὶ","lemma":"ποιητής","type":"noun","code":"N"},{"form":"λόγου","lemma":"λόγος","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"⸂ἀκροαταὶ","lemma":"ἀκροατής","type":"noun","code":"N"},{"form":"μόνον⸃","lemma":"μόνος","type":"adjective","code":"A"},{"form":"παραλογιζόμενοι","lemma":"παραλογίζομαι","type":"verb","code":"V"},{"form":"ἑαυτούς.","lemma":"ἑαυτοῦ","type":"personal_pronoun","code":"RP"}]},{"v":23,"ref":"Jas 1:23","grc":"ὅτι εἴ τις ἀκροατὴς λόγου ἐστὶν καὶ οὐ ποιητής, οὗτος ἔοικεν ἀνδρὶ κατανοοῦντι τὸ πρόσωπον τῆς γενέσεως αὐτοῦ ἐν ἐσόπτρῳ,","lemmas":[