":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἥλιος","lemma":"ἥλιος","type":"noun","code":"N"},{"form":"σὺν","lemma":"σύν","type":"preposition","code":"P"},{"form":"τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"καύσωνι","lemma":"καύσων","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐξήρανεν","lemma":"ξηραίνω","type":"verb","code":"V"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"χόρτον,","lemma":"χόρτος","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἄνθος","lemma":"ἄνθος","type":"noun","code":"N"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἐξέπεσεν","lemma":"ἐκπίπτω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"εὐπρέπεια","lemma":"εὐπρέπεια","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"προσώπου","lemma":"πρόσωπον","type":"noun","code":"N"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἀπώλετο·","lemma":"ἀπόλλυμι","type":"verb","code":"V"},{"form":"οὕτως","lemma":"οὕτως","type":"adverb","code":"D"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πλούσιος","lemma":"πλούσιος","type":"adjective","code":"A"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"ταῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"πορείαις","lemma":"πορεία","type":"noun","code":"N"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"μαρανθήσεται.","lemma":"μαραίνομαι","type":"verb","code":"V"}]},{"v":12,"ref":"Jas 1:12","grc":"Μακάριος ἀνὴρ ὃς ὑπομένει πειρασμόν, ὅτι δόκιμος γενόμενος λήμψεται τὸν στέφαν