ὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"λαμβάνετε,","lemma":"λαμβάνω","type":"verb","code":"V"},{"form":"διότι","lemma":"διότι","type":"conjunction","code":"C"},{"form":"κακῶς","lemma":"κακῶς","type":"adverb","code":"D"},{"form":"αἰτεῖσθε,","lemma":"αἰτέω","type":"verb","code":"V"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"ταῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἡδοναῖς","lemma":"ἡδονή","type":"noun","code":"N"},{"form":"ὑμῶν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"δαπανήσητε.","lemma":"δαπανάω","type":"verb","code":"V"}]},{"v":4,"ref":"Jas 4:4","grc":"⸀μοιχαλίδες, οὐκ οἴδατε ὅτι ἡ φιλία τοῦ κόσμου ἔχθρα τοῦ θεοῦ ἐστιν; ὃς ⸀ἐὰν οὖν βουληθῇ φίλος εἶναι τοῦ κόσμου, ἐχθρὸς τοῦ θεοῦ καθίσταται.","lemmas":["μοιχαλίς","οὐ","οἶδα","ὅτι","ὁ","φιλία","κόσμος","ἔχθρα","θεός","εἰμί","ὅς","ἐάν","οὖν","βούλομαι","φίλος","ἐχθρός","καθίστημι"],"tr":"Adulteresses, do [you all] not know that the friendship of the world [is] enmity of God? Therefore, whoever, if [he] might wish to be [a] friend of the world, is established [as an] enemy of God.","para":null,"para_continued":false,"words":[{"form":"⸀μοιχαλίδες,","lemma":"μοιχαλίς","type":"adjective","code":"A"},{"form":"οὐκ","lemma":"οὐ","type":"particle","code":"X"},{"form":"οἴδατε","lemma":"οἶδα","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"φιλία","lemma":"φιλία","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"κόσμου","lemma":"κόσμος","type":"noun","code":"N"},{"form":"ἔχθρα","lemma":"ἔχθρα","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεοῦ","lemma":"θεός","type":"noun","code":"N"},{"form":"ἐστιν;","lemma":"εἰμί","type":"verb","code":"V"},{"form":