","code":"C"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"ἑνί,","lemma":"εἷς","type":"adjective","code":"A"},{"form":"γέγονεν","lemma":"γίνομαι","type":"verb","code":"V"},{"form":"πάντων","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"ἔνοχος.","lemma":"ἔνοχος","type":"adjective","code":"A"}]},{"v":11,"ref":"Jas 2:11","grc":"ὁ γὰρ εἰπών Μὴ ⸀μοιχεύσῃς εἶπεν καί Μὴ ⸀φονεύσῃς· εἰ δὲ οὐ ⸂μοιχεύεις φονεύεις⸃ δέ, γέγονας παραβάτης νόμου.","lemmas":["ὁ","γάρ","λέγω","μή","μοιχεύω","καί","φονεύω","εἰ","δέ","οὐ","γίνομαι","παραβάτης","νόμος"],"tr":"For the [one] having said, “[You] might not commit adultery,” said also “[You] might not murder.” But if [you] do not commit adultery but [you] murder [you] have become [a] transgressor of law.","para":null,"para_continued":false,"words":[{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"εἰπών","lemma":"λέγω","type":"verb","code":"V"},{"form":"Μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"⸀μοιχεύσῃς","lemma":"μοιχεύω","type":"verb","code":"V"},{"form":"εἶπεν","lemma":"λέγω","type":"verb","code":"V"},{"form":"καί","lemma":"καί","type":"adverb","code":"D"},{"form":"Μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"⸀φονεύσῃς·","lemma":"φονεύω","type":"verb","code":"V"},{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"⸂μοιχεύεις","lemma":"μοιχεύω","type":"verb","code":"V"},{"form":"φονεύεις⸃","lemma":"φονεύω","type":"verb","code":"V"},{"form":"δέ,","lemma":"δέ","type":"conjunction","code":"C"},{"form":"γέγονας","lemma":"γίνομαι","type":"verb","code":"V"},{"form":"παραβάτης","lemma":"παραβάτης","type":"noun","code":"N"},{"form":"νόμου.","lemma":"νόμος","type":"noun","code":"N"}]},{"v":12,"ref":"Jas 2:12","grc":"οὕτως λαλεῖτε καὶ οὕτως ποιεῖτε ὡς διὰ νόμου ἐλευθερίας μέλλοντες κρίνεσθαι.","lem