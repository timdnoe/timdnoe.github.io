para":null,"para_continued":false,"words":[{"form":"οὐκ","lemma":"οὐ","type":"particle","code":"X"},{"form":"αὐτοὶ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"βλασφημοῦσιν","lemma":"βλασφημέω","type":"verb","code":"V"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"καλὸν","lemma":"καλός","type":"adjective","code":"A"},{"form":"ὄνομα","lemma":"ὄνομα","type":"noun","code":"N"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἐπικληθὲν","lemma":"ἐπικαλέω","type":"verb","code":"V"},{"form":"ἐφ’","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"ὑμᾶς;","lemma":"σύ","type":"personal_pronoun","code":"RP"}]},{"v":8,"ref":"Jas 2:8","grc":"Εἰ μέντοι νόμον τελεῖτε βασιλικὸν κατὰ τὴν γραφήν Ἀγαπήσεις τὸν πλησίον σου ὡς σεαυτόν, καλῶς ποιεῖτε·","lemmas":["εἰ","μέντοι","νόμος","τελέω","βασιλικός","κατά","ὁ","γραφή","ἀγαπάω","πλησίον","σύ","ὡς","σεαυτοῦ","καλῶς","ποιέω"],"tr":"However, indeed if [you all] pay royal law according to the scripture, “[You] will love your neighbor as yourself,” [you all] do well.","para":null,"para_continued":false,"words":[{"form":"Εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"μέντοι","lemma":"μέντοι","type":"conjunction","code":"C"},{"form":"νόμον","lemma":"νόμος","type":"noun","code":"N"},{"form":"τελεῖτε","lemma":"τελέω","type":"verb","code":"V"},{"form":"βασιλικὸν","lemma":"βασιλικός","type":"adjective","code":"A"},{"form":"κατὰ","lemma":"κατά","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"γραφήν","lemma":"γραφή","type":"noun","code":"N"},{"form":"Ἀγαπήσεις","lemma":"ἀγαπάω","type":"verb","code":"V"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"πλησίον","lemma":"πλησίον","type":"adverb","code":"D"},{"form":"σου","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"σεαυτόν,","lemma":"σεαυτοῦ","type":"personal_pronoun","code":"RP"},{"form":"