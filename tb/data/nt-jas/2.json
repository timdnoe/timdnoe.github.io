ctive","code":"A"},{"form":"ἐστιν;","lemma":"εἰμί","type":"verb","code":"V"}]},{"v":21,"ref":"Jas 2:21","grc":"Ἀβραὰμ ὁ πατὴρ ἡμῶν οὐκ ἐξ ἔργων ἐδικαιώθη, ἀνενέγκας Ἰσαὰκ τὸν υἱὸν αὐτοῦ ἐπὶ τὸ θυσιαστήριον;","lemmas":["Ἀβραάμ","ὁ","πατήρ","ἐγώ","οὐ","ἐκ","ἔργον","δικαιόω","ἀναφέρω","Ἰσαάκ","υἱός","αὐτός","ἐπί","θυσιαστήριον"],"tr":"Was not Abraham our father justified out of works, having brought up Isaac, his son, upon the altar?","para":null,"para_continued":false,"words":[{"form":"Ἀβραὰμ","lemma":"Ἀβραάμ","type":"noun","code":"N"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πατὴρ","lemma":"πατήρ","type":"noun","code":"N"},{"form":"ἡμῶν","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"οὐκ","lemma":"οὐ","type":"particle","code":"X"},{"form":"ἐξ","lemma":"ἐκ","type":"preposition","code":"P"},{"form":"ἔργων","lemma":"ἔργον","type":"noun","code":"N"},{"form":"ἐδικαιώθη,","lemma":"δικαιόω","type":"verb","code":"V"},{"form":"ἀνενέγκας","lemma":"ἀναφέρω","type":"verb","code":"V"},{"form":"Ἰσαὰκ","lemma":"Ἰσαάκ","type":"noun","code":"N"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"υἱὸν","lemma":"υἱός","type":"noun","code":"N"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἐπὶ","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θυσιαστήριον;","lemma":"θυσιαστήριον","type":"noun","code":"N"}]},{"v":22,"ref":"Jas 2:22","grc":"βλέπεις ὅτι ἡ πίστις συνήργει τοῖς ἔργοις αὐτοῦ καὶ ἐκ τῶν ἔργων ἡ πίστις ἐτελειώθη,","lemmas":["βλέπω","ὅτι","ὁ","πίστις","συνεργέω","ἔργον","αὐτός","καί","ἐκ","τελειόω"],"tr":"[You] see that the faith was working together [with] his deeds and out of the works the faith was perfected,","para":null,"para_continued":false,"words":[{"form":"βλέπεις","lemma":"βλέπω","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form