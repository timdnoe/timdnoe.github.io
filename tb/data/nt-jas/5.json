{"book":"nt-jas","book_name":"Epistle of James","chapter":5,"chapter_label":"5","prev":4,"next":null,"verses":[{"v":1,"ref":"Jas 5:1","grc":"Ἄγε νῦν οἱ πλούσιοι, κλαύσατε ὀλολύζοντες ἐπὶ ταῖς ταλαιπωρίαις ὑμῶν ταῖς ἐπερχομέναις.","lemmas":["ἄγω","νῦν","ὁ","πλούσιος","κλαίω","ὀλολύζω","ἐπί","ταλαιπωρία","σύ","ἐπέρχομαι"],"tr":"Come now, the rich [ones], weep, howling upon [all] your hardships coming upon [you all].","para":null,"para_continued":false,"words":[{"form":"Ἄγε","lemma":"ἄγω","type":"verb","code":"V"},{"form":"νῦν","lemma":"νῦν","type":"adverb","code":"D"},{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πλούσιοι,","lemma":"πλούσιος","type":"adjective","code":"A"},{"form":"κλαύσατε","lemma":"κλαίω","type":"verb","code":"V"},{"form":"ὀλολύζοντες","lemma":"ὀλολύζω","type":"verb","code":"V"},{"form":"ἐπὶ","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"ταῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ταλαιπωρίαις","lemma":"ταλαιπωρία","type":"noun","code":"N"},{"form":"ὑμῶν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"ταῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἐπερχομέναις.","lemma":"ἐπέρχομαι","type":"verb","code":"V"}]},{"v":2,"ref":"Jas 5:2","grc":"ὁ πλοῦτος ὑμῶν σέσηπεν, καὶ τὰ ἱμάτια ὑμῶν σητόβρωτα γέγονεν,","lemmas":["ὁ","πλοῦτος","σύ","σήπω","καί","ἱμάτιον","σητόβρωτος","γίνομαι"],"tr":"[All] your wealth has rotted and [the collection of all] your clothes has become moth-eaten,","para":null,"para_continued":false,"words":[{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πλοῦτος","lemma":"πλοῦτος","type":"noun","code":"N"},{"form":"ὑμῶν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"σέσηπεν,","lemma":"σήπω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἱμάτια","lemma":"ἱμάτιον","type":"noun","code":"N"},{"form":"ὑμῶν","lemma":"σύ","type":"personal_pronoun","cod