ctive","code":"A"},{"form":"πηδαλίου","lemma":"πηδάλιον","type":"noun","code":"N"},{"form":"ὅπου","lemma":"ὅπου","type":"conjunction","code":"C"},{"form":"⸂ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ὁρμὴ","lemma":"ὁρμή","type":"noun","code":"N"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"εὐθύνοντος","lemma":"εὐθύνω","type":"verb","code":"V"},{"form":"βούλεται⸃·","lemma":"βούλομαι","type":"verb","code":"V"}]},{"v":5,"ref":"Jas 3:5","grc":"οὕτως καὶ ἡ γλῶσσα μικρὸν μέλος ἐστὶν καὶ ⸂μεγάλα αὐχεῖ⸃. Ἰδοὺ ⸀ἡλίκον πῦρ ἡλίκην ὕλην ἀνάπτει·","lemmas":["οὕτως","καί","ὁ","γλῶσσα","μικρός","μέλος","εἰμί","μέγας","αὐχέω","ἰδού","ἡλίκος","πῦρ","ὕλη","ἀνάπτω"],"tr":"Thus also the tongue is [a] little part and [it] boasts greatly. Behold how great [a] fire, how great [a] forest [it] kindles!","para":null,"para_continued":false,"words":[{"form":"οὕτως","lemma":"οὕτως","type":"adverb","code":"D"},{"form":"καὶ","lemma":"καί","type":"adverb","code":"D"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"γλῶσσα","lemma":"γλῶσσα","type":"noun","code":"N"},{"form":"μικρὸν","lemma":"μικρός","type":"adjective","code":"A"},{"form":"μέλος","lemma":"μέλος","type":"noun","code":"N"},{"form":"ἐστὶν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"⸂μεγάλα","lemma":"μέγας","type":"adjective","code":"A"},{"form":"αὐχεῖ⸃.","lemma":"αὐχέω","type":"verb","code":"V"},{"form":"Ἰδοὺ","lemma":"ἰδού","type":"particle","code":"X"},{"form":"⸀ἡλίκον","lemma":"ἡλίκος","type":"interrogative_pronoun","code":"RI"},{"form":"πῦρ","lemma":"πῦρ","type":"noun","code":"N"},{"form":"ἡλίκην","lemma":"ἡλίκος","type":"interrogative_pronoun","code":"RI"},{"form":"ὕλην","lemma":"ὕλη","type":"noun","code":"N"},{"form":"ἀνάπτει·","lemma":"ἀνάπτω","type":"verb","code":"V"}]},{"v":6,"ref":"Jas 3:6","grc":"καὶ ἡ γλῶσσα πῦρ, ὁ κόσμος τῆς ⸀ἀδικίας ἡ γλῶσσα καθίσταται ἐν τοῖς μέλεσιν ἡμῶν, ἡ σπιλοῦσα ὅλον τὸ σῶμα καὶ φλογίζουσα τὸν τροχὸν τῆς γενέσεως καὶ φλογιζομένη ὑπὸ τῆς γεέννης.","lemmas":["καί","ὁ","γλῶσσα","πῦρ","κόσμος","ἀδικία","καθίστημι","ἐν","μέλος","ἐγώ","σπιλόω","ὅλος","σῶμα","φλογίζω","τροχός","γένεσις","ὑπό","γέεννα"],"tr":"And the tongue [is] fire, the world of the unrighteousness; the tongue is appointed in our members, the [thing] staining the whole body and setting on fire the wheel of the birth and being set on fire by Gehenna.","para":null,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"γλῶσσα","lemma":"γλῶσσα","type":"noun","code":"N"},{"form":"πῦρ,","lemma":"πῦρ","type":"noun","code":"N"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"κόσμος","lemma":"κόσμος","type":"noun","code":"N"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"⸀ἀδικίας","lemma":"ἀδικία","type":"noun","code":"N"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"γλῶσσα","lemma":"γλῶσσα","type":"noun","code":"N"},{"form":"καθίσταται","lemma":"καθίστημι","type":"verb","code":"V"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"τοῖς","lemma":"ὁ","type":"article","code":"RA"},{"form":"μέλεσιν","lemma":"μέλος","type":"noun","code":"N"},{"form":"ἡμῶν,","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"σπιλοῦσα","lemma":"σπιλόω","type":"verb","code":"V"},{"form":"ὅλον","lemma":"ὅλος","type":"adjective","code":"A"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"σῶμα","lemma":"σῶμα","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"φλογίζουσα","lemma":"φλογίζω","type":"verb","code":"V"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"τροχὸν","lemma":"τροχός","type":"noun","code":"N"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"γενέσεως","lemma":"γένεσις","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"φλογιζομένη","lemma":"φλογίζω","type":"verb","code":"V"},{"form":"ὑπὸ","lemma":"ὑπό","type":"preposition","code":"P"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"γεέννης.","lemma":"γέεννα","type":"noun","code":"N"}]},{"v":7,"ref":"Jas 3:7","grc":"πᾶσα γὰρ φύσις θηρίων τε καὶ πετεινῶν ἑρπετῶν τε καὶ ἐναλίων δαμάζεται καὶ δεδάμασται τῇ φύσει τῇ ἀνθρωπίνῃ·","lemmas":["πᾶς","γάρ","φύσις","θηρίον","τέ","καί","πετεινόν","ἑρπετόν","ἐνάλιον","δαμάζω","ὁ","ἀνθρώπινος"],"tr":"For every nature, both of birds and of crawling things, both [ones] of creeping and [ones] of the sea, is subdued and has been subdued [with] the human nature.","para":null,"para_continued":false,"words":[{"form":"πᾶσα","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"φύσις","lemma":"φύσις","type":"noun","code":"N"},{"form":"θηρίων","lemma":"θηρίον","type":"noun","code":"N"},{"form":"τε","lemma":"τέ","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"πετεινῶν","lemma":"πετεινόν","type":"adjective","code":"A"},{"form":"ἑρπετῶν","lemma":"ἑρπετόν","type":"noun","code":"N"},{"form":"τε","lemma":"τέ","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐναλίων","lemma":"ἐνάλιον","type":"adjective","code":"A"},{"form":"δαμάζεται","lemma":"δαμάζω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"δεδάμασται","lemma":"δαμάζω","type":"verb","code":"V"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"φύσει","lemma":"φύσις","type":"noun","code":"N"},{"form":"τῇ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀνθρωπίνῃ·","lemma":"ἀνθρώπινος","type":"adjective","code":"A"}]},{"v":8,"ref":"Jas 3:8","grc":"τὴν δὲ γλῶσσαν οὐδεὶς ⸂δαμάσαι δύναται ἀνθρώπων⸃· ⸀ἀκατάστατον κακόν, μεστὴ ἰοῦ θα