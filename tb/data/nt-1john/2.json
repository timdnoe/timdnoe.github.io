{"book":"nt-1john","book_name":"First Epistle of John","chapter":2,"chapter_label":"2","prev":1,"next":3,"verses":[{"v":1,"ref":"1John 2:1","grc":"Τεκνία μου, ταῦτα γράφω ὑμῖν ἵνα μὴ ἁμάρτητε. καὶ ἐάν τις ἁμάρτῃ, παράκλητον ἔχομεν πρὸς τὸν πατέρα Ἰησοῦν Χριστὸν δίκαιον,","lemmas":["τεκνίον","ἐγώ","οὗτος","γράφω","σύ","ἵνα","μή","ἁμαρτάνω","καί","ἐάν","τις","παράκλητος","ἔχω","πρός","ὁ","πατήρ","Ἰησοῦς","Χριστός","δίκαιος"],"tr":"My children, these [things I] write to you [all] so that you [all] might not sin. And if [a] certain [one] might sin, [we] have [a] Paraclete towards the father, Jesus Christ, [the] righteous,","para":1,"para_continued":false,"words":[{"form":"Τεκνία","lemma":"τεκνίον","type":"noun","code":"N"},{"form":"μου,","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"ταῦτα","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"γράφω","lemma":"γράφω","type":"verb","code":"V"},{"form":"ὑμῖν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"ἁμάρτητε.","lemma":"ἁμαρτάνω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐάν","lemma":"ἐάν","type":"conjunction","code":"C"},{"form":"τις","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"ἁμάρτῃ,","lemma":"ἁμαρτάνω","type":"verb","code":"V"},{"form":"παράκλητον","lemma":"παράκλητος","type":"noun","code":"N"},{"form":"ἔχομεν","lemma":"ἔχω","type":"verb","code":"V"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"πατέρα","lemma":"πατήρ","type":"noun","code":"N"},{"form":"Ἰησοῦν","lemma":"Ἰησοῦς","type":"noun","code":"N"},{"form":"Χριστὸν","lemma":"Χριστός","type":"noun","code":"N"},{"form":"δίκαιον,","lemma":"δίκαιος","type":"adjective","code":"A"}]},{"v":2,"ref":"1John 2:2","grc":"καὶ αὐτὸς ἱλασμός ἐστιν περὶ τῶν ἁμαρτ