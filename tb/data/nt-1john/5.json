e":"C"},{"form":"οἴδαμεν","lemma":"οἶδα","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"ἀκούει","lemma":"ἀκούω","type":"verb","code":"V"},{"form":"ἡμῶν","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"ὃ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"⸀ἐὰν","lemma":"ἐάν","type":"particle","code":"X"},{"form":"αἰτώμεθα,","lemma":"αἰτέω","type":"verb","code":"V"},{"form":"οἴδαμεν","lemma":"οἶδα","type":"verb","code":"V"},{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"ἔχομεν","lemma":"ἔχω","type":"verb","code":"V"},{"form":"τὰ","lemma":"ὁ","type":"article","code":"RA"},{"form":"αἰτήματα","lemma":"αἴτημα","type":"noun","code":"N"},{"form":"ἃ","lemma":"ὅς","type":"relative_pronoun","code":"RR"},{"form":"ᾐτήκαμεν","lemma":"αἰτέω","type":"verb","code":"V"},{"form":"⸀ἀπ’","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"αὐτοῦ.","lemma":"αὐτός","type":"personal_pronoun","code":"RP"}]},{"v":16,"ref":"1John 5:16","grc":"ἐάν τις ἴδῃ τὸν ἀδελφὸν αὐτοῦ ἁμαρτάνοντα ἁμαρτίαν μὴ πρὸς θάνατον, αἰτήσει, καὶ δώσει αὐτῷ ζωήν, τοῖς ἁμαρτάνουσιν μὴ πρὸς θάνατον. ἔστιν ἁμαρτία πρὸς θάνατον· οὐ περὶ ἐκείνης λέγω ἵνα ἐρωτήσῃ.","lemmas":["ἐάν","τις","ὁράω","ὁ","ἀδελφός","αὐτός","ἁμαρτάνω","ἁμαρτία","μή","πρός","θάνατος","αἰτέω","καί","δίδωμι","ζωή","εἰμί","οὐ","περί","ἐκεῖνος","λέγω","ἵνα","ἐρωτάω"],"tr":"If [a] certain [one] might see his brother sinning [a] sin not towards death, [he] will ask, and [he] will give to him life, to the [ones] sinning not towards death. [There] is [a] sin towards death; [I] say so that [he] might not ask about that [one].","para":1,"para_continued":false,"words":[{"form":"ἐάν","lemma":"ἐάν","type":"conjunction","code":"C"},{"form":"τις","lemma":"τις","type":"interrogative_pronoun","code":"RI"},{"form":"ἴδῃ","lemma":"ὁράω","type":"verb","code":"V"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀδελφὸν","lemma":"ἀδελφός","type":"noun","code