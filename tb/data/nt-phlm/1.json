","code":"N"}]},{"v":14,"ref":"Phlm 1:14","grc":"χωρὶς δὲ τῆς σῆς γνώμης οὐδὲν ἠθέλησα ποιῆσαι, ἵνα μὴ ὡς κατὰ ἀνάγκην τὸ ἀγαθόν σου ᾖ ἀλλὰ κατὰ ἑκούσιον·","lemmas":["χωρίς","δέ","ὁ","σός","γνώμη","οὐδείς","θέλω","ποιέω","ἵνα","μή","ὡς","κατά","ἀνάγκη","ἀγαθός","σύ","εἰμί","ἀλλά","ἑκούσιος"],"tr":"but without your purpose [I] desired to have done nothing, so that your good may not be as by necessity, rather by voluntary.","para":null,"para_continued":false,"words":[{"form":"χωρὶς","lemma":"χωρίς","type":"preposition","code":"P"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"σῆς","lemma":"σός","type":"adjective","code":"A"},{"form":"γνώμης","lemma":"γνώμη","type":"noun","code":"N"},{"form":"οὐδὲν","lemma":"οὐδείς","type":"adjective","code":"A"},{"form":"ἠθέλησα","lemma":"θέλω","type":"verb","code":"V"},{"form":"ποιῆσαι,","lemma":"ποιέω","type":"verb","code":"V"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"κατὰ","lemma":"κατά","type":"preposition","code":"P"},{"form":"ἀνάγκην","lemma":"ἀνάγκη","type":"noun","code":"N"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀγαθόν","lemma":"ἀγαθός","type":"adjective","code":"A"},{"form":"σου","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"ᾖ","lemma":"εἰμί","type":"verb","code":"V"},{"form":"ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"κατὰ","lemma":"κατά","type":"preposition","code":"P"},{"form":"ἑκούσιον·","lemma":"ἑκούσιος","type":"adjective","code":"A"}]},{"v":15,"ref":"Phlm 1:15","grc":"τάχα γὰρ διὰ τοῦτο ἐχωρίσθη πρὸς ὥραν ἵνα αἰώνιον αὐτὸν ἀπέχῃς,","lemmas":["τάχα","γάρ","διά","οὗτος","χωρίζω","πρός","ὥρα","ἵνα","αἰώνιος","αὐτός","ἀπέχω"],"tr":"For presently because of this [he] was separated towards [an] hour so that [you] might abstain him eternally,","para":null,"para_continued":false,"words":[{"form":"τάχα","lemma":"τάχα","type":"adverb","code":"D"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"τοῦτο","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"ἐχωρίσθη","lemma":"χωρίζω","type":"verb","code":"V"},{"form":"πρὸς","lemma":"πρός","type":"preposition","code":"P"},{"form":"ὥραν","lemma":"ὥρα","type":"noun","code":"N"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"αἰώνιον","lemma":"αἰώνιος","type":"adjective","code":"A"},{"form":"αὐτὸν","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἀπέχῃς,","lemma":"ἀπέχω","type":"verb","code":"V"}]},{"v":16,"ref":"Phlm 1:16","grc":"οὐκέτι ὡς δοῦλον ἀλλὰ ὑπὲρ δοῦλον, ἀδελφὸν ἀγαπητόν, μάλιστα ἐμοί, πόσῳ δὲ μᾶλλον σοὶ καὶ ἐν σαρκὶ καὶ ἐν κυρίῳ.","lemmas":["οὐκέτι","ὡς","δοῦλος","ἀλλά","ὑπέρ","ἀδελφός","ἀγαπητός","μάλιστα","ἐγώ","πόσος","δέ","μᾶλλον","σύ","καί","ἐν","σάρξ","κύριος"],"tr":"no longer as [a] servant, rather over [a] servant, [a] beloved brother, especially to me, but how much more to you both in flesh and in [the] lord.","para":null,"para_continued":false,"words":[{"form":"οὐκέτι","lemma":"οὐκέτι","type":"adverb","code":"D"},{"form":"ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"δοῦλον","lemma":"δοῦλος","type":"noun","code":"N"},{"form":"ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"ὑπὲρ","lemma":"ὑπέρ","type":"preposition","code":"P"},{"form":"δοῦλον,","lemma":"δοῦλος","type":"noun","code":"N"},{"form":"ἀδελφὸν","lemma":"ἀδελφός","type":"noun","code":"N"},{"form":"ἀγαπητόν,","lemma":"ἀγαπητός","type":"adjective","code":"A"},{"form":"μάλιστα","lemma":"μάλιστα","type":"adverb","code":"D"},{"form":"ἐμοί,","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"πόσῳ","lemma":"πόσος","type":"interrogative_pronoun","code":"RI"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"μᾶλλ