αλμός","type":"noun","code":"N"},{"form":"ἔμπροσθεν","lemma":"ἔμπροσθεν","type":"adverb","code":"D"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ὄπισθεν·","lemma":"ὄπισθεν","type":"adverb","code":"D"}]},{"v":7,"ref":"Rev 4:7","grc":"καὶ τὸ ζῷον τὸ πρῶτον ὅμοιον λέοντι, καὶ τὸ δεύτερον ζῷον ὅμοιον μόσχῳ, καὶ τὸ τρίτον ζῷον ⸀ἔχων ⸂τὸ πρόσωπον ὡς⸃ ἀνθρώπου, καὶ τὸ τέταρτον ζῷον ὅμοιον ἀετῷ πετομένῳ·","lemmas":["καί","ὁ","ζῶον","πρῶτος","ὅμοιος","λέων","δεύτερος","μόσχος","τρίτος","ἔχω","πρόσωπον","ὡς","ἄνθρωπος","τέταρτος","ἀετός","πέτομαι"],"tr":"and the first animal [was] similar to [a] lion and the second living creature [was] similar to [a] calf and the third animal [was] having the face as of [a] person, and the fourth animal [was] similar to [a] flying vulture.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ζῷον","lemma":"ζῶον","type":"noun","code":"N"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πρῶτον","lemma":"πρῶτος","type":"adjective","code":"A"},{"form":"ὅμοιον","lemma":"ὅμοιος","type":"adjective","code":"A"},{"form":"λέοντι,","lemma":"λέων","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"δεύτερον","lemma":"δεύτερος","type":"adjective","code":"A"},{"form":"ζῷον","lemma":"ζῶον","type":"noun","code":"N"},{"form":"ὅμοιον","lemma":"ὅμοιος","type":"adjective","code":"A"},{"form":"μόσχῳ,","lemma":"μόσχος","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"τρίτον","lemma":"τρίτος","type":"adjective","code":"A"},{"form":"ζῷον","lemma":"ζῶον","type":"noun","code":"N"},{"form":"⸀ἔχων","lemma":"ἔχω","type":"verb","code":"V"},{"form":"⸂τὸ","lemma":"ὁ","type":"article","code":"RA"},{"form":"πρόσωπον","lemma"