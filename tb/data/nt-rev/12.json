":"θρόνος","type":"noun","code":"N"},{"form":"αὐτοῦ.","lemma":"αὐτός","type":"personal_pronoun","code":"RP"}]},{"v":6,"ref":"Rev 12:6","grc":"καὶ ἡ γυνὴ ἔφυγεν εἰς τὴν ἔρημον, ὅπου ἔχει ἐκεῖ τόπον ἡτοιμασμένον ⸀ἀπὸ τοῦ θεοῦ, ἵνα ἐκεῖ ⸀τρέφωσιν αὐτὴν ἡμέρας χιλίας διακοσίας ἑξήκοντα.","lemmas":["καί","ὁ","γυνή","φεύγω","εἰς","ἔρημος","ὅπου","ἔχω","ἐκεῖ","τόπος","ἑτοιμάζω","ἀπό","θεός","ἵνα","τρέφω","αὐτός","ἡμέρα","χίλιοι","διακόσιοι","ἑξήκοντα"],"tr":"And the woman fled into the wilderness, where [she] has there [a] place having had been prepared from God, so that there [they] may feed her [for] one thousand two hundred sixty days.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἡ","lemma":"ὁ","type":"article","code":"RA"},{"form":"γυνὴ","lemma":"γυνή","type":"noun","code":"N"},{"form":"ἔφυγεν","lemma":"φεύγω","type":"verb","code":"V"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἔρημον,","lemma":"ἔρημος","type":"adjective","code":"A"},{"form":"ὅπου","lemma":"ὅπου","type":"adverb","code":"D"},{"form":"ἔχει","lemma":"ἔχω","type":"verb","code":"V"},{"form":"ἐκεῖ","lemma":"ἐκεῖ","type":"adverb","code":"D"},{"form":"τόπον","lemma":"τόπος","type":"noun","code":"N"},{"form":"ἡτοιμασμένον","lemma":"ἑτοιμάζω","type":"verb","code":"V"},{"form":"⸀ἀπὸ","lemma":"ἀπό","type":"preposition","code":"P"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεοῦ,","lemma":"θεός","type":"noun","code":"N"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"ἐκεῖ","lemma":"ἐκεῖ","type":"adverb","code":"D"},{"form":"⸀τρέφωσιν","lemma":"τρέφω","type":"verb","code":"V"},{"form":"αὐτὴν","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἡμέρας","lemma":"ἡμέρα","type":"noun","code":"N"},{"form":"χιλίας","lemma":"χίλιοι","type":"adjective","code":"A"},{"form":"διακοσίας","lemma":"διακόσιοι","type":"adjective