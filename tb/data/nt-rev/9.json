ρον, εἰ μὴ τοὺς ἀνθρώπους οἵτινες οὐκ ἔχουσι τὴν σφραγῖδα τοῦ θεοῦ ἐπὶ τῶν ⸀μετώπων.","lemmas":["καί","λέγω","αὐτός","ἵνα","μή","ἀδικέω","ὁ","χόρτος","γῆ","οὐδέ","πᾶς","χλωρός","δένδρον","εἰ","ἄνθρωπος","ὅστις","οὐ","ἔχω","σφραγίς","θεός","ἐπί","μέτωπον"],"tr":"And [it] was said to them so that [they] will not wrong the grass of the earth nor every green [thing] nor every tree, except the people who do not have the seal of God upon the foreheads.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐρρέθη","lemma":"λέγω","type":"verb","code":"V"},{"form":"αὐταῖς","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ἵνα","lemma":"ἵνα","type":"conjunction","code":"C"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"⸀ἀδικήσουσιν","lemma":"ἀδικέω","type":"verb","code":"V"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"χόρτον","lemma":"χόρτος","type":"noun","code":"N"},{"form":"τῆς","lemma":"ὁ","type":"article","code":"RA"},{"form":"γῆς","lemma":"γῆ","type":"noun","code":"N"},{"form":"οὐδὲ","lemma":"οὐδέ","type":"conjunction","code":"C"},{"form":"πᾶν","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"χλωρὸν","lemma":"χλωρός","type":"adjective","code":"A"},{"form":"οὐδὲ","lemma":"οὐδέ","type":"conjunction","code":"C"},{"form":"πᾶν","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"δένδρον,","lemma":"δένδρον","type":"noun","code":"N"},{"form":"εἰ","lemma":"εἰ","type":"conjunction","code":"C"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"τοὺς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀνθρώπους","lemma":"ἄνθρωπος","type":"noun","code":"N"},{"form":"οἵτινες","lemma":"ὅστις","type":"relative_pronoun","code":"RR"},{"form":"οὐκ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"ἔχουσι","lemma":"ἔχω","type":"verb","code":"V"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"σφραγῖδα","lemma":"σφραγίς","type":"noun","code":"N"}