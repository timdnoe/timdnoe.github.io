","lemma":"ὄνομα","type":"noun","code":"N"},{"form":"αὐτοῦ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"τὴν","lemma":"ὁ","type":"article","code":"RA"},{"form":"σκηνὴν","lemma":"σκηνή","type":"noun","code":"N"},{"form":"αὐτοῦ,","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"τοὺς","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"τῷ","lemma":"ὁ","type":"article","code":"RA"},{"form":"οὐρανῷ","lemma":"οὐρανός","type":"noun","code":"N"},{"form":"σκηνοῦντας.","lemma":"σκηνόω","type":"verb","code":"V"}]},{"v":7,"ref":"Rev 13:7","grc":"καὶ ἐδόθη αὐτῷ ποιῆσαι πόλεμον μετὰ τῶν ἁγίων καὶ νικῆσαι αὐτούς, καὶ ἐδόθη αὐτῷ ἐξουσία ἐπὶ πᾶσαν φυλὴν καὶ λαὸν καὶ γλῶσσαν καὶ ἔθνος.","lemmas":["καί","δίδωμι","αὐτός","ποιέω","πόλεμος","μετά","ὁ","ἅγιος","νικάω","ἐξουσία","ἐπί","πᾶς","φυλή","λαός","γλῶσσα","ἔθνος"],"tr":"And [it] was given to him to have made war with the holy [ones] and to have conquered them, and authority upon every tribe and people and tongue and nation was given to him.","para":1,"para_continued":false,"words":[{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐδόθη","lemma":"δίδωμι","type":"verb","code":"V"},{"form":"αὐτῷ","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"ποιῆσαι","lemma":"ποιέω","type":"verb","code":"V"},{"form":"πόλεμον","lemma":"πόλεμος","type":"noun","code":"N"},{"form":"μετὰ","lemma":"μετά","type":"preposition","code":"P"},{"form":"τῶν","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἁγίων","lemma":"ἅγιος","type":"adjective","code":"A"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"νικῆσαι","lemma":"νικάω","type":"verb","code":"V"},{"form":"αὐτούς,","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἐδόθη","lemma":"δίδωμι","type":"verb","code":"V"},{"form"