","code":"RP"},{"form":"υἱοὶ","lemma":"υἱός","type":"noun","code":"N"},{"form":"φωτός","lemma":"φῶς","type":"noun","code":"N"},{"form":"ἐστε","lemma":"εἰμί","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"υἱοὶ","lemma":"υἱός","type":"noun","code":"N"},{"form":"ἡμέρας.","lemma":"ἡμέρα","type":"noun","code":"N"},{"form":"οὐκ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"ἐσμὲν","lemma":"εἰμί","type":"verb","code":"V"},{"form":"νυκτὸς","lemma":"νύξ","type":"noun","code":"N"},{"form":"οὐδὲ","lemma":"οὐδέ","type":"conjunction","code":"C"},{"form":"σκότους·","lemma":"σκότος","type":"noun","code":"N"}]},{"v":6,"ref":"1Thess 5:6","grc":"ἄρα οὖν μὴ καθεύδωμεν ⸀ὡς οἱ λοιποί, ἀλλὰ γρηγορῶμεν καὶ νήφωμεν.","lemmas":["ἄρα","οὖν","μή","καθεύδω","ὡς","ὁ","λοιπός","ἀλλά","γρηγορέω","καί","νήφω"],"tr":"Therefore, then, may [we] not sleep as the rest, rather may [we] be alert and be sober.","para":null,"para_continued":false,"words":[{"form":"ἄρα","lemma":"ἄρα","type":"conjunction","code":"C"},{"form":"οὖν","lemma":"οὖν","type":"conjunction","code":"C"},{"form":"μὴ","lemma":"μή","type":"adverb","code":"D"},{"form":"καθεύδωμεν","lemma":"καθεύδω","type":"verb","code":"V"},{"form":"⸀ὡς","lemma":"ὡς","type":"conjunction","code":"C"},{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"λοιποί,","lemma":"λοιπός","type":"adjective","code":"A"},{"form":"ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"γρηγορῶμεν","lemma":"γρηγορέω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"νήφωμεν.","lemma":"νήφω","type":"verb","code":"V"}]},{"v":7,"ref":"1Thess 5:7","grc":"οἱ γὰρ καθεύδοντες νυκτὸς καθεύδουσιν, καὶ οἱ μεθυσκόμενοι νυκτὸς μεθύουσιν·","lemmas":["ὁ","γάρ","καθεύδω","νύξ","καί","μεθύσκομαι","μεθύω"],"tr":"For the [ones] sleeping sleep [by] night, and the [ones] getting drunk, get drunk [by] night.","para":null,"para_continued":false,"words":[{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"καθεύδοντες","lemma":"καθεύδω","type":"verb","code":"V"},{"form":"νυκτὸς","lemma":"νύξ","type":"noun","code":"N"},{"form":"καθεύδουσιν,","lemma":"καθεύδω","type":"verb","code":"V"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"οἱ","lemma":"ὁ","type":"article","code":"RA"},{"form":"μεθυσκόμενοι","lemma":"μεθύσκομαι","type":"verb","code":"V"},{"form":"νυκτὸς","lemma":"νύξ","type":"noun","code":"N"},{"form":"μεθύουσιν·","lemma":"μεθύω","type":"verb","code":"V"}]},{"v":8,"ref":"1Thess 5:8","grc":"ἡμεῖς δὲ ἡμέρας ὄντες νήφωμεν, ἐνδυσάμενοι θώρακα πίστεως καὶ ἀγάπης καὶ περικεφαλαίαν ἐλπίδα σωτηρίας·","lemmas":["ἐγώ","δέ","ἡμέρα","εἰμί","νήφω","ἐνδύω","θώραξ","πίστις","καί","ἀγάπη","περικεφαλαία","ἐλπίς","σωτηρία"],"tr":"But we, being of the day, may [we] be sober, having put on [the] breastplate of faith and love and [a] helmet [as] hope of salvation.","para":null,"para_continued":false,"words":[{"form":"ἡμεῖς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"δὲ","lemma":"δέ","type":"conjunction","code":"C"},{"form":"ἡμέρας","lemma":"ἡμέρα","type":"noun","code":"N"},{"form":"ὄντες","lemma":"εἰμί","type":"verb","code":"V"},{"form":"νήφωμεν,","lemma":"νήφω","type":"verb","code":"V"},{"form":"ἐνδυσάμενοι","lemma":"ἐνδύω","type":"verb","code":"V"},{"form":"θώρακα","lemma":"θώραξ","type":"noun","code":"N"},{"form":"πίστεως","lemma":"πίστις","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"ἀγάπης","lemma":"ἀγάπη","type":"noun","code":"N"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"περικεφαλαίαν","lemma":"περικεφαλαία","type":"noun","code":"N"},{"form":"ἐλπίδα","lemma":"ἐλπίς","type":"noun","code":"N"},{"form":"σωτηρίας·","lemma":"σωτηρία","type":"noun","code":"N"}]},{"v":9,"ref":"1Thess 5:9","grc":"ὅτι οὐκ ἔθετο ἡμᾶς ὁ θεὸς εἰς ὀργὴν ἀλλὰ εἰς περιποίησιν σωτηρίας διὰ τοῦ κυρίου ἡμῶν Ἰησοῦ Χριστοῦ,","lemmas":["ὅτι","οὐ","τίθημι","ἐγώ","ὁ","θεός","εἰς","ὀργή","ἀλλά","περιποίησις","σωτηρία","διά","κύριος","Ἰησοῦς","Χριστός"],"tr":"Because God did not appoint us into wrath, rather into making about of salvation through our lord Jesus Christ,","para":null,"para_continued":false,"words":[{"form":"ὅτι","lemma":"ὅτι","type":"conjunction","code":"C"},{"form":"οὐκ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"ἔθετο","lemma":"τίθημι","type":"verb","code":"V"},{"form":"ἡμᾶς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεὸς","lemma":"θεός","type":"noun","code":"N"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"ὀργὴν","lemma":"ὀργή","type":"noun","code":"N"},{"form":"ἀλλὰ","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"εἰς","lemma":"εἰς","type":"preposition","code":"P"},{"form":"περιποίησιν","lemma":"περιποίησις","type":"noun","code":"N"},{"form":"σωτηρίας","lemma":"σωτηρία","type":"noun","code":"N"},{"form":"διὰ","lemma":"διά","type":"preposition","code":"P"},{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"κυρίου","lemma":"κύριος","type":"noun","code":"N"},{"form":"ἡμῶν","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"Ἰησοῦ","lemma":"Ἰησοῦς","type":"noun","code":"N"},{"form":"Χριστοῦ,","lemma":"Χριστός","type":"noun","code":"N"}]},{"v":10,"ref":"1Thess 5:10","grc":"τοῦ ἀποθανόντος ⸀περὶ ἡμῶν ἵνα εἴτε γρηγορῶμεν εἴτε καθεύδωμεν ἅμα σὺν αὐτῷ ζήσωμεν.","lemmas":["ὁ","ἀποθνήσκω","περί","ἐγώ","ἵνα","εἴτε","γρηγορέω","καθεύδω","ἅμα","σύν","αὐτός","ζάω"],"tr":"the [one] having died about us, so that whether [we] may be alert or [we] may sleep, we [might] live with him at the same time.","para":null,"para_continued":false,"words":[{"form":"τοῦ","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀποθανόντος","lemma":"ἀποθνήσκω","type":"verb","code":"V"},{"form":"⸀περὶ","lemma":"περί","type":"preposition","code":