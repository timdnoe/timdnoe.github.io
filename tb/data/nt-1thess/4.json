ματι","lemma":"πρᾶγμα","type":"noun","code":"N"},{"form":"τὸν","lemma":"ὁ","type":"article","code":"RA"},{"form":"ἀδελφὸν","lemma":"ἀδελφός","type":"noun","code":"N"},{"form":"αὐτοῦ,","lemma":"αὐτός","type":"personal_pronoun","code":"RP"},{"form":"διότι","lemma":"διότι","type":"conjunction","code":"C"},{"form":"ἔκδικος","lemma":"ἔκδικος","type":"adjective","code":"A"},{"form":"⸀κύριος","lemma":"κύριος","type":"noun","code":"N"},{"form":"περὶ","lemma":"περί","type":"preposition","code":"P"},{"form":"πάντων","lemma":"πᾶς","type":"adjective","code":"A"},{"form":"τούτων,","lemma":"οὗτος","type":"demonstrative_pronoun","code":"RD"},{"form":"καθὼς","lemma":"καθώς","type":"conjunction","code":"C"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"προείπαμεν","lemma":"προλέγω","type":"verb","code":"V"},{"form":"ὑμῖν","lemma":"σύ","type":"personal_pronoun","code":"RP"},{"form":"καὶ","lemma":"καί","type":"conjunction","code":"C"},{"form":"διεμαρτυράμεθα.","lemma":"διαμαρτύρομαι","type":"verb","code":"V"}]},{"v":7,"ref":"1Thess 4:7","grc":"οὐ γὰρ ἐκάλεσεν ἡμᾶς ὁ θεὸς ἐπὶ ἀκαθαρσίᾳ ἀλλ’ ἐν ἁγιασμῷ.","lemmas":["οὐ","γάρ","καλέω","ἐγώ","ὁ","θεός","ἐπί","ἀκαθαρσία","ἀλλά","ἐν","ἁγιασμός"],"tr":"For God did not call us upon impurity, rather in holiness.","para":null,"para_continued":false,"words":[{"form":"οὐ","lemma":"οὐ","type":"adverb","code":"D"},{"form":"γὰρ","lemma":"γάρ","type":"conjunction","code":"C"},{"form":"ἐκάλεσεν","lemma":"καλέω","type":"verb","code":"V"},{"form":"ἡμᾶς","lemma":"ἐγώ","type":"personal_pronoun","code":"RP"},{"form":"ὁ","lemma":"ὁ","type":"article","code":"RA"},{"form":"θεὸς","lemma":"θεός","type":"noun","code":"N"},{"form":"ἐπὶ","lemma":"ἐπί","type":"preposition","code":"P"},{"form":"ἀκαθαρσίᾳ","lemma":"ἀκαθαρσία","type":"noun","code":"N"},{"form":"ἀλλ’","lemma":"ἀλλά","type":"conjunction","code":"C"},{"form":"ἐν","lemma":"ἐν","type":"preposition","code":"P"},{"form":"ἁγιασμῷ.","lemma":"ἁγιασμός","type":"noun","code":"N"}]},{"v":8,"