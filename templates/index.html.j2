{#- Generated into index.html by build.py. Do not edit index.html directly; edit cv.yml. -#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ basics.name }}</title>
  <meta name="description" content="Academic homepage and curriculum vitae of {{ basics.name }}.">
  <meta property="og:title" content="{{ basics.name }}">
  <meta property="og:description" content="Academic homepage and curriculum vitae of {{ basics.name }}.">
  <meta property="og:type" content="website">
  <link rel="stylesheet" href="styles.css" media="screen">
  <link rel="stylesheet" href="print.css" media="print">
</head>
<body>
  <header class="site-header">
    <nav class="nav" aria-label="Primary">
      <a class="nav__brand" href="#top">{{ basics.name | replace(" ", "&nbsp;") | safe }}</a>
      <button class="nav__toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav__menu" id="nav-menu">
        {% if basics.summary %}<li><a href="#about">About</a></li>{% endif %}
        {% if projects %}<li><a href="#research">Research</a></li>{% endif %}
        {% if education %}<li><a href="#education">Education</a></li>{% endif %}
        {% if ventures or employment %}<li><a href="#experience">Experience</a></li>{% endif %}
        {% if languages or skills %}<li><a href="#skills">Skills</a></li>{% endif %}
        {% if service %}<li><a href="#service">Service</a></li>{% endif %}
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>
  </header>

  <main id="top">
    <!-- ============================== HERO ============================== -->
    <section class="hero">
      <div class="container hero__inner">
        {% if basics.photo %}<img class="hero__photo" src="{{ basics.photo }}" alt="Portrait of {{ basics.name }}">{% endif %}
        <div class="hero__text">
          <h1 class="hero__name">{{ basics.name }}</h1>
          {% if basics.title %}<p class="hero__role">{{ basics.title }}</p>{% endif %}
          {% if basics.affiliation %}<p class="hero__affil">{{ basics.affiliation }}{% if basics.location %} &middot; {{ basics.location }}{% endif %}</p>{% endif %}
          {% if basics.tagline %}<p class="hero__tagline">{{ basics.tagline }}</p>{% endif %}
          <div class="hero__links">
            <a class="btn btn--primary screen-only" href="assets/CV.pdf">Download CV (PDF)</a>
            {% if basics.email %}<a class="btn contact-link" href="mailto:{{ basics.email }}">{{ basics.email }}</a>{% endif %}
            {% if basics.phone %}<span class="btn contact-link print-only">{{ basics.phone }}</span>{% endif %}
            {% for link in links if link.url %}<a class="btn contact-link" href="{{ link.url }}">{{ link.label }}</a>{% endfor %}
          </div>
        </div>
      </div>
    </section>

    <!-- ============================== ABOUT ============================== -->
    {% if basics.summary %}
    <section id="about" class="section">
      <div class="container">
        <h2 class="section__title">About</h2>
        <p>{{ basics.summary }}</p>
      </div>
    </section>
    {% endif %}

    <!-- ====================== RESEARCH & PROJECTS ======================= -->
    {% if projects %}
    <section id="research" class="section section--alt">
      <div class="container">
        <h2 class="section__title">Research &amp; Projects</h2>
        <ul class="cards">
          {% for p in projects %}
          <li class="card">
            <p class="card__title">{{ p.title }}</p>
            {% if p.desc %}<p class="card__desc">{{ p.desc }}</p>{% endif %}
          </li>
          {% endfor %}
        </ul>
      </div>
    </section>
    {% endif %}

    <!-- ============================ EDUCATION =========================== -->
    {% if education %}
    <section id="education" class="section">
      <div class="container">
        <h2 class="section__title">Education</h2>
        <ul class="timeline">
          {% for e in education %}
          <li class="timeline__item">
            <span class="timeline__date">{{ e.period }}</span>
            <div>
              <p class="timeline__head">{{ e.what }}</p>
              <p class="timeline__sub">{{ e.where }}{% if e.note %} &middot; {{ e.note }}{% endif %}</p>
            </div>
          </li>
          {% endfor %}
        </ul>
      </div>
    </section>
    {% endif %}

    <!-- =========================== EXPERIENCE =========================== -->
    {% if ventures or employment %}
    <section id="experience" class="section section--alt">
      <div class="container">
        <h2 class="section__title">Experience</h2>

        {% if ventures %}
        <h3 class="subhead">Ventures</h3>
        <ul class="timeline">
          {% for v in ventures %}
          <li class="timeline__item">
            <span class="timeline__date">{{ v.period }}</span>
            <div>
              <p class="timeline__head">{{ v.what }}</p>
              {% if v.note %}<p class="timeline__sub">{{ v.note }}</p>{% endif %}
            </div>
          </li>
          {% endfor %}
        </ul>
        {% endif %}

        {% if employment %}
        <h3 class="subhead">Employment</h3>
        <ul class="timeline">
          {% for j in employment %}
          <li class="timeline__item">
            <span class="timeline__date">{{ j.period }}</span>
            <div>
              <p class="timeline__head">{{ j.what }}{% if j.where %} &middot; {{ j.where }}{% endif %}</p>
              {% if j.note %}<p class="timeline__sub">{{ j.note }}</p>{% endif %}
            </div>
          </li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
    </section>
    {% endif %}

    <!-- ====================== LANGUAGES & SKILLS ======================== -->
    {% if languages or skills %}
    <section id="skills" class="section">
      <div class="container">
        <h2 class="section__title">Languages &amp; Skills</h2>

        {% if languages %}
        {% for group, items in languages.items() %}
        <div class="skillrow">
          <span class="skillrow__label">{{ group | capitalize }}</span>
          <ul class="tags">{% for it in items %}<li class="tag">{{ it }}</li>{% endfor %}</ul>
        </div>
        {% endfor %}
        {% endif %}

        {% if skills %}
        {% for group, items in skills.items() %}
        <div class="skillrow">
          <span class="skillrow__label">{{ group }}</span>
          <ul class="tags">{% for it in items %}<li class="tag">{{ it }}</li>{% endfor %}</ul>
        </div>
        {% endfor %}
        {% endif %}
      </div>
    </section>
    {% endif %}

    <!-- ============================= SERVICE ============================ -->
    {% if service %}
    <section id="service" class="section section--alt">
      <div class="container">
        <h2 class="section__title">Service</h2>
        {% for group, items in service.items() %}
        <h3 class="subhead">{{ group }}</h3>
        <ul class="plain">{% for s in items %}<li>{{ s | mdbold }}</li>{% endfor %}</ul>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <!-- ============================ CONTACT ============================= -->
    <section id="contact" class="section">
      <div class="container">
        <h2 class="section__title">Contact</h2>
        <p>The best way to reach me is by email:
          <a href="mailto:{{ basics.email }}">{{ basics.email }}</a>.</p>
        {% if citizenship %}<p class="muted">Citizenship: {{ citizenship | join(" · ") }}.</p>{% endif %}
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container site-footer__inner">
      <p>&copy; <span id="year">{{ year }}</span> {{ basics.name }}.</p>
      <p class="muted screen-only">Also here: <a href="index4.9.html">The Present Testament</a>.</p>
    </div>
  </footer>

  <script>
    document.getElementById('year').textContent = new Date().getFullYear();
    (function () {
      var toggle = document.querySelector('.nav__toggle');
      var menu = document.getElementById('nav-menu');
      if (!toggle) return;
      toggle.addEventListener('click', function () {
        var open = menu.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', String(open));
      });
      menu.addEventListener('click', function (e) {
        if (e.target.tagName === 'A') {
          menu.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
        }
      });
    })();
  </script>
</body>
</html>
